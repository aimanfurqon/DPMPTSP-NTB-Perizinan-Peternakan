@model PerizinanPeternakan.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "_LoginLayout";
}

<div class="text-center mb-4">
    <img src="~/images/dpmptsp-logo.png" alt="Logo NTB" class="logo" />
    <h1 class="h3 mb-1 fw-semibold">Login Sistem</h1>
    <p class="text-muted">Sistem Perizinan Peternakan NTB</p>
</div>

<form asp-action="Login" method="post">

    <div class="mb-3">
        <label asp-for="Username" class="form-label"><i class="fas fa-user me-2 opacity-75"></i>Username</label>
        <input asp-for="Username" class="form-control form-control-lg" placeholder="Masukkan username" required />
        <span asp-validation-for="Username" class="text-danger small mt-1 d-block"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Password" class="form-label"><i class="fas fa-lock me-2 opacity-75"></i>Password</label>

        <div class="input-group">
            <input asp-for="Password" id="password-field" type="password" class="form-control form-control-lg" placeholder="Masukkan password" required />

            <span class="input-group-text" id="togglePassword">
                <i class="fas fa-eye"></i>
            </span>
        </div>
        <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
    </div>
  
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="form-check">
            <input asp-for="RememberMe" class="form-check-input" />
            <label asp-for="RememberMe" class="form-check-label">
                @Html.DisplayNameFor(m => m.RememberMe)
            </label>
        </div>

        <a asp-action="ForgotPassword" class="small text-decoration-none">Lupa Password?</a>

    </div>

    <div class="d-grid">
        <button type="submit" class="btn btn-primary btn-lg fw-bold">
            <i class="fas fa-sign-in-alt me-2"></i> Login
        </button>
    </div>

    <div class="text-center mt-4">
        <p class="text-muted mb-0">
            Belum punya akun?
            <a asp-action="Register" class="fw-medium text-decoration-none">Daftar di sini</a>
        </p>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const togglePassword = document.getElementById('togglePassword');

            if (togglePassword) {
                togglePassword.addEventListener('click', function () {
                    const icon = this.querySelector('i');
                    const passwordField = document.getElementById('password-field');

                    const type = passwordField.getAttribute('type') === 'password' ? 'text' : 'password';
                    passwordField.setAttribute('type', type);

                    icon.classList.toggle('fa-eye');
                    icon.classList.toggle('fa-eye-slash');
                });
            }
        });
    </script>
}

<style>
    .logo {
        width: 200px;
        margin-bottom: 1rem;
    }

    .btn-primary {
        background-color: #6a5af9;
        border-color: #6a5af9;
        padding-top: 0.75rem;
        padding-bottom: 0.75rem;
    }

        .btn-primary:hover {
            background-color: #5a4ae9;
            border-color: #5a4ae9;
        }

    .form-control:focus {
        border-color: #a9a2f7;
        box-shadow: 0 0 0 0.25rem rgba(106, 90, 249, 0.25);
    }

    .form-check-input:checked {
        background-color: #6a5af9;
        border-color: #6a5af9;
    }

    a {
        color: #6a5af9;
    }

        a:hover {
            color: #5a4ae9;
        }

    #togglePassword {
        cursor: pointer; 
    }
</style>
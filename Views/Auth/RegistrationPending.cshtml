@{
    ViewData["Title"] = "Pendaftaran Berhasil";
    Layout = "_LoginLayout";
}

<div class="text-center">
    <div class="mb-4">
        <i class="fas fa-paper-plane fa-4x text-primary"></i>
    </div>
    <h1 class="h3 mb-3 fw-normal">Satu Langkah Lagi!</h1>
    <p class="lead text-muted mb-4">
        Pendaftaran Anda hampir selesai. Kami telah mengirimkan email verifikasi ke alamat email yang Anda daftarkan.
    </p>
    <p>
        Silakan buka email Anda dan klik link verifikasi untuk mengaktifkan akun Anda.
    </p>
    <hr />
    <p class="mt-4">
        <a asp-action="Login" class="btn btn-secondary">Kembali ke Halaman Login</a>
    </p>
</div>

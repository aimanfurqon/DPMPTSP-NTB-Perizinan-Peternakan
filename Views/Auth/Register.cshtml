@model PerizinanPeternakan.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Registrasi";
    Layout = "_LoginLayout";
}

@* Header *@
<div class="text-center mb-4">
    <img src="~/images/dpmptsp-logo.png" alt="Logo NTB" class="logo" />
    <h1 class="h3 mb-1 fw-semibold">Buat Akun Baru</h1>
    <p class="text-muted">Sistem Perizinan Peternakan NTB</p>
</div>

@* Indikator Langkah (Step Indicator) *@
<div class="step-indicator mb-4">
    <div class="step active" data-step="1">
        <div class="step-number">1</div>
        <div class="step-title">Akun</div>
    </div>
    <div class="step-line"></div>
    <div class="step" data-step="2">
        <div class="step-number">2</div>
        <div class="step-title">Profil</div>
    </div>
</div>

<form asp-action="Register" method="post" id="registerForm">
    @* Step 1: Informasi Akun *@
    <div class="form-step active" id="step1">
        <div class="mb-3">
            <label asp-for="Username" class="form-label">Username</label>
            <input asp-for="Username" class="form-control" placeholder="Min. 3 karakter, tanpa spasi" required />
            <span asp-validation-for="Username" class="text-danger small mt-1 d-block"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Email" class="form-label">Email</label>
            <input asp-for="Email" class="form-control" placeholder="contoh@email.com" required />
            <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Password" class="form-label">Password</label>
            <input asp-for="Password" class="form-control" placeholder="Min. 6 karakter" required />
            <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
        </div>
        <div class="mb-4">
            <label asp-for="ConfirmPassword" class="form-label">Konfirmasi Password</label>
            <input asp-for="ConfirmPassword" class="form-control" placeholder="Ulangi password" required />
            <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
        </div>
        <div class="d-grid">
            <button type="button" id="btnNext" class="btn btn-primary fw-bold">Selanjutnya <i class="fas fa-arrow-right ms-2"></i></button>
        </div>
    </div>

    @* Step 2: Informasi Profil *@
    <div class="form-step" id="step2" style="display: none;">
        <div class="mb-3">
            <label asp-for="NamaLengkap" class="form-label">Nama Lengkap / Perusahaan</label>
            <input asp-for="NamaLengkap" class="form-control" placeholder="Masukkan nama Anda" required />
            <span asp-validation-for="NamaLengkap" class="text-danger small mt-1 d-block"></span>
        </div>
        <div class="mb-3">
            <label asp-for="NoTelepon" class="form-label">Nomor Telepon</label>
            <input asp-for="NoTelepon" class="form-control" placeholder="Contoh: 081234567890" required />
            <span asp-validation-for="NoTelepon" class="text-danger small mt-1 d-block"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Alamat" class="form-label">Alamat (Opsional)</label>
            <textarea asp-for="Alamat" class="form-control" rows="2"></textarea>
            <span asp-validation-for="Alamat" class="text-danger small mt-1 d-block"></span>
        </div>
        <div class="form-check mb-4">
            <input class="form-check-input" type="checkbox" id="agreeTerms" required>
            <label class="form-check-label" for="agreeTerms">
                Saya setuju dengan <a href="#" class="text-decoration-none">syarat & ketentuan</a>.
            </label>
        </div>
        <div class="d-flex gap-2">
            <button type="button" id="btnPrev" class="btn btn-outline-secondary w-50 fw-bold"><i class="fas fa-arrow-left me-2"></i> Kembali</button>
            <button type="submit" class="btn btn-success w-50 fw-bold"><i class="fas fa-user-plus me-2"></i> Daftar</button>
        </div>
    </div>

    <div class="text-center mt-4 pt-3 border-top">
        <p class="text-muted mb-0">
            Sudah punya akun?
            <a asp-action="Login" class="fw-medium text-decoration-none">Login di sini</a>
        </p>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            let currentStep = 1;
            const form = $('#registerForm');
            const validator = form.validate();

            function showStep(step) {
                $('.form-step').hide().removeClass('active');
                $('#step' + step).show().addClass('active');

                $('.step').removeClass('active');
                $('.step[data-step=' + step + ']').addClass('active');

                currentStep = step;
            }

            $('#btnNext').on('click', function () {
                let isValid = true;
                // Validasi setiap input di step 1
                $('#step1 :input[data-val]').each(function () {
                    if (!validator.element(this)) {
                        isValid = false;
                    }
                });

                if (isValid) {
                    showStep(2);
                }
            });

            $('#btnPrev').on('click', function () {
                showStep(1);
            });

            // Saat form disubmit, validasi checkbox secara manual jika diperlukan
            form.on('submit', function(e) {
                if (!$('#agreeTerms').is(':checked')) {
                    e.preventDefault();
                    // Anda bisa menambahkan notifikasi di sini
                    alert('Anda harus menyetujui syarat dan ketentuan untuk mendaftar.');
                }
            });
        });
    </script>
}

@* Style khusus untuk halaman ini (step indicator) *@
<style>
    .logo {
        width: 80px;
        margin-bottom: 1rem;
    }

    .step-indicator {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .step {
        display: flex;
        flex-direction: column;
        align-items: center;
        color: #6c757d;
        transition: color 0.3s ease;
    }

        .step.active {
            color: #6a5af9;
            font-weight: 600;
        }

    .step-number {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        border: 2px solid #ced4da;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
        background-color: #f8f9fa;
        transition: all 0.3s ease;
    }

    .step.active .step-number {
        border-color: #6a5af9;
        background-color: #6a5af9;
        color: white;
    }

    .step-title {
        font-size: 0.8rem;
        margin-top: 0.5rem;
    }

    .step-line {
        flex-grow: 1;
        max-width: 60px;
        height: 2px;
        background-color: #ced4da;
        margin: 0 1rem;
        margin-bottom: 1.8rem; /* align with numbers */
    }

    .form-step {
        animation: fadeIn 0.5s;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    .btn-primary {
        background-color: #6a5af9;
        border-color: #6a5af9;
    }

        .btn-primary:hover {
            background-color: #5a4ae9;
            border-color: #5a4ae9;
        }

    .btn-success {
        background-color: #198754;
        border-color: #198754;
    }

        .btn-success:hover {
            background-color: #157347;
            border-color: #146c43;
        }
</style>
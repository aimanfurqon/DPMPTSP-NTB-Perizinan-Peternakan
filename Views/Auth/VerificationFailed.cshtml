@{
    ViewData["Title"] = "Verifikasi Gagal";
    Layout = "_LoginLayout";
}

<div class="text-center">
    <div class="mb-4">
        <i class="fas fa-exclamation-triangle fa-4x text-danger"></i>
    </div>
    <h1 class="h3 mb-3 fw-normal">Verifikasi Gagal</h1>
    <p class="lead text-muted mb-4">
        Maaf, link verifikasi yang Anda gunakan tidak valid, sudah digunakan, atau telah kedaluwarsa.
    </p>
    <p>
        Silakan coba untuk login. Jika Anda belum menerima email, Anda bisa mencoba mendaftar kembali.
    </p>
    <hr />
    <p class="mt-4">
        <a asp-action="Login" class="btn btn-primary">Kembali ke Halaman Login</a>
    </p>
</div>

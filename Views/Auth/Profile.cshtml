@model PerizinanPeternakan.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "Profile";
}

<div class="profile-container">
    <div class="profile-header">
        <div class="header-content">
            <h1 class="profile-title">
                <i class="fas fa-user-circle"></i>
                Profile Pengguna
            </h1>
            <p class="profile-subtitle">Kelola informasi akun Anda</p>
        </div>

        <div class="header-actions">
            <a href="@Url.Action("Index", "Dashboard")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i>
                Kembali ke Dashboard
            </a>
        </div>
    </div>

    <div class="profile-content">
        <div class="profile-card">
            <div class="card-header">
                <h3>
                    <i class="fas fa-edit"></i>
                    Update Profile
                </h3>
                <p class="card-subtitle">Perbarui informasi personal Anda</p>
            </div>

            <div class="card-body">
                <form asp-action="Profile" method="post" class="profile-form">
                    <div class="form-grid">
                        <div class="form-group">
                            <label asp-for="Username" class="form-label">
                                <i class="fas fa-user"></i>
                                @Html.DisplayNameFor(m => m.Username)
                            </label>
                            <input asp-for="Username" class="form-control" readonly />
                            <small class="form-text text-muted">Username tidak dapat diubah</small>
                        </div>

                        <div class="form-group">
                            <label asp-for="Email" class="form-label required">
                                <i class="fas fa-envelope"></i>
                                @Html.DisplayNameFor(m => m.Email)
                            </label>
                            <input asp-for="Email" class="form-control" placeholder="Masukkan email aktif" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="NamaLengkap" class="form-label required">
                                <i class="fas fa-user-circle"></i>
                                @Html.DisplayNameFor(m => m.NamaLengkap)
                            </label>
                            <input asp-for="NamaLengkap" class="form-control" placeholder="Masukkan nama lengkap" />
                            <span asp-validation-for="NamaLengkap" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="NoTelepon" class="form-label required">
                                <i class="fas fa-phone"></i>
                                @Html.DisplayNameFor(m => m.NoTelepon)
                            </label>
                            <input asp-for="NoTelepon" class="form-control" placeholder="Masukkan nomor telepon" />
                            <span asp-validation-for="NoTelepon" class="text-danger"></span>
                        </div>

                        <div class="form-group full-width">
                            <label asp-for="Alamat" class="form-label">
                                <i class="fas fa-map-marker-alt"></i>
                                @Html.DisplayNameFor(m => m.Alamat)
                            </label>
                            <textarea asp-for="Alamat" class="form-control" rows="3" placeholder="Masukkan alamat lengkap"></textarea>
                            <span asp-validation-for="Alamat" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="password-section">
                        <h4 class="section-title">
                            <i class="fas fa-lock"></i>
                            Ubah Password
                        </h4>
                        <p class="section-subtitle">Kosongkan jika tidak ingin mengubah password</p>

                        <div class="form-grid">
                            <div class="form-group">
                                <label asp-for="Password" class="form-label">
                                    <i class="fas fa-key"></i>
                                    @Html.DisplayNameFor(m => m.Password)
                                </label>
                                <input asp-for="Password" class="form-control" placeholder="Masukkan password baru" />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="ConfirmPassword" class="form-label">
                                    <i class="fas fa-key"></i>
                                    @Html.DisplayNameFor(m => m.ConfirmPassword)
                                </label>
                                <input asp-for="ConfirmPassword" class="form-control" placeholder="Konfirmasi password baru" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="fas fa-save"></i>
                            Simpan Perubahan
                        </button>

                        <button type="reset" class="btn btn-outline-secondary btn-lg">
                            <i class="fas fa-undo"></i>
                            Reset
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Account Info Card -->
        <div class="info-card">
            <div class="card-header">
                <h3>
                    <i class="fas fa-info-circle"></i>
                    Informasi Akun
                </h3>
            </div>

            <div class="card-body">
                <div class="info-items">
                    <div class="info-item">
                        <div class="info-icon">
                            <i class="fas fa-user-tag"></i>
                        </div>
                        <div class="info-content">
                            <h4>Role Pengguna</h4>
                            <p>@Context.Session.GetString("Role")</p>
                        </div>
                    </div>

                    <div class="info-item">
                        <div class="info-icon">
                            <i class="fas fa-calendar-plus"></i>
                        </div>
                        <div class="info-content">
                            <h4>Tanggal Daftar</h4>
                            <p>Bergabung sejak pendaftaran akun</p>
                        </div>
                    </div>

                    <div class="info-item">
                        <div class="info-icon">
                            <i class="fas fa-shield-alt"></i>
                        </div>
                        <div class="info-content">
                            <h4>Keamanan Akun</h4>
                            <p>Password terenkripsi dengan BCrypt</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Show password strength indicator
        document.getElementById('Password').addEventListener('input', function() {
            const password = this.value;
            const strengthIndicator = document.getElementById('passwordStrength');

            if (password.length === 0) {
                if (strengthIndicator) strengthIndicator.style.display = 'none';
                return;
            }

            let strength = 0;
            if (password.length >= 6) strength++;
            if (password.match(/[a-z]/)) strength++;
            if (password.match(/[A-Z]/)) strength++;
            if (password.match(/[0-9]/)) strength++;
            if (password.match(/[^a-zA-Z0-9]/)) strength++;

            // You can add password strength indicator here if needed
        });

        // Confirm before reset
        document.querySelector('button[type="reset"]').addEventListener('click', function(e) {
            if (!confirm('Apakah Anda yakin ingin mereset semua perubahan?')) {
                e.preventDefault();
            }
        });

        // Form submission confirmation
        document.querySelector('.profile-form').addEventListener('submit', function(e) {
            const submitBtn = document.querySelector('button[type="submit"]');
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Menyimpan...';
            submitBtn.disabled = true;
        });
    </script>
}

<style>
    .profile-container {
        padding: 20px;
        max-width: 1000px;
        margin: 0 auto;
    }

    .profile-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 2px solid #e9ecef;
    }

    .header-content {
        flex: 1;
    }

    .profile-title {
        color: #333;
        margin-bottom: 8px;
        font-size: 28px;
        font-weight: 600;
    }

        .profile-title i {
            margin-right: 12px;
            color: #667eea;
        }

    .profile-subtitle {
        color: #666;
        margin: 0;
        font-size: 16px;
    }

    .header-actions {
        margin-left: 20px;
    }

    .profile-content {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 30px;
    }

    .profile-card, .info-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        overflow: hidden;
    }

    .card-header {
        background: #f8f9fa;
        padding: 20px;
        border-bottom: 1px solid #e9ecef;
    }

        .card-header h3 {
            margin: 0 0 5px 0;
            color: #333;
            font-size: 18px;
            font-weight: 600;
        }

        .card-header i {
            margin-right: 10px;
            color: #667eea;
        }

    .card-subtitle {
        margin: 0;
        color: #666;
        font-size: 14px;
    }

    .card-body {
        padding: 25px;
    }

    .profile-form {
        display: flex;
        flex-direction: column;
        gap: 25px;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

        .form-group.full-width {
            grid-column: 1 / -1;
        }

    .form-label {
        display: flex;
        align-items: center;
        margin-bottom: 8px;
        color: #333;
        font-weight: 600;
        font-size: 14px;
    }

        .form-label.required::after {
            content: '*';
            color: #dc3545;
            margin-left: 4px;
        }

        .form-label i {
            margin-right: 8px;
            color: #667eea;
            width: 16px;
        }

    .form-control {
        padding: 12px 15px;
        border: 2px solid #e1e5e9;
        border-radius: 8px;
        font-size: 16px;
        transition: all 0.3s;
    }

        .form-control:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        .form-control[readonly] {
            background-color: #f8f9fa;
            cursor: not-allowed;
        }

    .form-text {
        margin-top: 5px;
        font-size: 12px;
        color: #666;
    }

    .password-section {
        background: #f8f9fa;
        padding: 20px;
        border-radius: 8px;
        border: 1px solid #e9ecef;
    }

    .section-title {
        margin: 0 0 5px 0;
        color: #333;
        font-size: 16px;
        font-weight: 600;
    }

        .section-title i {
            margin-right: 8px;
            color: #667eea;
        }

    .section-subtitle {
        margin: 0 0 15px 0;
        color: #666;
        font-size: 14px;
    }

    .form-actions {
        display: flex;
        gap: 15px;
        padding-top: 20px;
        border-top: 1px solid #e9ecef;
    }

    .btn-lg {
        padding: 12px 24px;
        font-size: 16px;
        font-weight: 600;
        border-radius: 8px;
        transition: all 0.3s;
    }

    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.3);
        }

    .btn-outline-secondary {
        border: 2px solid #6c757d;
        color: #6c757d;
    }

        .btn-outline-secondary:hover {
            background: #6c757d;
            color: white;
            transform: translateY(-2px);
        }

    .info-items {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .info-item {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 15px;
        background: #f8f9fa;
        border-radius: 8px;
    }

    .info-icon {
        width: 40px;
        height: 40px;
        border-radius: 8px;
        background: #667eea;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        flex-shrink: 0;
    }

    .info-content h4 {
        margin: 0 0 4px 0;
        color: #333;
        font-size: 14px;
        font-weight: 600;
    }

    .info-content p {
        margin: 0;
        color: #666;
        font-size: 12px;
    }

    .text-danger {
        color: #dc3545;
        font-size: 12px;
        margin-top: 5px;
    }

    @@media (max-width: 768px) {
        .profile-container

    {
        padding: 15px;
    }

    .profile-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 15px;
    }

    .header-actions {
        margin-left: 0;
        width: 100%;
    }

        .header-actions .btn {
            width: 100%;
        }

    .profile-content {
        grid-template-columns: 1fr;
        gap: 20px;
    }

    .form-grid {
        grid-template-columns: 1fr;
    }

    .form-actions {
        flex-direction: column;
    }

        .form-actions .btn {
            width: 100%;
        }

    .profile-title {
        font-size: 24px;
    }

    }
</style>
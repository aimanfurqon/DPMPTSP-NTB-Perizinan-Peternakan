@model PerizinanPeternakan.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = "_LoginLayout";
}

<div class="text-center mb-4">
    <h1 class="h3 mb-1 fw-semibold">Reset Password Anda</h1>
    <p class="text-muted">Masukkan password baru Anda di bawah ini.</p>
</div>

<form asp-action="ResetPassword" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    @* Input tersembunyi untuk token dan email *@
    <input type="hidden" asp-for="Token" />
    <input type="hidden" asp-for="Email" />

    <div class="mb-3">
        <label asp-for="Password" class="form-label"><i class="fas fa-lock me-2 opacity-75"></i></label>
        <input asp-for="Password" class="form-control form-control-lg" placeholder="Masukkan password baru" required />
        <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ConfirmPassword" class="form-label"><i class="fas fa-lock me-2 opacity-75"></i></label>
        <input asp-for="ConfirmPassword" class="form-control form-control-lg" placeholder="Konfirmasi password baru" required />
        <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
    </div>

    <div class="d-grid mt-4">
        <button type="submit" class="btn btn-primary btn-lg fw-bold">
            <i class="fas fa-save me-2"></i> Simpan Password Baru
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@{
    ViewData["Title"] = "Link Terkirim";
    Layout = "_LoginLayout";
}

<div class="text-center">
    <div class="mb-4">
        <i class="fas fa-check-circle fa-4x text-success"></i>
    </div>
    <h1 class="h3 mb-3 fw-normal">Silakan Periksa Email Anda</h1>
    <p class="lead text-muted mb-4">
        Jika email yang Anda masukkan terdaftar di sistem kami, kami telah mengirimkan link untuk mereset password Anda.
    </p>
    <p>
        Link tersebut akan kedaluwarsa dalam 1 jam. Jangan lupa periksa folder spam jika Anda tidak menemukannya.
    </p>
    <hr />
    <p class="mt-4">
        <a asp-action="Login" class="btn btn-primary">Kembali ke Halaman Login</a>
    </p>
</div>

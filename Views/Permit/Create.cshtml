        // ===============================================
        // FORM VALIDATION HELPERS
        // ===============================================

        function setFormRequired(formSelector, isRequired) {
            const $form = $(formSelector);

            if (isRequired) {
                $form.find('input[type="text"], input[type="email"], textarea, select').each(function() {
                    const $field = $(this);
                    if ($field.hasClass('form-control') && !$field.attr('readonly') && !$field.attr('type') === 'hidden') {
                        $field.attr('required', 'required');

                        const fieldName = $field.attr('name') || $field.attr('asp-for');
                        if (fieldName) {
                            $form.find(`label[for="${fieldName}"], label[asp-for="${fieldName}"]`).addClass('required');
                        }
                    }
                });
            } else {
                $form.find('input, textarea, select').removeAttr('required');
                $form.find('label').removeClass('required');
            }
        }

        function clearFormValidation(formSelector) {
            const $form = $(formSelector);

            $form.find('input[type="text"], input[type="email"], textarea').val('');
            $form.find('select').prop('selectedIndex', 0);

            $form.find('.text-danger').text('');
            $form.find('.form-control').removeClass('is-invalid is-valid');
        }


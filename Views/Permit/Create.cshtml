        function updateSummary() {
            const totalTypes = $('.livestock-item').length;
            let totalQuantity = 0;

            $('.livestock-quantity').each(function() {
                totalQuantity += parseInt($(this).val()) || 0;
            });

            $('#totalTypes').text(totalTypes);
            $('#totalQuantity').text(totalQuantity);
        }

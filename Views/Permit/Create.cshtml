@model PerizinanPeternakan.ViewModels.PermitApplicationViewModel
@{
    ViewData["Title"] = "Permohonan Baru";
}

<div class="create-container">
    <!-- Page Header -->
    <div class="page-header">
        <div class="header-content">
            <h1 class="page-title">
                <i class="fas fa-plus-circle"></i>
                Permohonan Izin Baru
            </h1>
            <p class="page-subtitle">Buat permohonan izin pengeluaran ternak potong dengan mudah</p>
        </div>
        <div class="header-actions">
            <a href="@Url.Action("Index", "Permit")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i>
                Kembali
            </a>
        </div>
    </div>

    <!-- Multi-Step Progress Indicator -->
    <div class="step-progress">
        <div class="step-indicators">
            <div class="step-indicator active" data-step="1">
                <div class="step-circle">
                    <span class="step-number">1</span>
                    <i class="fas fa-check step-check"></i>
                </div>
                <div class="step-info">
                    <span class="step-title">Informasi Perusahaan</span>
                    <span class="step-subtitle">Data perusahaan pemohon</span>
                </div>
            </div>

            <div class="step-line"></div>

            <div class="step-indicator" data-step="2">
                <div class="step-circle">
                    <span class="step-number">2</span>
                    <i class="fas fa-check step-check"></i>
                </div>
                <div class="step-info">
                    <span class="step-title">Detail Pengiriman</span>
                    <span class="step-subtitle">Lokasi asal dan tujuan</span>
                </div>
            </div>

            <div class="step-line"></div>

            <div class="step-indicator" data-step="3">
                <div class="step-circle">
                    <span class="step-number">3</span>
                    <i class="fas fa-check step-check"></i>
                </div>
                <div class="step-info">
                    <span class="step-title">Detail Ternak</span>
                    <span class="step-subtitle">Jenis dan jumlah ternak</span>
                </div>
            </div>

            <div class="step-line"></div>

            <div class="step-indicator" data-step="4">
                <div class="step-circle">
                    <span class="step-number">4</span>
                    <i class="fas fa-check step-check"></i>
                </div>
                <div class="step-info">
                    <span class="step-title">Dokumen Pendukung</span>
                    <span class="step-subtitle">Upload dokumen wajib</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Multi-Step Form -->
    <form asp-action="Create" method="post" enctype="multipart/form-data" class="permit-form" id="permitForm">
        @Html.AntiForgeryToken()

        <div class="form-steps-container">
            <!-- Step 1: Informasi Pemohon (COMBINED VERSION) -->
            <div class="form-step active" data-step="1">
                <div class="step-content">
                    <div class="step-header">
                        <div class="step-icon">
                            <i class="fas fa-user-friends"></i>
                        </div>
                        <div class="step-text">
                            <h2>Informasi Pemohon</h2>
                            <p>Pilih tipe pemohon dan masukkan data lengkap yang akan mengajukan izin</p>
                        </div>
                    </div>

                    <div class="form-body">
                        <!-- Pilihan Tipe Pemohon -->
                        <div class="form-group full-width">
                            <label class="form-label required">
                                <i class="fas fa-users"></i>
                                Tipe Pemohon
                            </label>
                            <div class="applicant-type-selection">
                                <div class="radio-group">
                                    <div class="radio-item">
                                        <input type="radio" id="individual" name="ApplicantType" value="Individual" class="form-radio" />
                                        <label for="individual" class="radio-label">
                                            <div class="radio-content">
                                                <i class="fas fa-user"></i>
                                                <span class="radio-title">Perorangan</span>
                                                <span class="radio-subtitle">Pemohon individu/perorangan</span>
                                            </div>
                                        </label>
                                    </div>
                                    <div class="radio-item">
                                        <input type="radio" id="company" name="ApplicantType" value="Company" class="form-radio" checked />
                                        <label for="company" class="radio-label">
                                            <div class="radio-content">
                                                <i class="fas fa-building"></i>
                                                <span class="radio-title">Perusahaan</span>
                                                <span class="radio-subtitle">Badan usaha/perusahaan</span>
                                            </div>
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Form untuk Perusahaan (Default - LENGKAP dengan dropdown spesifik) -->
                        <div id="companyForm" class="applicant-form">
                            <div class="form-grid">
                                <div class="form-group">
                                    <label asp-for="CompanyName" class="form-label required">
                                        <i class="fas fa-building"></i>
                                        Nama Perusahaan
                                    </label>
                                    <input asp-for="CompanyName" class="form-control" placeholder="Contoh: CV. DENA BERSAUDARA" />
                                    <span asp-validation-for="CompanyName" class="text-danger"></span>
                                    <!-- Debug info -->
                                    <small class="form-text text-muted" id="companyNameDebug">Debug: Field ID = "CompanyName", Name = "CompanyName"</small>
                                </div>

                                <!-- ALAMAT PERUSAHAAN LENGKAP dengan dropdown spesifik -->
                                <div class="form-group full-width">
                                    <label class="form-label required">
                                        <i class="fas fa-map-marker-alt"></i>
                                        Alamat Perusahaan
                                    </label>
                                    <div class="address-grid">
                                        <!-- Provinsi -->
                                        <div class="address-group span-2">
                                            <label asp-for="CompanyProvince">Provinsi</label>
                                            <select id="companyProvinceSelect" class="form-control">
                                                <option value="">Pilih Provinsi</option>
                                            </select>
                                            <input asp-for="CompanyProvince" type="hidden" />
                                            <span asp-validation-for="CompanyProvince" class="text-danger"></span>
                                        </div>

                                        <!-- Kabupaten/Kota -->
                                        <div class="address-group span-2">
                                            <label asp-for="CompanyRegency">Kabupaten/Kota</label>
                                            <select id="companyRegencySelect" class="form-control" disabled>
                                                <option value="">Pilih Kabupaten/Kota</option>
                                            </select>
                                            <input asp-for="CompanyRegency" type="hidden" />
                                            <span asp-validation-for="CompanyRegency" class="text-danger"></span>
                                        </div>

                                        <!-- Kecamatan -->
                                        <div class="address-group span-2">
                                            <label asp-for="AddressDistrict">Kecamatan</label>
                                            <select id="companyDistrictSelect" class="form-control" disabled>
                                                <option value="">Pilih Kecamatan</option>
                                            </select>
                                            <input asp-for="AddressDistrict" type="hidden" />
                                            <span asp-validation-for="AddressDistrict" class="text-danger"></span>
                                        </div>

                                        <!-- Desa/Kelurahan -->
                                        <div class="address-group span-2">
                                            <label asp-for="AddressVillage">Desa/Kelurahan</label>
                                            <select id="companyVillageSelect" class="form-control" disabled>
                                                <option value="">Pilih Desa/Kelurahan</option>
                                            </select>
                                            <input asp-for="AddressVillage" type="hidden" />
                                            <span asp-validation-for="AddressVillage" class="text-danger"></span>
                                        </div>

                                        <!-- Nama Jalan -->
                                        <div class="address-group span-2">
                                            <label asp-for="AddressStreet">Nama Jalan</label>
                                            <input asp-for="AddressStreet" class="form-control" placeholder="Contoh: Jl. Merdeka No. 10" />
                                            <span asp-validation-for="AddressStreet" class="text-danger"></span>
                                        </div>

                                        <!-- RT -->
                                        <div class="address-group">
                                            <label asp-for="AddressRT">RT</label>
                                            <input asp-for="AddressRT" class="form-control" placeholder="001" maxlength="3" />
                                            <span asp-validation-for="AddressRT" class="text-danger"></span>
                                        </div>

                                        <!-- RW -->
                                        <div class="address-group">
                                            <label asp-for="AddressRW">RW</label>
                                            <input asp-for="AddressRW" class="form-control" placeholder="002" maxlength="3" />
                                            <span asp-validation-for="AddressRW" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <!-- Hidden field untuk alamat gabungan -->
                                    <input asp-for="CompanyAddress" type="hidden" />
                                </div>
                            </div>
                        </div>

                        <!-- Form untuk Perorangan (Hidden by default - SEDERHANA) -->
                        <div id="individualForm" class="applicant-form" style="display: none;">
                            <div class="form-grid">
                                <div class="form-group">
                                    <label asp-for="IndividualName" class="form-label required">
                                        <i class="fas fa-user"></i>
                                        Nama Lengkap
                                    </label>
                                    <input asp-for="IndividualName" class="form-control" placeholder="Masukkan nama lengkap Anda" />
                                    <span asp-validation-for="IndividualName" class="text-danger"></span>
                                    <small class="form-text text-muted">Data akan diambil dari profil akun: @User.Identity.Name</small>
                                </div>

                                <!-- Alamat Perorangan - SEDERHANA -->
                                <div class="form-group full-width">
                                    <label class="form-label required">
                                        <i class="fas fa-map-marker-alt"></i>
                                        Alamat Perorangan
                                    </label>
                                    <div class="address-grid">
                                        <!-- Provinsi -->
                                        <div class="address-group span-2">
                                            <label asp-for="IndividualProvince">Provinsi</label>
                                            <select id="individualProvinceSelect" class="form-control">
                                                <option value="">Pilih Provinsi</option>
                                            </select>
                                            <input asp-for="IndividualProvince" type="hidden" />
                                            <span asp-validation-for="IndividualProvince" class="text-danger"></span>
                                        </div>

                                        <!-- Kabupaten/Kota -->
                                        <div class="address-group span-2">
                                            <label asp-for="IndividualRegency">Kabupaten/Kota</label>
                                            <select id="individualRegencySelect" class="form-control" disabled>
                                                <option value="">Pilih Provinsi terlebih dahulu</option>
                                            </select>
                                            <input asp-for="IndividualRegency" type="hidden" />
                                            <span asp-validation-for="IndividualRegency" class="text-danger"></span>
                                        </div>

                                        <!-- Alamat Lengkap (textarea untuk individual) -->
                                        <div class="address-group span-4">
                                            <label asp-for="IndividualAddress">Alamat Lengkap</label>
                                            <textarea asp-for="IndividualAddress" class="form-control" rows="3"
                                                      placeholder="Masukkan alamat lengkap: Jalan, RT/RW, Kelurahan/Desa, Kecamatan"></textarea>
                                            <span asp-validation-for="IndividualAddress" class="text-danger"></span>
                                            <small class="form-text text-muted">Data akan diambil dari profil akun jika tersedia</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Step 2: Detail Pengiriman -->
            <div class="form-step" data-step="2">
                <div class="step-content">
                    <div class="step-header">
                        <div class="step-icon">
                            <i class="fas fa-shipping-fast"></i>
                        </div>
                        <div class="step-text">
                            <h2>Detail Pengiriman</h2>
                            <p>Tentukan lokasi asal ternak dan tujuan pengiriman dengan detail pelabuhan</p>
                        </div>
                    </div>

                    <div class="form-body">
                        <div class="form-grid">
                            <!-- Asal Ternak -->
                            <div class="form-group">
                                <label class="form-label required">
                                    <i class="fas fa-map-marker-alt text-success"></i>
                                    Asal Ternak
                                </label>
                                <div class="location-dropdown">
                                    <select id="originProvinceSelect" class="form-control select2-province">
                                        <option value="">Pilih Provinsi</option>
                                    </select>
                                    <select id="originRegencySelect" class="form-control select2-regency" disabled>
                                        <option value="">Pilih Kabupaten/Kota</option>
                                    </select>
                                </div>
                                <input asp-for="OriginLocation" id="originLocationHidden" type="hidden" />
                                <span asp-validation-for="OriginLocation" class="text-danger"></span>
                            </div>

                            <!-- Tujuan Pengiriman -->
                            <div class="form-group">
                                <label class="form-label required">
                                    <i class="fas fa-map-marker-alt text-danger"></i>
                                    Tujuan Pengiriman
                                </label>
                                <div class="location-dropdown">
                                    <select id="destinationProvinceSelect" class="form-control select2-province">
                                        <option value="">Pilih Provinsi</option>
                                    </select>
                                    <select id="destinationRegencySelect" class="form-control select2-regency" disabled>
                                        <option value="">Pilih Kabupaten/Kota</option>
                                    </select>
                                </div>
                                <input asp-for="DestinationLocation" id="destinationLocationHidden" type="hidden" />
                                <span asp-validation-for="DestinationLocation" class="text-danger"></span>
                            </div>

                            <!-- Pelabuhan Keberangkatan -->
                            <div class="form-group">
                                <label class="form-label required">
                                    <i class="fas fa-anchor text-primary"></i>
                                    Pelabuhan Keberangkatan
                                </label>
                                <select id="departurePortSelect" class="form-control select2-port" disabled>
                                    <option value="">Pilih provinsi asal terlebih dahulu</option>
                                </select>
                                <input asp-for="DeparturePort" id="departurePortHidden" type="hidden" />
                                <span asp-validation-for="DeparturePort" class="text-danger"></span>
                                <small class="form-text text-muted">
                                    <i class="fas fa-info-circle"></i>
                                    Pelabuhan akan muncul setelah memilih provinsi asal
                                </small>
                            </div>

                            <!-- Pelabuhan Tujuan -->
                            <div class="form-group">
                                <label class="form-label required">
                                    <i class="fas fa-anchor text-warning"></i>
                                    Pelabuhan Tujuan
                                </label>
                                <select id="arrivalPortSelect" class="form-control select2-port" disabled>
                                    <option value="">Pilih provinsi tujuan terlebih dahulu</option>
                                </select>
                                <input asp-for="ArrivalPort" id="arrivalPortHidden" type="hidden" />
                                <span asp-validation-for="ArrivalPort" class="text-danger"></span>
                                <small class="form-text text-muted">
                                    <i class="fas fa-info-circle"></i>
                                    Pelabuhan akan muncul setelah memilih provinsi tujuan
                                </small>
                            </div>
                        </div>

                        <!-- Summary Card -->
                        <div class="shipping-summary" id="shippingSummary" style="display: none;">
                            <div class="summary-card">
                                <div class="summary-header">
                                    <i class="fas fa-route"></i>
                                    <span>Ringkasan Rute Pengiriman</span>
                                </div>
                                <div class="summary-content">
                                    <div class="route-info">
                                        <div class="route-point origin">
                                            <div class="point-icon">
                                                <i class="fas fa-circle text-success"></i>
                                            </div>
                                            <div class="point-details">
                                                <div class="point-label">Asal</div>
                                                <div class="point-location" id="summaryOrigin">-</div>
                                                <div class="point-port" id="summaryDeparturePort">-</div>
                                            </div>
                                        </div>
                                        <div class="route-arrow">
                                            <i class="fas fa-arrow-right"></i>
                                        </div>
                                        <div class="route-point destination">
                                            <div class="point-icon">
                                                <i class="fas fa-circle text-danger"></i>
                                            </div>
                                            <div class="point-details">
                                                <div class="point-label">Tujuan</div>
                                                <div class="point-location" id="summaryDestination">-</div>
                                                <div class="point-port" id="summaryArrivalPort">-</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Step 3: Detail Ternak -->
            <div class="form-step" data-step="3">
                <div class="step-content">
                    <div class="step-header">
                        <div class="step-icon">
                            <i class="fas fa-paw"></i>
                        </div>
                        <div class="step-text">
                            <h2>Detail Ternak</h2>
                            <p>Tambahkan informasi lengkap mengenai jenis dan jumlah ternak yang akan dikirim</p>
                            <small class="text-info">
                                <i class="fas fa-info-circle"></i>
                                Kuota akan ditampilkan secara real-time berdasarkan asal ternak yang dipilih
                            </small>
                        </div>
                    </div>

                    <div class="form-body">
                        <!-- Quota Information Panel -->
                        <div class="quota-info-panel" id="quotaInfoPanel" style="display: none;">
                            <div class="panel-header">
                                <i class="fas fa-chart-pie"></i>
                                <span>Informasi Kuota Ternak 2025</span>
                                <button type="button" class="btn btn-sm btn-outline-primary" id="refreshQuotaBtn">
                                    <i class="fas fa-sync-alt"></i> Refresh
                                </button>
                            </div>
                            <div class="panel-content" id="quotaInfoContent">
                                <!-- Quota info will be loaded here -->
                            </div>
                        </div>

                        <div class="livestock-container" id="livestockContainer">
                            @for (int i = 0; i < Math.Max(Model.LivestockDetails?.Count ?? 0, 1); i++)
                            {
                                <div class="livestock-item" data-index="@i">
                                    <div class="livestock-header">
                                        <h4>Ternak #<span class="livestock-number">@(i + 1)</span></h4>
                                        @if (i > 0)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-danger remove-livestock" title="Hapus item ini">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        }
                                    </div>

                                    <div class="livestock-form">
                                        <div class="form-group">
                                            <label class="form-label required">
                                                <i class="fas fa-paw"></i>
                                                Jenis Ternak
                                                <span class="quota-indicator" data-index="@i" style="display: none;">
                                                    <i class="fas fa-info-circle text-primary"></i>
                                                    <span class="quota-text">Loading...</span>
                                                </span>
                                            </label>
                                            <select name="LivestockDetails[@i].LivestockType" class="form-control livestock-type" data-index="@i" required>
                                                <option value="">Pilih Jenis Ternak</option>
                                                <option value="Sapi Potong">Sapi Potong</option>
                                                <option value="Kerbau Potong">Kerbau Potong</option>
                                                <option value="Kuda Pedaging">Kuda Pedaging</option>
                                                <option value="Kambing">Kambing</option>
                                                <option value="Domba">Domba</option>
                                            </select>
                                        </div>

                                        <div class="form-group">
                                            <label class="form-label required">
                                                <i class="fas fa-calculator"></i>
                                                Jumlah (ekor)
                                                <span class="quota-limit" data-index="@i" style="display: none;">
                                                    <small class="text-muted">Maks: <span class="max-quota">-</span> ekor</small>
                                                </span>
                                            </label>
                                            <input type="number" name="LivestockDetails[@i].Quantity"
                                                   class="form-control livestock-quantity" data-index="@i"
                                                   min="1" max="1"
                                                   placeholder="Masukkan jumlah ternak" required />
                                            <div class="quantity-feedback" data-index="@i" style="display: none;">
                                                <small class="feedback-text">-</small>
                                            </div>
                                        </div>

                                        <div class="form-group">
                                            <label class="form-label">
                                                <i class="fas fa-comment"></i>
                                                Keterangan
                                            </label>
                                            <textarea name="LivestockDetails[@i].Description"
                                                  class="form-control" rows="2"
                                                  placeholder="Keterangan tambahan (opsional)"></textarea>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="livestock-actions">
                            <button type="button" class="btn btn-outline-primary" id="addLivestock">
                                <i class="fas fa-plus"></i>
                                Tambah Jenis Ternak
                            </button>

                            <div class="livestock-summary">
                                <div class="summary-item">
                                    <span class="label">Total Jenis</span>
                                    <span class="value" id="totalTypes">1</span>
                                </div>
                                <div class="summary-item">
                                    <span class="label">Total Ekor</span>
                                    <span class="value" id="totalQuantity">0</span>
                                </div>
                                <div class="summary-item quota-usage" style="display: none;">
                                    <span class="label">Status Kuota</span>
                                    <span class="value" id="quotaStatus">
                                        <i class="fas fa-check-circle text-success"></i>
                                        Dalam Batas
                                    </span>
                                </div>
                            </div>
                        </div>

                        <!-- Quota Validation Summary -->
                        <div class="quota-validation-summary" id="quotaValidationSummary" style="display: none;">
                            <div class="validation-header">
                                <i class="fas fa-shield-alt"></i>
                                <span>Validasi Kuota</span>
                            </div>
                            <div class="validation-content" id="validationContent">
                                <!-- Validation results will be shown here -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Step 4: Dokumen Pendukung -->
            <div class="form-step" data-step="4">
                <div class="step-content">
                    <div class="step-header">
                        <div class="step-icon">
                            <i class="fas fa-file-upload"></i>
                        </div>
                        <div class="step-text">
                            <h2>Dokumen Pendukung</h2>
                            <p>Upload semua dokumen yang diperlukan untuk melengkapi permohonan izin</p>
                        </div>
                    </div>

                    <div class="form-body">
                        <div class="document-upload-container">
                            <!-- Upload Information -->
                            <div class="upload-info">
                                <div class="info-card">
                                    <i class="fas fa-info-circle"></i>
                                    <div class="info-content">
                                        <h4>Petunjuk Upload Dokumen</h4>
                                        <ul>
                                            <li>Format file yang diterima: PDF, JPG, JPEG, PNG</li>
                                            <li>Ukuran maksimal per file: 5MB</li>
                                            <li>Pastikan dokumen terlihat jelas dan tidak blur</li>
                                            <li>Semua dokumen wajib diupload untuk memproses permohonan</li>
                                            <li>Isi tanggal pengajuan dan nomor dokumen sesuai dengan dokumen asli</li>
                                        </ul>
                                    </div>
                                </div>

                                <!-- Upload Progress Summary -->
                                <div class="upload-summary">
                                    <div class="summary-header">
                                        <i class="fas fa-clipboard-check"></i>
                                        <span>Status Upload Dokumen</span>
                                    </div>
                                    <div class="summary-progress">
                                        <div class="progress-bar">
                                            <div class="progress-fill" id="uploadProgress" style="width: 0%"></div>
                                        </div>
                                        <span class="progress-text" id="uploadProgressText">0 dari 7 dokumen telah diupload</span>
                                    </div>
                                    <div class="summary-checklist" id="documentChecklist">
                                        <div class="checklist-item" data-doc="SuratPermohonan">
                                            <i class="fas fa-times-circle text-danger"></i>
                                            <span>Surat Permohonan</span>
                                        </div>
                                        <div class="checklist-item" data-doc="RekomendasiDinasProv">
                                            <i class="fas fa-times-circle text-danger"></i>
                                            <span>Rekomendasi Dinas Peternakan Provinsi NTB</span>
                                        </div>
                                        <div class="checklist-item" data-doc="RekomendasiDaerahTujuan">
                                            <i class="fas fa-times-circle text-danger"></i>
                                            <span>Rekomendasi Pemasukan Ternak dari Daerah Tujuan</span>
                                        </div>
                                        <div class="checklist-item" data-doc="SKKHKabupatenAsal">
                                            <i class="fas fa-times-circle text-danger"></i>
                                            <span>SKKH dari Kabupaten Asal</span>
                                        </div>
                                        <div class="checklist-item" data-doc="SKKHDinasProvinsi">
                                            <i class="fas fa-times-circle text-danger"></i>
                                            <span>SKKH dari Dinas Peternakan Provinsi NTB</span>
                                        </div>
                                        <div class="checklist-item" data-doc="SuratJalanTernak">

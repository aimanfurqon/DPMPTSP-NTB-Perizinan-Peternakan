        function updateCompanyAddressFromComponents() {
            const addressParts = [];

            const street = $('input[name="AddressStreet"]').val();
            const rt = $('input[name="AddressRT"]').val();
            const rw = $('input[name="AddressRW"]').val();
            const village = $('input[name="AddressVillage"]').val();
            const district = $('input[name="AddressDistrict"]').val();
            const regency = $('input[name="CompanyRegency"]').val();
            const province = $('input[name="CompanyProvince"]').val();

            if (street) addressParts.push(street);
            if (rt || rw) {
                const rtRw = `RT ${rt || '-'} / RW ${rw || '-'}`;
                addressParts.push(rtRw);

                <button type="submit" class="btn btn-success btn-submit" id="submitBtn" style="display: none;">
                    <i class="fas fa-paper-plane"></i>
                    Ajukan Permohonan
                </button>
            </div>

            <div class="form-info">
                <div class="info-item">
                    <i class="fas fa-info-circle"></i>
                    <span>Pastikan semua data yang diisi sudah benar sebelum mengajukan permohonan</span>
                </div>
                <div class="info-item">
                    <i class="fas fa-clock"></i>
                    <span>Proses verifikasi akan dilakukan dalam 1-3 hari kerja</span>
                </div>
                <div class="info-item">
                    <i class="fas fa-upload"></i>
                    <span>Semua dokumen pendukung wajib diupload untuk memproses permohonan</span>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <!-- CSS Dependencies - Load First -->
    <link rel="stylesheet" href="~/css/permit/create-modern.css" />
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" />
    
    <!-- JavaScript Dependencies -->
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="~/js/multi-step-form.js"></script>
    <script src="~/js/permit-create.js" asp-append-version="true"></script>
    
    <script>
        // Data user dari server (akan diisi oleh controller)
        var userProfileData = {
            namaLengkap: '@Html.Raw(Model.IndividualName)',
            alamat: '@Html.Raw(Model.IndividualAddress)'
        };
        
        console.log('📋 User profile data loaded:', userProfileData);

        $(document).ready(function() {
            // Handler untuk radio button ApplicantType
            $('input[name="ApplicantType"]').on('change', function() {
                const selectedType = $(this).val();
                console.log('ApplicantType changed to:', selectedType);
                
                if (selectedType === 'Individual') {
                    // Isi data dari profil user
                    fillIndividualDataFromProfile();
                    
                    // Sembunyikan dropdown provinsi dan kabupaten untuk sementara
                    $('#individualProvinceGroup').hide();
                    $('#individualRegencyGroup').hide();
                    
                    // Tampilkan pesan bahwa data diambil dari profil
                    showProfileDataMessage();
                } else if (selectedType === 'Company') {
                    // Tampilkan dropdown provinsi dan kabupaten untuk perusahaan
                    $('#companyProvinceSelect').closest('.address-group').show();
                    $('#companyRegencySelect').closest('.address-group').show();
                    
                    // Sembunyikan pesan profil
                    hideProfileDataMessage();
                }
            });
        });

        function fillIndividualDataFromProfile() {
            // Isi nama lengkap dari profil
            if (userProfileData.namaLengkap) {
                $('#IndividualName').val(userProfileData.namaLengkap);
                console.log('✅ Nama lengkap diisi dari profil:', userProfileData.namaLengkap);
            }
            
            // Isi alamat dari profil
            if (userProfileData.alamat) {
                $('#IndividualAddress').val(userProfileData.alamat);
                console.log('✅ Alamat diisi dari profil:', userProfileData.alamat);
            }
        }

        function showProfileDataMessage() {
            // Tambahkan pesan bahwa data diambil dari profil
            if (!$('#profileDataMessage').length) {
                const message = `
                    <div id="profileDataMessage" class="alert alert-info mt-3">
                        <i class="fas fa-info-circle"></i>
                        <strong>Data diambil dari profil:</strong> Nama dan alamat telah diisi otomatis dari data profil akun Anda. 
                        Anda dapat mengubah data ini jika diperlukan.
                    </div>
                `;
                $('#individualForm').append(message);
            }
        }

        function hideProfileDataMessage() {
            $('#profileDataMessage').remove();
        }
    </script>
}
            if (village) addressParts.push(`Desa/Kel. ${village}`);
            if (district) addressParts.push(`Kec. ${district}`);
            if (regency) addressParts.push(regency);
            if (province) addressParts.push(province);

            const fullAddress = addressParts.join(', ');
            $('input[name="CompanyAddress"]').val(fullAddress);

            console.log('📍 Company address updated:', fullAddress);
        }


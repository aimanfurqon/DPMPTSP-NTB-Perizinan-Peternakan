@model PerizinanPeternakan.ViewModels.PermitApplicationViewModel
@{
    ViewData["Title"] = "Permohonan Baru";
}

<div class="create-container">
    <div class="page-header">
        <div class="header-content">
            <h1 class="page-title">
                <i class="fas fa-plus-circle"></i>
                Permohonan Izin Baru
            </h1>
            <p class="page-subtitle">Buat permohonan izin pengeluaran ternak potong</p>
        </div>

        <div class="header-actions">
            <a href="@Url.Action("Index", "Permit")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i>
                Kembali
            </a>
        </div>
    </div>

    <form asp-action="Create" method="post" enctype="multipart/form-data" class="permit-form" id="permitForm">
        <div class="form-sections">
            <!-- Informasi Perusahaan -->
            <div class="form-section">
                <div class="section-header">
                    <h3>
                        <i class="fas fa-building"></i>
                        Informasi Perusahaan
                    </h3>
                    <span class="section-number">1</span>
                </div>

                <div class="section-body">
                    <div class="form-grid">
                        <div class="form-group">
                            <label asp-for="CompanyName" class="form-label required">
                                <i class="fas fa-building"></i>
                                Nama Perusahaan
                            </label>
                            <input asp-for="CompanyName" class="form-control"
                                   placeholder="Contoh: CV. DENA BERSAUDARA" />
                            <span asp-validation-for="CompanyName" class="text-danger"></span>
                        </div>

                        <div class="form-group full-width">
                            <label asp-for="CompanyAddress" class="form-label required">
                                <i class="fas fa-map-marker-alt"></i>
                                Alamat Perusahaan
                            </label>
                            <textarea asp-for="CompanyAddress" class="form-control" rows="3"
                                      placeholder="Masukkan alamat lengkap perusahaan"></textarea>
                            <span asp-validation-for="CompanyAddress" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Detail Pengiriman -->
            <div class="form-section">
                <div class="section-header">
                    <h3>
                        <i class="fas fa-shipping-fast"></i>
                        Detail Pengiriman
                    </h3>
                    <span class="section-number">2</span>
                </div>

                <div class="section-body">
                    <div class="form-grid">
                        <div class="form-group">
                            <label asp-for="OriginLocation" class="form-label required">
                                <i class="fas fa-map-marker-alt text-success"></i>
                                Asal Ternak
                            </label>
                            <input asp-for="OriginLocation" class="form-control"
                                   placeholder="Contoh: Kab. Bima" />
                            <span asp-validation-for="OriginLocation" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="DestinationLocation" class="form-label required">
                                <i class="fas fa-map-marker-alt text-danger"></i>
                                Tujuan Pengiriman
                            </label>
                            <input asp-for="DestinationLocation" class="form-control"
                                   placeholder="Contoh: Kab. Jeneponto, Sulawesi Selatan" />
                            <span asp-validation-for="DestinationLocation" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="DeparturePort" class="form-label required">
                                <i class="fas fa-anchor"></i>
                                Pelabuhan Asal
                            </label>
                            <input asp-for="DeparturePort" class="form-control"
                                   placeholder="Contoh: Pelabuhan Sape, Kab. Bima" />
                            <span asp-validation-for="DeparturePort" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="ArrivalPort" class="form-label required">
                                <i class="fas fa-anchor"></i>
                                Pelabuhan Bongkar
                            </label>
                            <input asp-for="ArrivalPort" class="form-control"
                                   placeholder="Contoh: Pelabuhan Bungeng, Kab. Jeneponto" />
                            <span asp-validation-for="ArrivalPort" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Detail Ternak -->
            <div class="form-section">
                <div class="section-header">
                    <h3>
                        <i class="fas fa-paw"></i>
                        Detail Ternak
                    </h3>
                    <span class="section-number">3</span>
                </div>

                <div class="section-body">
                    <div class="livestock-container" id="livestockContainer">
                        @for (int i = 0; i < Math.Max(Model.LivestockDetails?.Count ?? 0, 1); i++)
                        {
                            <div class="livestock-item" data-index="@i">
                                <div class="livestock-header">
                                    <h4>Ternak #<span class="livestock-number">@(i + 1)</span></h4>
                                    @if (i > 0)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-danger remove-livestock">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    }
                                </div>

                                <div class="livestock-form">
                                    <div class="form-group">
                                        <label class="form-label required">
                                            <i class="fas fa-paw"></i>
                                            Jenis Ternak
                                        </label>
                                        <select name="LivestockDetails[@i].LivestockType" class="form-control livestock-type" required>
                                            <option value="">Pilih Jenis Ternak</option>
                                            <option value="Sapi Potong">Sapi Potong</option>
                                            <option value="Kerbau Potong">Kerbau Potong</option>
                                            <option value="Kuda Pedaging">Kuda Pedaging</option>
                                            <option value="Kambing">Kambing</option>
                                            <option value="Domba">Domba</option>
                                        </select>
                                    </div>

                                    <div class="form-group">
                                        <label class="form-label required">
                                            <i class="fas fa-calculator"></i>
                                            Jumlah (ekor)
                                        </label>
                                        <input type="number" name="LivestockDetails[@i].Quantity"
                                               class="form-control livestock-quantity" min="1" max="10000"
                                               placeholder="Masukkan jumlah ternak" required />
                                    </div>

                                    <div class="form-group">
                                        <label class="form-label">
                                            <i class="fas fa-comment"></i>
                                            Keterangan
                                        </label>
                                        <textarea name="LivestockDetails[@i].Description"
                                              class="form-control" rows="2"
                                              placeholder="Keterangan tambahan (opsional)"></textarea>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="livestock-actions">
                        <button type="button" class="btn btn-outline-primary" id="addLivestock">
                            <i class="fas fa-plus"></i>
                            Tambah Jenis Ternak
                        </button>

                        <div class="livestock-summary">
                            <div class="summary-item">
                                <span class="label">Total Jenis:</span>
                                <span class="value" id="totalTypes">1</span>
                            </div>
                            <div class="summary-item">
                                <span class="label">Total Ekor:</span>
                                <span class="value" id="totalQuantity">0</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Dokumen Pendukung -->
            <div class="form-section">
                <div class="section-header">
                    <h3>
                        <i class="fas fa-file-upload"></i>
                        Dokumen Pendukung
                    </h3>
                    <span class="section-number">4</span>
                </div>

                <div class="section-body">
                    <div class="document-upload-container">
                        <div class="upload-info">
                            <div class="info-card">
                                <i class="fas fa-info-circle"></i>
                                <div class="info-content">
                                    <h4>Petunjuk Upload Dokumen</h4>
                                    <ul>
                                        <li>Format file yang diterima: PDF, JPG, JPEG, PNG</li>
                                        <li>Ukuran maksimal per file: 5MB</li>
                                        <li>Pastikan dokumen terlihat jelas dan tidak blur</li>
                                        <li>Semua dokumen wajib diupload untuk memproses permohonan</li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <div class="document-upload-grid">
                            <!-- Surat Permohonan -->
                            <div class="upload-item" data-document-type="SuratPermohonan">
                                <div class="upload-header">
                                    <label class="form-label required">
                                        <i class="fas fa-file-alt"></i>
                                        Surat Permohonan
                                    </label>
                                    <span class="upload-status" id="status-surat-permohonan">
                                        <i class="fas fa-circle text-danger"></i>
                                        Belum Upload
                                    </span>
                                </div>
                                <div class="upload-area" data-target="SuratPermohonan">
                                    <input type="file" asp-for="SuratPermohonan"
                                           class="file-input"
                                           accept=".pdf,.jpg,.jpeg,.png"
                                           data-max-size="5242880"
                                           id="SuratPermohonan" />
                                    <div class="upload-placeholder">
                                        <i class="fas fa-cloud-upload-alt"></i>
                                        <p>Klik untuk upload atau drag & drop file</p>
                                        <small>PDF, JPG, PNG (Max: 5MB)</small>
                                    </div>
                                    <div class="file-preview" style="display: none;">
                                        <div class="file-info">
                                            <i class="fas fa-file"></i>
                                            <div class="file-details">
                                                <span class="file-name"></span>
                                                <span class="file-size"></span>
                                            </div>
                                        </div>
                                        <button type="button" class="btn-remove">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                </div>
                                <span asp-validation-for="SuratPermohonan" class="text-danger"></span>
                            </div>

                            <!-- Rekomendasi Dinas Provinsi -->
                            <div class="upload-item" data-document-type="RekomendasiDinasProv">
                                <div class="upload-header">
                                    <label class="form-label required">
                                        <i class="fas fa-file-alt"></i>
                                        Rekomendasi Dinas Peternakan Provinsi NTB
                                    </label>
                                    <span class="upload-status" id="status-rekomendasi-dinas">
                                        <i class="fas fa-circle text-danger"></i>
                                        Belum Upload
                                    </span>
                                </div>
                                <div class="upload-area" data-target="RekomendasiDinasProv">
                                    <input type="file" asp-for="RekomendasiDinasProv"
                                           class="file-input"
                                           accept=".pdf,.jpg,.jpeg,.png"
                                           data-max-size="5242880"
                                           id="RekomendasiDinasProv" />
                                    <div class="upload-placeholder">
                                        <i class="fas fa-cloud-upload-alt"></i>
                                        <p>Klik untuk upload atau drag & drop file</p>
                                        <small>PDF, JPG, PNG (Max: 5MB)</small>
                                    </div>
                                    <div class="file-preview" style="display: none;">
                                        <div class="file-info">
                                            <i class="fas fa-file"></i>
                                            <div class="file-details">
                                                <span class="file-name"></span>
                                                <span class="file-size"></span>
                                            </div>
                                        </div>
                                        <button type="button" class="btn-remove">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                </div>
                                <span asp-validation-for="RekomendasiDinasProv" class="text-danger"></span>
                            </div>

                            <!-- Rekomendasi Daerah Tujuan -->
                            <div class="upload-item" data-document-type="RekomendasiDaerahTujuan">
                                <div class="upload-header">
                                    <label class="form-label required">
                                        <i class="fas fa-file-alt"></i>
                                        Rekomendasi Pemasukan Ternak dari Daerah Tujuan
                                    </label>
                                    <span class="upload-status" id="status-rekomendasi-tujuan">
                                        <i class="fas fa-circle text-danger"></i>
                                        Belum Upload
                                    </span>
                                </div>
                                <div class="upload-area" data-target="RekomendasiDaerahTujuan">
                                    <input type="file" asp-for="RekomendasiDaerahTujuan"
                                           class="file-input"
                                           accept=".pdf,.jpg,.jpeg,.png"
                                           data-max-size="5242880"
                                           id="RekomendasiDaerahTujuan" />
                                    <div class="upload-placeholder">
                                        <i class="fas fa-cloud-upload-alt"></i>
                                        <p>Klik untuk upload atau drag & drop file</p>
                                        <small>PDF, JPG, PNG (Max: 5MB)</small>
                                    </div>
                                    <div class="file-preview" style="display: none;">
                                        <div class="file-info">
                                            <i class="fas fa-file"></i>
                                            <div class="file-details">
                                                <span class="file-name"></span>
                                                <span class="file-size"></span>
                                            </div>
                                        </div>
                                        <button type="button" class="btn-remove">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                </div>
                                <span asp-validation-for="RekomendasiDaerahTujuan" class="text-danger"></span>
                            </div>

                            <!-- SKKH Kabupaten Asal -->
                            <div class="upload-item" data-document-type="SKKHKabupatenAsal">
                                <div class="upload-header">
                                    <label class="form-label required">
                                        <i class="fas fa-file-medical"></i>
                                        SKKH dari Kabupaten Asal
                                    </label>
                                    <span class="upload-status" id="status-skkh-kabupaten">
                                        <i class="fas fa-circle text-danger"></i>
                                        Belum Upload
                                    </span>
                                </div>
                                <div class="upload-area" data-target="SKKHKabupatenAsal">
                                    <input type="file" asp-for="SKKHKabupatenAsal"
                                           class="file-input"
                                           accept=".pdf,.jpg,.jpeg,.png"
                                           data-max-size="5242880"
                                           id="SKKHKabupatenAsal" />
                                    <div class="upload-placeholder">
                                        <i class="fas fa-cloud-upload-alt"></i>
                                        <p>Klik untuk upload atau drag & drop file</p>
                                        <small>PDF, JPG, PNG (Max: 5MB)</small>
                                    </div>
                                    <div class="file-preview" style="display: none;">
                                        <div class="file-info">
                                            <i class="fas fa-file"></i>
                                            <div class="file-details">
                                                <span class="file-name"></span>
                                                <span class="file-size"></span>
                                            </div>
                                        </div>
                                        <button type="button" class="btn-remove">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                </div>
                                <span asp-validation-for="SKKHKabupatenAsal" class="text-danger"></span>
                            </div>

                            <!-- SKKH Dinas Provinsi -->
                            <div class="upload-item" data-document-type="SKKHDinasProvinsi">
                                <div class="upload-header">
                                    <label class="form-label required">
                                        <i class="fas fa-file-medical"></i>
                                        SKKH dari Dinas Peternakan Provinsi NTB
                                    </label>
                                    <span class="upload-status" id="status-skkh-provinsi">
                                        <i class="fas fa-circle text-danger"></i>
                                        Belum Upload
                                    </span>
                                </div>
                                <div class="upload-area" data-target="SKKHDinasProvinsi">
                                    <input type="file" asp-for="SKKHDinasProvinsi"
                                           class="file-input"
                                           accept=".pdf,.jpg,.jpeg,.png"
                                           data-max-size="5242880"
                                           id="SKKHDinasProvinsi" />
                                    <div class="upload-placeholder">
                                        <i class="fas fa-cloud-upload-alt"></i>
                                        <p>Klik untuk upload atau drag & drop file</p>
                                        <small>PDF, JPG, PNG (Max: 5MB)</small>
                                    </div>
                                    <div class="file-preview" style="display: none;">
                                        <div class="file-info">
                                            <i class="fas fa-file"></i>
                                            <div class="file-details">
                                                <span class="file-name"></span>
                                                <span class="file-size"></span>
                                            </div>
                                        </div>
                                        <button type="button" class="btn-remove">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                </div>
                                <span asp-validation-for="SKKHDinasProvinsi" class="text-danger"></span>
                            </div>

                            <!-- Surat Jalan Ternak -->
                            <div class="upload-item" data-document-type="SuratJalanTernak">
                                <div class="upload-header">
                                    <label class="form-label required">
                                        <i class="fas fa-route"></i>
                                        Surat Keterangan Jalan Ternak/Rekomendasi Asal
                                    </label>
                                    <span class="upload-status" id="status-surat-jalan">
                                        <i class="fas fa-circle text-danger"></i>
                                        Belum Upload
                                    </span>
                                </div>
                                <div class="upload-area" data-target="SuratJalanTernak">
                                    <input type="file" asp-for="SuratJalanTernak"
                                           class="file-input"
                                           accept=".pdf,.jpg,.jpeg,.png"
                                           data-max-size="5242880"
                                           id="SuratJalanTernak" />
                                    <div class="upload-placeholder">
                                        <i class="fas fa-cloud-upload-alt"></i>
                                        <p>Klik untuk upload atau drag & drop file</p>
                                        <small>PDF, JPG, PNG (Max: 5MB)</small>
                                    </div>
                                    <div class="file-preview" style="display: none;">
                                        <div class="file-info">
                                            <i class="fas fa-file"></i>
                                            <div class="file-details">
                                                <span class="file-name"></span>
                                                <span class="file-size"></span>
                                            </div>
                                        </div>
                                        <button type="button" class="btn-remove">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                </div>
                                <span asp-validation-for="SuratJalanTernak" class="text-danger"></span>
                            </div>

                            <!-- Hasil Pemeriksaan Fisik -->
                            <div class="upload-item" data-document-type="HasilPemeriksaanFisik">
                                <div class="upload-header">
                                    <label class="form-label required">
                                        <i class="fas fa-stethoscope"></i>
                                        Hasil Pemeriksaan Fisik (Holding Ground)
                                    </label>
                                    <span class="upload-status" id="status-pemeriksaan-fisik">
                                        <i class="fas fa-circle text-danger"></i>
                                        Belum Upload
                                    </span>
                                </div>
                                <div class="upload-area" data-target="HasilPemeriksaanFisik">
                                    <input type="file" asp-for="HasilPemeriksaanFisik"
                                           class="file-input"
                                           accept=".pdf,.jpg,.jpeg,.png"
                                           data-max-size="5242880"
                                           id="HasilPemeriksaanFisik" />
                                    <div class="upload-placeholder">
                                        <i class="fas fa-cloud-upload-alt"></i>
                                        <p>Klik untuk upload atau drag & drop file</p>
                                        <small>PDF, JPG, PNG (Max: 5MB)</small>
                                    </div>
                                    <div class="file-preview" style="display: none;">
                                        <div class="file-info">
                                            <i class="fas fa-file"></i>
                                            <div class="file-details">
                                                <span class="file-name"></span>
                                                <span class="file-size"></span>
                                            </div>
                                        </div>
                                        <button type="button" class="btn-remove">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                </div>
                                <span asp-validation-for="HasilPemeriksaanFisik" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="upload-summary">
                            <div class="summary-header">
                                <i class="fas fa-clipboard-check"></i>
                                <span>Status Upload Dokumen</span>
                            </div>
                            <div class="summary-progress">
                                <div class="progress-bar">
                                    <div class="progress-fill" id="uploadProgress" style="width: 0%"></div>
                                </div>
                                <span class="progress-text" id="uploadProgressText">0 dari 7 dokumen telah diupload</span>
                            </div>
                            <div class="summary-checklist" id="documentChecklist">
                                <div class="checklist-item" data-doc="SuratPermohonan">
                                    <i class="fas fa-times-circle text-danger"></i>
                                    <span>Surat Permohonan</span>
                                </div>
                                <div class="checklist-item" data-doc="RekomendasiDinasProv">
                                    <i class="fas fa-times-circle text-danger"></i>
                                    <span>Rekomendasi Dinas Peternakan Provinsi NTB</span>
                                </div>
                                <div class="checklist-item" data-doc="RekomendasiDaerahTujuan">
                                    <i class="fas fa-times-circle text-danger"></i>
                                    <span>Rekomendasi Pemasukan Ternak dari Daerah Tujuan</span>
                                </div>
                                <div class="checklist-item" data-doc="SKKHKabupatenAsal">
                                    <i class="fas fa-times-circle text-danger"></i>
                                    <span>SKKH dari Kabupaten Asal</span>
                                </div>
                                <div class="checklist-item" data-doc="SKKHDinasProvinsi">
                                    <i class="fas fa-times-circle text-danger"></i>
                                    <span>SKKH dari Dinas Peternakan Provinsi NTB</span>
                                </div>
                                <div class="checklist-item" data-doc="SuratJalanTernak">
                                    <i class="fas fa-times-circle text-danger"></i>
                                    <span>Surat Keterangan Jalan Ternak/Rekomendasi Asal</span>
                                </div>
                                <div class="checklist-item" data-doc="HasilPemeriksaanFisik">
                                    <i class="fas fa-times-circle text-danger"></i>
                                    <span>Hasil Pemeriksaan Fisik (Holding Ground)</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Form Actions -->
        <div class="form-actions">
            <div class="action-buttons">
                <button type="button" class="btn btn-outline-secondary btn-lg" onclick="window.location.href='@Url.Action("Index", "Permit")'">
                    <i class="fas fa-times"></i>
                    Batal
                </button>

                <button type="submit" class="btn btn-primary btn-lg" id="submitBtn">
                    <i class="fas fa-paper-plane"></i>
                    Ajukan Permohonan
                </button>
            </div>

            <div class="form-info">
                <div class="info-item">
                    <i class="fas fa-info-circle"></i>
                    <span>Pastikan semua data yang diisi sudah benar sebelum mengajukan permohonan</span>
                </div>
                <div class="info-item">
                    <i class="fas fa-clock"></i>
                    <span>Proses verifikasi akan dilakukan dalam 1-3 hari kerja</span>
                </div>
                <div class="info-item">
                    <i class="fas fa-upload"></i>
                    <span>Semua dokumen pendukung wajib diupload untuk memproses permohonan</span>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
                // JAVASCRIPT SEDERHANA DAN AMAN - TANPA INFINITE LOOP

        let livestockIndex = @(Math.Max(Model.LivestockDetails?.Count ?? 0, 1));
        const totalRequiredFiles = 7;
        const uploadedDocuments = new Map();
        const documentTypes = [
            'SuratPermohonan',
            'RekomendasiDinasProv',
            'RekomendasiDaerahTujuan',
            'SKKHKabupatenAsal',
            'SKKHDinasProvinsi',
            'SuratJalanTernak',
            'HasilPemeriksaanFisik'
        ];

        $(document).ready(function() {
            console.log('🚀 Initializing simple upload system...');

            // SOLUSI SEDERHANA: Direct binding tanpa kompleksitas
            initializeSimpleFileUpload();
            updateSummary();
            updateLivestockNumbers();
            updateUploadProgress();

            // Livestock handlers
            $('#addLivestock').on('click', addLivestockItem);
            $(document).on('click', '.remove-livestock', function(e) {
                e.preventDefault();
                $(this).closest('.livestock-item').remove();
                updateLivestockNumbers();
                updateSummary();
            });

            $(document).on('input', '.livestock-quantity', updateSummary);

            // Form submission
            $('#permitForm').on('submit', function(e) {
                console.log('📤 Form submission...');
                debugFormData();

                if (!validateForm()) {
                    e.preventDefault();
                    return false;
                }

                $('#submitBtn').html('<i class="fas fa-spinner fa-spin"></i> Menyimpan...').prop('disabled', true);
            });
        });

        function initializeSimpleFileUpload() {
            // SOLUSI: Binding langsung ke input file tanpa kompleksitas
            $('.file-input').each(function() {
                const $input = $(this);
                const documentType = $input.attr('id');
                const $uploadArea = $input.closest('.upload-area');

                console.log(`🔧 Simple init for: ${documentType}`);

                // HANYA binding ke input file change event
                $input.on('change', function() {
                    if (this.files && this.files[0]) {
                        handleFileSelection(this, this.files[0]);
                    }
                });

                // SOLUSI SEDERHANA: Direct click ke hidden input
                $uploadArea.find('.upload-placeholder').on('click', function(e) {
                    e.preventDefault();
                    console.log(`📁 Placeholder clicked for: ${documentType}`);
                    $input[0].click(); // Direct DOM click, tidak melalui jQuery
                });

                // Remove file handler
                $uploadArea.find('.btn-remove').on('click', function(e) {
                    e.preventDefault();
                    removeFileSimple($input);
                });
            });
        }

        function handleFileSelection(inputElement, file) {
            const $input = $(inputElement);
            const documentType = $input.attr('id');
            const maxSize = 5242880; // 5MB
            const allowedTypes = ['application/pdf', 'image/jpeg', 'image/jpg', 'image/png'];

            console.log(`📄 File selected: ${file.name} for ${documentType}`);

            // Simple validation
            if (file.size > maxSize) {
                showSimpleAlert('File terlalu besar (max 5MB)', 'danger');
                $input.val('');
                return;
            }

            if (!allowedTypes.includes(file.type)) {
                showSimpleAlert('Format file tidak didukung. Gunakan PDF atau gambar', 'danger');
                $input.val('');
                return;
            }

            // Update UI
            updateFilePreviewSimple($input, file);

            // Track file
            uploadedDocuments.set(documentType, {
                file: file,
                name: file.name,
                size: file.size
            });

            updateUploadProgress();
            updateDocumentChecklist();

            console.log(`✅ File processed: ${documentType}`);
            showSimpleAlert(`File "${file.name}" berhasil dipilih`, 'success');
        }

        function updateFilePreviewSimple($input, file) {
            const $uploadArea = $input.closest('.upload-area');
            const $placeholder = $uploadArea.find('.upload-placeholder');
            const $preview = $uploadArea.find('.file-preview');

            // Update preview info
            $preview.find('.file-name').text(file.name);
            $preview.find('.file-size').text(formatFileSize(file.size));

            // Show/hide elements
            $placeholder.hide();
            $preview.show();
        }

        function removeFileSimple($input) {
            const documentType = $input.attr('id');
            const $uploadArea = $input.closest('.upload-area');

            // Clear input
            $input.val('');

            // Update UI
            $uploadArea.find('.file-preview').hide();
            $uploadArea.find('.upload-placeholder').show();

            // Remove from tracking
            uploadedDocuments.delete(documentType);

            updateUploadProgress();
            updateDocumentChecklist();

            console.log(`🗑️ File removed: ${documentType}`);
            showSimpleAlert('File berhasil dihapus', 'info');
        }

        function debugFormData() {
            console.log('🔍 === SIMPLE DEBUG ===');

            $('.file-input').each(function() {
                const hasFile = this.files && this.files.length > 0;
                console.log(`${this.id}: ${hasFile ? this.files[0].name : 'NONE'}`);
            });

            console.log(`Tracked files: ${uploadedDocuments.size}/${totalRequiredFiles}`);
            console.log('Files:', Array.from(uploadedDocuments.keys()));
        }

        function validateForm() {
            const errors = [];

            // Check livestock
            let hasValidLivestock = false;
            $('.livestock-item').each(function() {
                const type = $(this).find('.livestock-type').val();
                const quantity = parseInt($(this).find('.livestock-quantity').val()) || 0;
                if (type && quantity > 0) hasValidLivestock = true;
            });

            if (!hasValidLivestock) {
                errors.push('Minimal harus ada satu jenis ternak');
            }

            // Check files
            if (uploadedDocuments.size < totalRequiredFiles) {
                errors.push(`Dokumen belum lengkap (${uploadedDocuments.size}/${totalRequiredFiles})`);
            }

            // Check required fields
            const required = ['CompanyName', 'CompanyAddress', 'OriginLocation',
                             'DestinationLocation', 'DeparturePort', 'ArrivalPort'];

            required.forEach(field => {
                const $field = $(`[name="${field}"]`);
                if (!$field.val()?.trim()) {
                    errors.push(`${field} harus diisi`);
                    $field.addClass('is-invalid');
                } else {
                    $field.removeClass('is-invalid');
                }
            });

            if (errors.length > 0) {
                showSimpleAlert('Validasi gagal:\n' + errors.join('\n'), 'danger');
                return false;
            }

            return true;
        }

        function updateUploadProgress() {
            const count = uploadedDocuments.size;
            const percentage = (count / totalRequiredFiles) * 100;

            $('#uploadProgress').css('width', percentage + '%');
            $('#uploadProgressText').text(`${count} dari ${totalRequiredFiles} dokumen`);

            console.log(`📊 Progress: ${count}/${totalRequiredFiles}`);
        }

        function updateDocumentChecklist() {
            documentTypes.forEach(docType => {
                const $item = $(`.checklist-item[data-doc="${docType}"]`);
                const $icon = $item.find('i');

                if (uploadedDocuments.has(docType)) {
                    $icon.removeClass('fas fa-times-circle text-danger')
                         .addClass('fas fa-check-circle text-success');
                    $item.addClass('completed');
                } else {
                    $icon.removeClass('fas fa-check-circle text-success')
                         .addClass('fas fa-times-circle text-danger');
                    $item.removeClass('completed');
                }
            });
        }

        function formatFileSize(bytes) {
            if (bytes === 0) return '0 Bytes';
            const k = 1024;
            const sizes = ['Bytes', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
        }

        function showSimpleAlert(message, type) {
            $('.upload-alert').remove();

            const alertClass = {
                'success': 'alert-success',
                'danger': 'alert-danger',
                'info': 'alert-info',
                'warning': 'alert-warning'
            }[type] || 'alert-info';

            const alert = $(`
                <div class="alert ${alertClass} alert-dismissible fade show upload-alert"
                     style="position: fixed; top: 20px; right: 20px; z-index: 9999; max-width: 400px;">
                    ${message.replace(/\n/g, '<br>')}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `);

            $('body').append(alert);

            setTimeout(() => alert.fadeOut(), type === 'danger' ? 5000 : 3000);
        }

        function addLivestockItem() {
            const template = `
                <div class="livestock-item" data-index="${livestockIndex}">
                    <div class="livestock-header">
                        <h4>Ternak #<span class="livestock-number">${livestockIndex + 1}</span></h4>
                        <button type="button" class="btn btn-sm btn-outline-danger remove-livestock">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                    <div class="livestock-form">
                        <div class="form-group">
                            <label class="form-label required">Jenis Ternak</label>
                            <select name="LivestockDetails[${livestockIndex}].LivestockType" class="form-control livestock-type" required>
                                <option value="">Pilih Jenis Ternak</option>
                                <option value="Sapi Potong">Sapi Potong</option>
                                <option value="Kerbau Potong">Kerbau Potong</option>
                                <option value="Kuda Pedaging">Kuda Pedaging</option>
                                <option value="Kambing">Kambing</option>
                                <option value="Domba">Domba</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label required">Jumlah (ekor)</label>
                            <input type="number" name="LivestockDetails[${livestockIndex}].Quantity"
                                   class="form-control livestock-quantity" min="1" max="10000" required />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Keterangan</label>
                            <textarea name="LivestockDetails[${livestockIndex}].Description"
                                      class="form-control" rows="2"></textarea>
                        </div>
                    </div>
                </div>
            `;

            $('#livestockContainer').append(template);
            livestockIndex++;
            updateLivestockNumbers();
            updateSummary();
        }

        function updateLivestockNumbers() {
            $('.livestock-item').each(function(index) {
                $(this).find('.livestock-number').text(index + 1);

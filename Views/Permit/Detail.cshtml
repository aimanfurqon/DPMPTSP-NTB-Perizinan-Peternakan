@model PerizinanPeternakan.ViewModels.PermitDetailViewModel
@{
    ViewData["Title"] = "Detail Permohonan";
    var userRole = Context.Session.GetString("Role");
}

<div class="permit-detail-container">
    <div class="detail-header">
        <div class="header-content">
            <h1 class="detail-title">
                <i class="fas fa-file-alt"></i>
                Detail Permohonan
            </h1>
            <div class="header-actions">
                <a href="@Url.Action("Index", "Permit")" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left"></i>
                    Kembali
                </a>

                @if (Model.CanDownload && Context.Session.GetString("Role") == "User")
                {
                    <a href="@Url.Action("Download", "Permit", new { id = Model.Id })" class="btn btn-success">
                        <i class="fas fa-download"></i>
                        Download PDF
                    </a>
                }

                @if (!string.IsNullOrEmpty(Model.GeneratedDocumentPath) &&
                                (Context.Session.GetString("Role") == "Verifikator" || Context.Session.GetString("Role") == "KepalaDinas"))
                {
                    <a href="@Url.Action("ViewDocument", "Permit", new { id = Model.Id })" class="btn btn-info">
                        <i class="fas fa-eye"></i>
                        Lihat Dokumen
                    </a>
                }

                @if (Model.CanApprove)
                {
                    <a href="@Url.Action("Approve", "Permit", new { id = Model.Id })" class="btn btn-primary">
                        <i class="fas fa-gavel"></i>
                        Proses Permohonan
                    </a>
                }
            </div>
        </div>

        <div class="permit-status">
            <span class="status-badge badge-@PermitStatusHelper.GetStatusClass(Model.Status)">
                @PermitStatusHelper.GetStatusText(Model.Status)
            </span>
        </div>
    </div>

    <div class="detail-content">
        <div class="content-grid">
            <!-- Informasi Umum -->
            <div class="info-card">
                <div class="card-header">
                    <h3>
                        <i class="fas fa-info-circle"></i>
                        Informasi Umum
                    </h3>
                </div>
                <div class="card-body">
                    <div class="info-grid">
                        <div class="info-item">
                            <label>Nomor Permohonan</label>
                            <span class="value highlight">@Model.ApplicationNumber</span>
                        </div>
                        <div class="info-item">
                            <label>Tanggal Pengajuan</label>
                            <span class="value">@Model.SubmissionDate.ToString("dd MMMM yyyy")</span>
                        </div>
                        <div class="info-item">
                            <label>Status</label>
                            <span class="status-badge badge-@PermitStatusHelper.GetStatusClass(Model.Status)">
                                @PermitStatusHelper.GetStatusText(Model.Status)
                            </span>
                        </div>
                        @if (Model.ValidFrom.HasValue && Model.ValidUntil.HasValue)
                        {
                            <div class="info-item">
                                <label>Masa Berlaku</label>
                                <span class="value">@Model.ValidFrom.Value.ToString("dd MMM yyyy") - @Model.ValidUntil.Value.ToString("dd MMM yyyy")</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Informasi Pemohon -->
            <div class="info-card">
                <div class="card-header">
                    <h3>
                        <i class="fas fa-user"></i>
                        Informasi Pemohon
                    </h3>
                </div>
                <div class="card-body">
                    <div class="info-grid">
                        <div class="info-item">
                            <label>Nama Lengkap</label>
                            <span class="value">@Model.ApplicantName</span>
                        </div>
                        <div class="info-item">
                            <label>Email</label>
                            <span class="value">@Model.ApplicantEmail</span>
                        </div>
                        <div class="info-item">
                            <label>Nomor Telepon</label>
                            <span class="value">@Model.ApplicantPhone</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Informasi Perusahaan -->
        <div class="info-card full-width">
            <div class="card-header">
                <h3>
                    <i class="fas fa-building"></i>
                    Informasi Perusahaan
                </h3>
            </div>
            <div class="card-body">
                <div class="info-grid">
                    <div class="info-item">
                        <label>Nama Perusahaan</label>
                        <span class="value">@Model.CompanyName</span>
                    </div>
                    <div class="info-item full-width">
                        <label>Alamat Perusahaan</label>
                        <span class="value">@Model.CompanyAddress</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Detail Pengiriman -->
        <div class="info-card full-width">
            <div class="card-header">
                <h3>
                    <i class="fas fa-shipping-fast"></i>
                    Detail Pengiriman
                </h3>
            </div>
            <div class="card-body">
                <div class="shipping-route">
                    <div class="route-item">
                        <div class="route-icon origin">
                            <i class="fas fa-map-marker-alt"></i>
                        </div>
                        <div class="route-content">
                            <h4>Asal Ternak</h4>
                            <p>@Model.OriginLocation</p>
                            <small>Pelabuhan: @Model.DeparturePort</small>
                        </div>
                    </div>

                    <div class="route-arrow">
                        <i class="fas fa-arrow-right"></i>
                    </div>

                    <div class="route-item">
                        <div class="route-icon destination">
                            <i class="fas fa-map-marker-alt"></i>
                        </div>
                        <div class="route-content">
                            <h4>Tujuan Pengiriman</h4>
                            <p>@Model.DestinationLocation</p>
                            <small>Pelabuhan: @Model.ArrivalPort</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Detail Ternak -->
        <div class="info-card full-width">
            <div class="card-header">
                <h3>
                    <i class="fas fa-paw"></i>
                    Detail Ternak
                </h3>
            </div>
            <div class="card-body">
                <div class="livestock-table-container">
                    <table class="livestock-table">
                        <thead>
                            <tr>
                                <th>No.</th>
                                <th>Jenis Ternak</th>
                                <th>Jumlah</th>
                                <th>Keterangan</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.LivestockDetails.Count; i++)
                            {
                                <tr>
                                    <td>@(i + 1)</td>
                                    <td>@Model.LivestockDetails[i].LivestockType</td>
                                    <td>@Model.LivestockDetails[i].Quantity ekor</td>
                                    <td>@(Model.LivestockDetails[i].Description ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="total-row">
                                <td colspan="2"><strong>Total</strong></td>
                                <td><strong>@Model.LivestockDetails.Sum(l => l.Quantity) ekor</strong></td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <!-- History Persetujuan -->
        <div class="info-card full-width">
            <div class="card-header">
                <h3>
                    <i class="fas fa-history"></i>
                    Riwayat Persetujuan
                </h3>
            </div>
            <div class="card-body">
                <div class="timeline">
                    @foreach (var history in Model.ApprovalHistory)
                    {
                        <div class="timeline-item">
                            <div class="timeline-marker @GetTimelineClass(history.Action)">
                                <i class="@GetTimelineIcon(history.Action)"></i>
                            </div>
                            <div class="timeline-content">
                                <div class="timeline-header">
                                    <h4>@history.Action</h4>
                                    <span class="timeline-date">@history.ActionDate.ToString("dd MMM yyyy HH:mm")</span>
                                </div>
                                <div class="timeline-body">
                                    <p><strong>Oleh:</strong> @history.ActionBy (@history.ActionByRole)</p>
                                    @if (!string.IsNullOrEmpty(history.Comments))
                                    {
                                        <p><strong>Komentar:</strong> @history.Comments</p>
                                    }
                                    <p><strong>Status:</strong> @PermitStatusHelper.GetStatusText(history.FromStatus) → @PermitStatusHelper.GetStatusText(history.ToStatus)</p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.RejectionReason))
        {
            <div class="info-card full-width rejection-card">
                <div class="card-header">
                    <h3>
                        <i class="fas fa-exclamation-triangle"></i>
                        Alasan Penolakan
                    </h3>
                </div>
                <div class="card-body">
                    <p class="rejection-reason">@Model.RejectionReason</p>
                </div>
            </div>
        }
    </div>
</div>

@functions {
    private string GetTimelineClass(string action)
    {
        return action.ToLower() switch
        {
            "submit" => "primary",
            "disetujui admin" => "success",
            "ditolak admin" => "danger",
            "disetujui verifikator" => "success",
            "ditolak verifikator" => "danger",
            "disetujui kepala dinas" => "success",
            "ditolak kepala dinas" => "danger",
            _ => "secondary"
        };
    }

    private string GetTimelineIcon(string action)
    {
        return action.ToLower() switch
        {
            "submit" => "fas fa-paper-plane",
            "disetujui admin" => "fas fa-check",
            "ditolak admin" => "fas fa-times",
            "disetujui verifikator" => "fas fa-check",
            "ditolak verifikator" => "fas fa-times",
            "disetujui kepala dinas" => "fas fa-stamp",
            "ditolak kepala dinas" => "fas fa-ban",
            _ => "fas fa-circle"
        };
    }
}

<style>
    .permit-detail-container {
        padding: 20px;
        max-width: 1200px;
        margin: 0 auto;
    }

    .detail-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 2px solid #e9ecef;
    }

    .header-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
    }

    .detail-title {
        color: #333;
        margin: 0;
        font-size: 28px;
        font-weight: 600;
    }

        .detail-title i {
            margin-right: 12px;
            color: #667eea;
        }

    .header-actions {
        display: flex;
        gap: 10px;
    }

    .permit-status {
        margin-top: 10px;
    }

    .status-badge {
        padding: 8px 16px;
        border-radius: 20px;
        font-size: 14px;
        font-weight: 600;
        text-transform: uppercase;
    }

    .badge-secondary {
        background: #6c757d;
        color: white;
    }

    .badge-info {
        background: #17a2b8;
        color: white;
    }

    .badge-warning {
        background: #ffc107;
        color: #212529;
    }

    .badge-primary {
        background: #007bff;
        color: white;
    }

    .badge-danger {
        background: #dc3545;
        color: white;
    }

    .badge-success {
        background: #28a745;
        color: white;
    }

    .detail-content {
        display: flex;
        flex-direction: column;
        gap: 25px;
    }

    .content-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 25px;
    }

    .info-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        overflow: hidden;
    }

        .info-card.full-width {
            grid-column: 1 / -1;
        }

    .card-header {
        background: #f8f9fa;
        padding: 20px;
        border-bottom: 1px solid #e9ecef;
    }

        .card-header h3 {
            margin: 0;
            color: #333;
            font-size: 18px;
            font-weight: 600;
        }

        .card-header i {
            margin-right: 10px;
            color: #667eea;
        }

    .card-body {
        padding: 25px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .info-item {
        display: flex;
        flex-direction: column;
    }

        .info-item.full-width {
            grid-column: 1 / -1;
        }

        .info-item label {
            font-size: 14px;
            color: #666;
            margin-bottom: 5px;
            font-weight: 500;
        }

        .info-item .value {
            font-size: 16px;
            color: #333;
            font-weight: 600;
        }

            .info-item .value.highlight {
                color: #667eea;
                font-size: 18px;
            }

    .shipping-route {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 30px;
    }

    .route-item {
        display: flex;
        align-items: center;
        flex: 1;
        gap: 15px;
    }

    .route-icon {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        color: white;
    }

        .route-icon.origin {
            background: #28a745;
        }

        .route-icon.destination {
            background: #dc3545;
        }

    .route-content h4 {
        margin: 0 0 5px 0;
        color: #333;
        font-size: 16px;
        font-weight: 600;
    }

    .route-content p {
        margin: 0 0 5px 0;
        color: #333;
        font-size: 14px;
    }

    .route-content small {
        color: #666;
        font-size: 12px;
    }

    .route-arrow {
        font-size: 24px;
        color: #667eea;
        margin: 0 20px;
    }

    .livestock-table-container {
        overflow-x: auto;
    }

    .livestock-table {
        width: 100%;
        border-collapse: collapse;
        margin: 0;
    }

        .livestock-table th,
        .livestock-table td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #e9ecef;
        }

        .livestock-table th {
            background: #f8f9fa;
            font-weight: 600;
            color: #333;
        }

        .livestock-table tbody tr:hover {
            background: #f8f9fa;
        }

    .total-row {
        background: #f8f9fa;
        font-weight: 600;
    }

    .timeline {
        position: relative;
    }

        .timeline::before {
            content: '';
            position: absolute;
            left: 25px;
            top: 0;
            bottom: 0;
            width: 2px;
            background: #e9ecef;
        }

    .timeline-item {
        position: relative;
        display: flex;
        margin-bottom: 30px;
    }

    .timeline-marker {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 16px;
        margin-right: 20px;
        position: relative;
        z-index: 2;
    }

        .timeline-marker.primary {
            background: #007bff;
        }

        .timeline-marker.success {
            background: #28a745;
        }

        .timeline-marker.danger {
            background: #dc3545;
        }

        .timeline-marker.secondary {
            background: #6c757d;
        }

    .timeline-content {
        flex: 1;
        background: #f8f9fa;
        border-radius: 8px;
        padding: 20px;
        margin-top: 5px;
    }

    .timeline-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 10px;
    }

        .timeline-header h4 {
            margin: 0;
            color: #333;
            font-size: 16px;
            font-weight: 600;
        }

    .timeline-date {
        color: #666;
        font-size: 12px;
    }

    .timeline-body p {
        margin: 5px 0;
        color: #333;
        font-size: 14px;
    }

    .rejection-card {
        border-left: 4px solid #dc3545;
    }

    .rejection-reason {
        background: #fff5f5;
        padding: 15px;
        border-radius: 8px;
        color: #721c24;
        font-size: 14px;
        margin: 0;
    }

    @@media (max-width: 768px) {
        .permit-detail-container

    {
        padding: 15px;
    }

    .header-content {
        flex-direction: column;
        align-items: flex-start;
        gap: 15px;
    }

    .header-actions {
        width: 100%;
        justify-content: flex-start;
    }

    .content-grid {
        grid-template-columns: 1fr;
    }

    .info-grid {
        grid-template-columns: 1fr;
    }

    .shipping-route {
        flex-direction: column;
        gap: 20px;
    }

    .route-arrow {
        transform: rotate(90deg);
        margin: 10px 0;
    }

    .detail-title {
        font-size: 24px;
    }

    .timeline::before {
        left: 20px;
    }

    .timeline-marker {
        width: 40px;
        height: 40px;
        font-size: 14px;
    }

    }
</style>
@model List<PerizinanPeternakan.ViewModels.PermitListViewModel>
@{
    ViewData["Title"] = "Daftar Permohonan Izin";
    var userRole = Context.Session.GetString("Role");
}

<div class="permits-container">
    <div class="page-header">
        <div class="header-content">
            <h1 class="page-title">
                <i class="fas fa-file-alt"></i>
                @if (userRole == "User")
                {
                    <text>Permohonan Izin Saya</text>
                }
                else if (userRole == "Verifikator")
                {
                    <text>Permohonan Perlu Verifikasi</text>
                }
                else if (userRole == "Admin")
                {
                    <text>Permohonan Perlu Review</text>
                }
                else
                {
                    <text>Permohonan Perlu Persetujuan</text>
                }
            </h1>
            <p class="page-subtitle">Kelola permohonan izin pengeluaran ternak potong</p>
        </div>

        @if (userRole == "User")
        {
            <div class="header-actions">
                <a asp-action="Create" class="btn btn-primary">
                    <i class="fas fa-plus"></i>
                    Permohonan Baru
                </a>
            </div>
        }
    </div>

    @if (Model.Any())
    {
        <div class="permits-grid">
            @foreach (var permit in Model)
            {
                <div class="permit-card">
                    <div class="card-header">
                        <div class="permit-number">
                            <i class="fas fa-hashtag"></i>
                            @permit.ApplicationNumber
                        </div>
                        <span class="status-badge badge-@PermitStatusHelper.GetStatusClass(permit.Status)">
                            @PermitStatusHelper.GetStatusText(permit.Status)
                        </span>
                    </div>

                    <div class="card-body">
                        <h3 class="company-name">@permit.CompanyName</h3>
                        <p class="applicant-name">
                            <i class="fas fa-user"></i>
                            @permit.ApplicantName
                        </p>

                        <div class="permit-details">
                            <div class="detail-item">
                                <i class="fas fa-map-marker-alt text-success"></i>
                                <span class="detail-label">Asal:</span>
                                <span class="detail-value">@permit.OriginLocation</span>
                            </div>
                            <div class="detail-item">
                                <i class="fas fa-map-marker-alt text-danger"></i>
                                <span class="detail-label">Tujuan:</span>
                                <span class="detail-value">@permit.DestinationLocation</span>
                            </div>
                            <div class="detail-item">
                                <i class="fas fa-calendar"></i>
                                <span class="detail-label">Diajukan:</span>
                                <span class="detail-value">@permit.SubmissionDate.ToString("dd/MM/yyyy")</span>
                            </div>
                            @if (permit.AdminApprovalDate.HasValue && userRole != "User")
                            {
                                <div class="detail-item">
                                    <i class="fas fa-check-circle text-primary"></i>
                                    <span class="detail-label">Admin:</span>
                                    <span class="detail-value">@permit.AdminApprovalDate.Value.ToString("dd/MM/yyyy")</span>
                                </div>
                            }
                            @if (permit.VerificationDate.HasValue && userRole == "KepalaDinas")
                            {
                                <div class="detail-item">
                                    <i class="fas fa-clipboard-check text-info"></i>
                                    <span class="detail-label">Verifikasi:</span>
                                    <span class="detail-value">@permit.VerificationDate.Value.ToString("dd/MM/yyyy")</span>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="card-footer">
                        <div class="action-buttons">
                            <a asp-action="Detail" asp-route-id="@permit.Id" class="btn btn-outline-primary btn-sm">
                                <i class="fas fa-eye"></i>
                                Detail
                            </a>

                            @if (permit.CanApprove)
                            {
                                <a asp-action="Approve" asp-route-id="@permit.Id" class="btn btn-warning btn-sm">
                                    <i class="fas fa-check-circle"></i>
                                    Proses
                                </a>
                            }

                            @* Untuk User - hanya bisa download jika sudah approved *@
                            @if (permit.CanDownload && userRole == "User")
                            {
                                <a asp-action="Download" asp-route-id="@permit.Id" class="btn btn-success btn-sm">
                                    <i class="fas fa-download"></i>
                                    Download
                                </a>
                            }

                            @* Untuk Verifikator dan KepalaDinas - lihat dokumen tanpa download *@
                            @if (!string.IsNullOrEmpty(permit.GeneratedDocumentPath) &&
                                                (userRole == "Verifikator" || userRole == "KepalaDinas" || userRole == "Admin"))
                            {
                                <button type="button" class="btn btn-info btn-sm"
                                        onclick="viewDocumentModal('@permit.Id', '@permit.ApplicationNumber')">
                                    <i class="fas fa-file-pdf"></i>
                                    Lihat Dokumen
                                </button>
                            }

                            @* Link ke halaman view document untuk semua yang berhak *@
                            @if (!string.IsNullOrEmpty(permit.GeneratedDocumentPath) &&
                                                (userRole == "Verifikator" || userRole == "KepalaDinas"))
                            {
                                <a asp-action="ViewDocument" asp-route-id="@permit.Id" class="btn btn-secondary btn-sm">
                                    <i class="fas fa-external-link-alt"></i>
                                    Buka Dokumen
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">
                <i class="fas fa-inbox"></i>
            </div>
            <h3>Tidak Ada Permohonan</h3>
            <p class="empty-description">
                @if (userRole == "User")
                {
                    <text>Anda belum memiliki permohonan izin. Buat permohonan baru untuk memulai.</text>
                }
                else
                {
                    <text>Tidak ada permohonan yang perlu diproses saat ini.</text>
                }
            </p>
            @if (userRole == "User")
            {
                <a asp-action="Create" class="btn btn-primary">
                    <i class="fas fa-plus"></i>
                    Buat Permohonan Baru
                </a>
            }
        </div>
    }
</div>

<!-- Modal untuk menampilkan dokumen dalam iframe -->
<div class="modal fade" id="documentModal" tabindex="-1" aria-labelledby="documentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="documentModalLabel">
                    <i class="fas fa-file-pdf text-danger"></i>
                    Dokumen Permohonan
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div class="document-viewer">
                    <div class="viewer-header">
                        <div class="document-info">
                            <h6 id="documentTitle">Memuat dokumen...</h6>
                            <div class="viewer-controls">
                                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="downloadFromModal()">
                                    <i class="fas fa-download"></i>
                                    Download
                                </button>
                                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="printFromModal()">
                                    <i class="fas fa-print"></i>
                                    Print
                                </button>
                                <button type="button" class="btn btn-outline-primary btn-sm" onclick="openInNewTab()">
                                    <i class="fas fa-external-link-alt"></i>
                                    Buka di Tab Baru
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="viewer-container">
                        <div class="loading-spinner" id="documentLoader">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p>Memuat dokumen...</p>
                        </div>
                        <iframe id="documentFrame" src="" style="display: none; width: 100%; height: 600px; border: none; border-radius: 0 0 8px 8px;"></iframe>
                        <div class="error-message" id="documentError" style="display: none;">
                            <i class="fas fa-exclamation-triangle text-warning"></i>
                            <p>Gagal memuat dokumen. Silakan coba lagi atau buka di tab baru.</p>
                            <button type="button" class="btn btn-outline-primary" onclick="retryLoadDocument()">
                                <i class="fas fa-redo"></i>
                                Coba Lagi
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Tutup</button>
                <a href="#" id="approveFromModal" class="btn btn-warning" style="display: none;">
                    <i class="fas fa-check-circle"></i>
                    Proses Permohonan
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentPermitId = null;
        let currentApplicationNumber = null;

        function viewDocumentModal(permitId, applicationNumber) {
            currentPermitId = permitId;
            currentApplicationNumber = applicationNumber;

            // Show modal
            const modal = new bootstrap.Modal(document.getElementById('documentModal'));
            modal.show();

            // Reset modal state
            document.getElementById('documentTitle').innerText = `Dokumen ${applicationNumber}`;
            document.getElementById('documentLoader').style.display = 'block';
            document.getElementById('documentFrame').style.display = 'none';
            document.getElementById('documentError').style.display = 'none';

            // Update approve button if user can approve
            const approveBtn = document.getElementById('approveFromModal');
            @if (userRole == "Verifikator" || userRole == "KepalaDinas" || userRole == "Admin")
            {
                    <text>
                    approveBtn.href = '@Url.Action("Approve", "Permit")/' + permitId;
                    approveBtn.style.display = 'inline-block';
                    </text>
            }

            // Load document
            loadDocumentInModal(permitId);
        }

        function loadDocumentInModal(permitId) {
            const iframe = document.getElementById('documentFrame');
            const loader = document.getElementById('documentLoader');
            const errorDiv = document.getElementById('documentError');

            // Set iframe source
            iframe.src = `@Url.Action("GetDocumentFile", "Permit")/${permitId}`;

            // Handle iframe load
            iframe.onload = function() {
                try {
                    // Check if iframe loaded successfully
                    if (iframe.contentDocument || iframe.contentWindow.document) {
                        loader.style.display = 'none';
                        iframe.style.display = 'block';
                        errorDiv.style.display = 'none';
                    }
                } catch (e) {
                    // Cross-origin or other error
                    setTimeout(() => {
                        loader.style.display = 'none';
                        iframe.style.display = 'block';
                        errorDiv.style.display = 'none';
                    }, 1000);
                }
            };

            // Handle iframe error
            iframe.onerror = function() {
                loader.style.display = 'none';
                iframe.style.display = 'none';
                errorDiv.style.display = 'block';
            };

            // Fallback timeout
            setTimeout(() => {
                if (loader.style.display !== 'none') {
                    loader.style.display = 'none';
                    iframe.style.display = 'block';
                }
            }, 3000);
        }

        function downloadFromModal() {
            if (currentPermitId) {
                window.open(`@Url.Action("Download", "Permit")/${currentPermitId}`, '_blank');
            }
        }

        function printFromModal() {
            const iframe = document.getElementById('documentFrame');
            try {
                if (iframe.contentWindow) {
                    iframe.contentWindow.print();
                } else {
                    // Fallback: open in new window and print
                    const printWindow = window.open(`@Url.Action("GetDocumentFile", "Permit")/${currentPermitId}`, '_blank');
                    printWindow.onload = function() {
                        printWindow.print();
                    };
                }
            } catch (e) {
                console.log('Print error:', e);
                alert('Tidak dapat mencetak dari modal. Silakan buka dokumen di tab baru untuk mencetak.');
            }
        }

        function openInNewTab() {
            if (currentPermitId) {
                window.open(`@Url.Action("ViewDocument", "Permit")/${currentPermitId}`, '_blank');
            }
        }

        function retryLoadDocument() {
            if (currentPermitId) {
                loadDocumentInModal(currentPermitId);
            }
        }

        // Clean up when modal is closed
        document.getElementById('documentModal').addEventListener('hidden.bs.modal', function() {
            const iframe = document.getElementById('documentFrame');
            iframe.src = 'about:blank';
            currentPermitId = null;
            currentApplicationNumber = null;
        });
    </script>
}


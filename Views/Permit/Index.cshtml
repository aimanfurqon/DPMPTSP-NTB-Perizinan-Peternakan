@model List<PerizinanPeternakan.ViewModels.PermitListViewModel>
@{
    ViewData["Title"] = "Daftar Permohonan Izin";
    var userRole = Context.Session.GetString("Role");
}

<div class="permits-container">
    <div class="page-header">
        <div class="header-content">
            <h1 class="page-title">
                <i class="fas fa-file-alt"></i>
                @if (userRole == "User")
                {
                    <text>Permohonan Izin Saya</text>
                }
                else if (userRole == "Verifikator")
                {
                    <text>Permohonan Perlu Verifikasi</text>
                }
                else
                {
                    <text>Permohonan Perlu Persetujuan</text>
                }
            </h1>
            <p class="page-subtitle">Kelola permohonan izin pengeluaran ternak potong</p>
        </div>

        @if (userRole == "User")
        {
            <div class="header-actions">
                <a asp-action="Create" class="btn btn-primary">
                    <i class="fas fa-plus"></i>
                    Permohonan Baru
                </a>
            </div>
        }
    </div>

    @if (Model.Any())
    {
        <div class="permits-grid">
            @foreach (var permit in Model)
            {
                <div class="permit-card">
                    <div class="card-header">
                        <div class="permit-number">
                            <i class="fas fa-hashtag"></i>
                            @permit.ApplicationNumber
                        </div>
                        <span class="status-badge badge-@PermitStatusHelper.GetStatusClass(permit.Status)">
                            @PermitStatusHelper.GetStatusText(permit.Status)
                        </span>
                    </div>

                    <div class="card-body">
                        <h3 class="company-name">@permit.CompanyName</h3>
                        <p class="applicant-name">
                            <i class="fas fa-user"></i>
                            @permit.ApplicantName
                        </p>

                        <div class="permit-details">
                            <div class="detail-item">
                                <i class="fas fa-map-marker-alt text-success"></i>
                                <span class="detail-label">Asal:</span>
                                <span class="detail-value">@permit.OriginLocation</span>
                            </div>
                            <div class="detail-item">
                                <i class="fas fa-map-marker-alt text-danger"></i>
                                <span class="detail-label">Tujuan:</span>
                                <span class="detail-value">@permit.DestinationLocation</span>
                            </div>
                            <div class="detail-item">
                                <i class="fas fa-calendar"></i>
                                <span class="detail-label">Diajukan:</span>
                                <span class="detail-value">@permit.SubmissionDate.ToString("dd/MM/yyyy")</span>
                            </div>
                        </div>
                    </div>

                    <div class="card-footer">
                        <div class="action-buttons">
                            <a asp-action="Detail" asp-route-id="@permit.Id" class="btn btn-outline-primary btn-sm">
                                <i class="fas fa-eye"></i>
                                Detail
                            </a>

                            @if (permit.CanApprove)
                            {
                                <a asp-action="Approve" asp-route-id="@permit.Id" class="btn btn-warning btn-sm">
                                    <i class="fas fa-check-circle"></i>
                                    Proses
                                </a>
                            }

                            @if (permit.CanDownload)
                            {
                                <a asp-action="Download" asp-route-id="@permit.Id" class="btn btn-success btn-sm">
                                    <i class="fas fa-download"></i>
                                    Download
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (Model.Count == 10)
        {
            <div class="text-center mt-4">
                <button class="btn btn-outline-primary" onclick="loadMore()">
                    <i class="fas fa-chevron-down"></i>
                    Muat Lebih Banyak
                </button>
            </div>
        }
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">
                <i class="fas fa-inbox"></i>
            </div>
            <h3>
                @if (userRole == "User")
                {
                    <text>Belum Ada Permohonan</text>
                }
                else
                {
                    <text>Tidak Ada Permohonan untuk Diproses</text>
                }
            </h3>
            <p>
                @if (userRole == "User")
                {
                    <text>Anda belum memiliki permohonan izin. Buat permohonan baru untuk memulai.</text>
                }
                else
                {
                    <text>Saat ini tidak ada permohonan yang perlu diproses.</text>
                }
            </p>

            @if (userRole == "User")
            {
                <a asp-action="Create" class="btn btn-primary mt-3">
                    <i class="fas fa-plus"></i>
                    Buat Permohonan Pertama
                </a>
            }
        </div>
    }
</div>

<style>
    .permits-container {
        padding: 20px;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 2px solid #e9ecef;
    }

    .header-content h1 {
        color: #333;
        margin-bottom: 8px;
        font-size: 28px;
        font-weight: 600;
    }

        .header-content h1 i {
            margin-right: 12px;
            color: #667eea;
        }

    .page-subtitle {
        color: #666;
        margin: 0;
        font-size: 16px;
    }

    .header-actions .btn {
        padding: 12px 24px;
        font-weight: 600;
        border-radius: 8px;
    }

    .permits-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
        gap: 25px;
    }

    .permit-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
        overflow: hidden;
    }

        .permit-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
        }

    .card-header {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        padding: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #e9ecef;
    }

    .permit-number {
        font-weight: 600;
        color: #333;
        font-size: 14px;
    }

        .permit-number i {
            margin-right: 8px;
            color: #667eea;
        }

    .status-badge {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
    }

    .badge-secondary {
        background: #6c757d;
        color: white;
    }

    .badge-info {
        background: #17a2b8;
        color: white;
    }

    .badge-warning {
        background: #ffc107;
        color: #212529;
    }

    .badge-primary {
        background: #007bff;
        color: white;
    }

    .badge-danger {
        background: #dc3545;
        color: white;
    }

    .badge-success {
        background: #28a745;
        color: white;
    }

    .card-body {
        padding: 20px;
    }

    .company-name {
        font-size: 18px;
        font-weight: 600;
        color: #333;
        margin-bottom: 8px;
    }

    .applicant-name {
        color: #666;
        margin-bottom: 15px;
        font-size: 14px;
    }

        .applicant-name i {
            margin-right: 8px;
            color: #667eea;
        }

    .permit-details {
        space-y: 8px;
    }

    .detail-item {
        display: flex;
        align-items: center;
        margin-bottom: 8px;
        font-size: 14px;
    }

        .detail-item i {
            width: 16px;
            margin-right: 8px;
        }

    .detail-label {
        font-weight: 500;
        margin-right: 8px;
        color: #555;
    }

    .detail-value {
        color: #333;
    }

    .card-footer {
        background: #f8f9fa;
        padding: 15px 20px;
        border-top: 1px solid #e9ecef;
    }

    .action-buttons {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

        .action-buttons .btn {
            flex: 1;
            min-width: 80px;
            font-size: 12px;
            padding: 8px 12px;
            border-radius: 6px;
            font-weight: 500;
        }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    }

    .empty-icon {
        font-size: 64px;
        color: #e9ecef;
        margin-bottom: 20px;
    }

    .empty-state h3 {
        color: #333;
        margin-bottom: 12px;
        font-size: 24px;
    }

    .empty-state p {
        color: #666;
        font-size: 16px;
        max-width: 400px;
        margin: 0 auto;
    }

    @@media (max-width: 768px) {
        .page-header

    {
        flex-direction: column;
        align-items: flex-start;
        gap: 20px;
    }

    .permits-grid {
        grid-template-columns: 1fr;
        gap: 20px;
    }

    .permit-card {
        margin-bottom: 0;
    }

    .card-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 10px;
    }

    .action-buttons {
        flex-direction: column;
    }

        .action-buttons .btn {
            flex: none;
            width: 100%;
        }

    }
</style>

<script>
    function loadMore() {
        // Implementation for loading more permits
        // This would typically involve AJAX call to load more data
        console.log('Load more permits');
    }
</script>
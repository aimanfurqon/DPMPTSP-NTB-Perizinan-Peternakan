            function initializeEditPortSearch() {
            // Initialize Select2 with search functionality
            $('#editDeparturePortSelect, #editArrivalPortSelect').select2({
                theme: 'bootstrap-5',
                width: '100%',
                placeholder: 'Ketik untuk mencari pelabuhan...',
                allowClear: true,
                minimumInputLength: 2,
                ajax: {
                    url: '/Port/Search',
                    dataType: 'json',
                    delay: 300,
                    data: function (params) {
                        return {
                            term: params.term

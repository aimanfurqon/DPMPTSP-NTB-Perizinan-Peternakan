            }


                function updateEditShippingSummary() {
            const originLocation = $('#EditableOriginLocation').val();
            const destinationLocation = $('#EditableDestinationLocation').val();
            const departurePort = $('#EditableDeparturePort').val();
            const arrivalPort = $('#EditableArrivalPort').val();

            // ⭐ UPDATED: Better port name display
            const departurePortDisplay = departurePort || '-';
            const arrivalPortDisplay = arrivalPort || '-';

            $('#editSummaryOrigin').text(originLocation || '-');
            $('#editSummaryDestination').text(destinationLocation || '-');
            $('#editSummaryDeparturePort').text(departurePortDisplay);
            $('#editSummaryArrivalPort').text(arrivalPortDisplay);

            if (originLocation && destinationLocation && departurePort && arrivalPort) {
                $('#editShippingSummary').slideDown();
            } else {
                $('#editShippingSummary').slideUp();
            }
        }
            // ===============================================
            // LIVESTOCK EDIT HANDLERS
            // ===============================================

            function setupEditLivestockHandlers() {
                // Livestock type change
                $(document).on('change', '.livestock-type', function() {
                    const index = $(this).data('index');
                    const selectedType = $(this).val();

                    if (selectedType && editOriginProvinceCode) {
                        validateEditQuotaForType(selectedType, index);
                    } else {
                        hideEditQuotaIndicator(index);
                    }

                    updateEditSummary();
                });

                // Livestock quantity change
                $(document).on('input change', '.livestock-quantity', function() {
                    const index = $(this).data('index');
                    const quantity = parseInt($(this).val()) || 0;
                    const livestockType = $(`.livestock-type[data-index="${index}"]`).val();

                    if (livestockType && editOriginProvinceCode && quantity > 0) {
                        validateEditQuantityRealtime(livestockType, editOriginProvinceCode, quantity, index);
                    }

                    updateEditSummary();
                });

                // Add livestock button
                $('#editAddLivestock').on('click', function() {
                    addEditLivestockItem();
                });

                // Remove livestock button
                $(document).on('click', '.remove-livestock', function() {
                    const $item = $(this).closest('.livestock-item');
                    const index = $item.data('index');

                    // Mark for deletion instead of immediate removal
                    $item.find('input[name$=".IsMarkedForDeletion"]').val('true');
                    $item.hide();

                    updateEditLivestockNumbers();
                    updateEditSummary();
                    updateEditQuotaValidationSummary();
                });

                // Refresh quota button
                $('#editRefreshQuotaBtn').on('click', function() {
                    if (editOriginProvinceCode) {
                        editQuotaCache = {};
                        loadEditQuotaInfo(editOriginProvinceCode);
                        refreshAllEditQuotaValidations();
                    }
                });
            }

            function addEditLivestockItem() {
                const template = `
                    <div class="livestock-item editable" data-index="${editLivestockIndex}">
                        <div class="livestock-header">
                            <h4>Ternak #<span class="livestock-number">${editLivestockIndex + 1}</span></h4>
                            <button type="button" class="btn btn-sm btn-outline-danger remove-livestock">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                        <div class="livestock-form">
                            <input type="hidden" name="EditableLivestockDetails[${editLivestockIndex}].Id" value="" />
                            <input type="hidden" name="EditableLivestockDetails[${editLivestockIndex}].Index" value="${editLivestockIndex}" />
                            <input type="hidden" name="EditableLivestockDetails[${editLivestockIndex}].IsMarkedForDeletion" value="false" />
                            <input type="hidden" name="EditableLivestockDetails[${editLivestockIndex}].IsNewEntry" value="true" />

                            <div class="form-group">
                                <label class="form-label required">
                                    <i class="fas fa-paw"></i>
                                    Jenis Ternak
                                    <span class="quota-indicator" data-index="${editLivestockIndex}" style="display: none;">
                                        <i class="fas fa-info-circle text-primary"></i>
                                        <span class="quota-text">Loading...</span>
                                    </span>
                                </label>
                                <select name="EditableLivestockDetails[${editLivestockIndex}].LivestockType"
                                        class="form-control livestock-type editable-field"
                                        data-index="${editLivestockIndex}"
                                        data-original=""
                                        required>
        <option value="">Pilih Jenis Ternak</option>
                                   <option value="Sapi Potong">Sapi Potong</option>
                                   <option value="Kerbau Potong">Kerbau Potong</option>
                                   <option value="Kuda Pedaging">Kuda Pedaging</option>
                                   <option value="Kambing">Kambing</option>
                                   <option value="Domba">Domba</option>
                               </select>
                           </div>

                           <div class="form-group">
                               <label class="form-label required">
                                   <i class="fas fa-calculator"></i>
                                   Jumlah (ekor)
                                   <span class="quota-limit" data-index="${editLivestockIndex}" style="display: none;">
                                       <small class="text-muted">Maks: <span class="max-quota">-</span> ekor</small>
                                   </span>
                               </label>
                               <input type="number"
                                      name="EditableLivestockDetails[${editLivestockIndex}].Quantity"
                                      class="form-control livestock-quantity editable-field"
                                      data-index="${editLivestockIndex}"
                                      data-original="0"
                                      min="1"
                                      value=""
                                      placeholder="Masukkan jumlah ternak"
                                      required />
                               <div class="quantity-feedback" data-index="${editLivestockIndex}" style="display: none;">
                                   <small class="feedback-text">-</small>
                               </div>
                           </div>

                           <div class="form-group">
                               <label class="form-label">
                                   <i class="fas fa-comment"></i>
                                   Keterangan
                               </label>
                               <textarea name="EditableLivestockDetails[${editLivestockIndex}].Description"
                                         class="form-control editable-field"
                                         rows="2"
                                         data-original=""
                                         placeholder="Keterangan tambahan (opsional)"></textarea>
                           </div>
                       </div>
                   </div>
               `;

               $('#editLivestockContainer').append(template);
               editLivestockIndex++;
               updateEditLivestockNumbers();
               updateEditSummary();
           }

           function updateEditLivestockNumbers() {
               $('.livestock-item.editable:visible').each(function(index) {
                   $(this).find('.livestock-number').text(index + 1);
               });
           }

           function updateEditSummary() {
               const totalTypes = $('.livestock-item.editable:visible').length;
               let totalQuantity = 0;

               $('.livestock-item.editable:visible .livestock-quantity').each(function() {
                   totalQuantity += parseInt($(this).val()) || 0;
               });

               $('#editTotalTypes').text(totalTypes);
               $('#editTotalQuantity').text(totalQuantity.toLocaleString());
           }

           // ===============================================
           // QUOTA MANAGEMENT FOR EDIT MODE
           // ===============================================

           function loadEditQuotaInfo(provinceCode) {
               console.log('Loading edit quota info for province:', provinceCode);

               $('#editQuotaInfoPanel').show();
               $('#editQuotaInfoContent').html('<div class="text-center"><div class="quota-loading"></div> Memuat informasi kuota...</div>');

               $.get('/Quota/GetQuotasByProvince', { provinceCode: provinceCode })
                   .done(function(response) {
                       if (response.success && response.data.length > 0) {
                           displayEditQuotaInfo(response.data);
                       } else {
                           $('#editQuotaInfoContent').html('<div class="alert alert-warning">Tidak ada data kuota untuk provinsi ini.</div>');
                       }
                   })
                   .fail(function() {
                       $('#editQuotaInfoContent').html('<div class="alert alert-danger">Gagal memuat data kuota.</div>');
                   });
           }

           function displayEditQuotaInfo(quotas) {
               let html = '<div class="row">';

               quotas.forEach(quota => {
                   const usagePercentage = quota.usagePercentage;
                   const progressColor = usagePercentage < 50 ? '#28a745' :
                                        usagePercentage < 80 ? '#ffc107' : '#dc3545';
                   const iconColor = usagePercentage < 50 ? 'background: #28a745' :
                                    usagePercentage < 80 ? 'background: #ffc107' : 'background: #dc3545';

                   html += `
                       <div class="col-md-6 col-lg-4">
                           <div class="quota-card">
                               <div class="quota-info">
                                   <div class="quota-icon" style="${iconColor}">
                                       <i class="fas fa-paw"></i>
                                   </div>
                                   <div class="quota-details">
                                       <h6>${quota.livestockType}</h6>
                                       <p>Tersedia: ${quota.remainingQuota.toLocaleString()} ekor</p>
                                   </div>
                               </div>
                               <div class="quota-stats">
                                   <p class="quota-number" style="color: ${progressColor}">${quota.remainingQuota.toLocaleString()}</p>
                                   <p class="quota-label">dari ${quota.totalQuota.toLocaleString()}</p>
                                   <div class="quota-progress">
                                       <div class="quota-progress-bar" style="width: ${usagePercentage}%; background: ${progressColor}"></div>
                                   </div>
                               </div>
                           </div>
                       </div>
                   `;
               });

               html += '</div>';
               $('#editQuotaInfoContent').html(html);

               // Cache quota data
               quotas.forEach(quota => {
                   editQuotaCache[quota.livestockType] = quota;
               });
           }

           function hideEditQuotaInfo() {
               $('#editQuotaInfoPanel').hide();
               editQuotaCache = {};
           }

           function validateEditQuotaForType(livestockType, index) {
               const quota = editQuotaCache[livestockType];
               const $quantityInput = $(`.livestock-quantity[data-index="${index}"]`);
               const $quotaIndicator = $(`.quota-indicator[data-index="${index}"]`);
               const $quotaLimit = $(`.quota-limit[data-index="${index}"]`);

               if (quota) {
                   $quotaIndicator.show().find('.quota-text').text(`Kuota: ${quota.remainingQuota.toLocaleString()} ekor`);
                   $quotaLimit.show().find('.max-quota').text(quota.remainingQuota.toLocaleString());
                   $quantityInput.attr('max', quota.remainingQuota);

                   const currentQuantity = parseInt($quantityInput.val()) || 0;
                   if (currentQuantity > 0) {
                       validateEditQuantityRealtime(livestockType, editOriginProvinceCode, currentQuantity, index);
                   }
               } else {
                   loadEditQuotaForType(livestockType, index);
               }
           }

           function loadEditQuotaForType(livestockType, index) {
               $.get('/Quota/GetQuota', {
                   livestockType: livestockType,
                   provinceCode: editOriginProvinceCode
               })
               .done(function(response) {
                   const $quantityInput = $(`.livestock-quantity[data-index="${index}"]`);
                   const $quotaIndicator = $(`.quota-indicator[data-index="${index}"]`);
                   const $quotaLimit = $(`.quota-limit[data-index="${index}"]`);

                   if (response.isValid && response.availableQuota > 0) {
                       $quotaIndicator.show().find('.quota-text').text(`Kuota: ${response.availableQuota.toLocaleString()} ekor`);
                       $quotaLimit.show().find('.max-quota').text(response.availableQuota.toLocaleString());
                       $quantityInput.attr('max', response.availableQuota);

                       editQuotaCache[livestockType] = {
                           livestockType: livestockType,
                           remainingQuota: response.availableQuota,
                           totalQuota: response.totalQuota,
                           usedQuota: response.usedQuota
                       };
                   } else {
                       $quotaIndicator.show().find('.quota-text').text('Kuota habis').parent().addClass('text-danger');
                       $quantityInput.attr('max', 0);
                       showEditQuantityFeedback(index, 'error', 'Kuota untuk jenis ternak ini sudah habis');
                   }
               })
               .fail(function() {
                   showEditQuantityFeedback(index, 'error', 'Gagal memuat data kuota');
               });
           }

           function validateEditQuantityRealtime(livestockType, provinceCode, quantity, index) {
               const validationData = {
                   livestockType: livestockType,
                   provinceCode: provinceCode,
                   requestedQuantity: quantity
               };

               $.ajax({
                   url: '/Quota/ValidateQuota',
                   method: 'POST',
                   contentType: 'application/json',
                   data: JSON.stringify(validationData),
                   success: function(response) {
                       const $quantityInput = $(`.livestock-quantity[data-index="${index}"]`);

                       if (response.isValid) {
                           $quantityInput.removeClass('error').addClass('success');
                           showEditQuantityFeedback(index, 'success', response.message);
                       } else {
                           $quantityInput.removeClass('success').addClass('error');
                           showEditQuantityFeedback(index, 'error', response.message);
                       }

                       updateEditQuotaValidationSummary();
                   },
                   error: function() {
                       showEditQuantityFeedback(index, 'error', 'Gagal validasi kuota');
                   }
               });
           }

           function showEditQuantityFeedback(index, type, message) {
               const $feedback = $(`.quantity-feedback[data-index="${index}"]`);
               $feedback.show().find('.feedback-text')
                   .removeClass('success warning error')
                   .addClass(type)
                   .text(message);
           }

           function hideEditQuotaIndicator(index) {
               $(`.quota-indicator[data-index="${index}"]`).hide();
               $(`.quota-limit[data-index="${index}"]`).hide();
               $(`.quantity-feedback[data-index="${index}"]`).hide();
           }

           function updateEditQuotaValidationSummary() {
               const hasErrors = $('.livestock-quantity.error').length > 0;
               const hasSuccess = $('.livestock-quantity.success').length > 0;

               if (hasSuccess || hasErrors) {
                   $('#editQuotaValidationSummary').show();
                   $('.quota-usage').show();

                   if (hasErrors) {
                       $('#editQuotaStatus').html('<i class="fas fa-exclamation-triangle text-warning"></i> Ada Masalah');
                   } else {
                       $('#editQuotaStatus').html('<i class="fas fa-check-circle text-success"></i> Dalam Batas');
                   }
               } else {
                   $('#editQuotaValidationSummary').hide();
                   $('.quota-usage').hide();
               }
           }

           function refreshAllEditQuotaValidations() {
               $('.livestock-type').each(function() {
                   const index = $(this).data('index');
                   const selectedType = $(this).val();
                   if (selectedType) {
                       validateEditQuotaForType(selectedType, index);
                   }
               });
           }

           // ===============================================
           // ENHANCED FORM SUBMISSION
           // ===============================================

           function submitEditApproval(action) {
               // Enhanced validation for edit mode
               if (action === 'Approve') {
                   let hasValidationErrors = false;

                   // Validate required fields for approval
                   $('.form-label.required').each(function() {
                       const input = $(this).next('input, textarea, select');
                       if (!input.val() || input.val().trim() === '') {
                           input.addClass('is-invalid');
                           hasValidationErrors = true;
                       } else {
                           input.removeClass('is-invalid');
                       }
                   });

                   // Validate quota errors
                   const hasQuotaErrors = $('.livestock-quantity.error').length > 0;
                   if (hasQuotaErrors) {
                       alert('Masih ada masalah dengan kuota ternak. Silakan periksa kembali jumlah yang diminta.');
                       return;
                   }

                   // Validate livestock details
                   const validLivestock = $('.livestock-item.editable:visible').filter(function() {
                       const type = $(this).find('.livestock-type').val();
                       const quantity = parseInt($(this).find('.livestock-quantity').val()) || 0;
                       return type && quantity > 0;
                   }).length;

                   if (validLivestock === 0) {
                       alert('Minimal harus ada satu detail ternak yang valid');
                       return;
                   }

                   if (hasValidationErrors) {
                       alert('Mohon lengkapi semua field yang wajib diisi sebelum menyetujui');
                       return;
                   }
               }

               // Confirm if there are changes
               if (hasChanges && action === 'Approve') {
                   if (!confirm('Anda telah melakukan perubahan data. Apakah yakin ingin menyimpan perubahan dan menyetujui permohonan?')) {
                       return;
                   }
               } else if (action === 'Reject') {
                   const comments = $('#Comments').val().trim();
                   if (!comments) {
                       alert('Komentar wajib diisi untuk penolakan permohonan');
                       $('#Comments').focus();
                       return;
                   }

                   if (!confirm('Apakah yakin ingin menolak permohonan ini?')) {
                       return;
                   }
               }

               // Set action and submit
               $('#actionInput').val(action);

               // Show loading
               if (action === 'Approve') {
                   $('#approveBtn').html('<i class="fas fa-spinner fa-spin"></i> Memproses...');
                   $('#approveBtn').prop('disabled', true);
               } else {
                   $('#rejectBtn').html('<i class="fas fa-spinner fa-spin"></i> Memproses...');
                   $('#rejectBtn').prop('disabled', true);
               }

               $('#editApprovalForm').submit();
           }

           // ===============================================
           // UTILITY FUNCTIONS
           // ===============================================

           function showNotification(type, message) {
               console.log(`${type.toUpperCase()}: ${message}`);

               const alertClass = type === 'error' ? 'danger' : type === 'success' ? 'success' : 'warning';
               const notification = $(`
                   <div class="alert alert-${alertClass} alert-dismissible fade show position-fixed" style="top: 20px; right: 20px; z-index: 9999; max-width: 350px;">
                       <i class="fas fa-${type === 'error' ? 'exclamation-circle' : type === 'success' ? 'check-circle' : 'info-circle'}"></i>
                       ${message}
                       <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                   </div>
               `);

               $('body').append(notification);

               setTimeout(() => {
                   notification.alert('close');
               }, 4000);
           }

           // Override the existing functions if they exist
           window.submitEditApproval = submitEditApproval;

           // Initialize edit mode summary
           updateEditSummary();
    </script>
}

            function loadEditPortsByProvinceWithInitialValue(provinceCode, targetSelect, initialPortName) {
                const $target = $(targetSelect);
                const isOrigin = targetSelect.includes('Departure');
                const loadingVar = isOrigin ? 'isLoadingEditOriginPorts' : 'isLoadingEditDestinationPorts';
                const placeholderText = isOrigin ? 'Pilih pelabuhan keberangkatan' : 'Pilih pelabuhan tujuan';

                console.log('Loading edit ports with initial value for province:', provinceCode, 'target:', targetSelect, 'initial port:', initialPortName);

                if (!provinceCode || provinceCode === '') {
                    console.log('No province code provided, skipping port load');
                    return;
                }

                if (window[loadingVar]) {
                    console.log('Already loading edit ports for', targetSelect);
                    return;
                }

                window[loadingVar] = true;

                // Reset and show loading
                $target.empty()
                    .append(`<option value="">⏳ Memuat pelabuhan...</option>`)
                    .prop('disabled', true);

                if (!provinceCode) {
                    $target.empty()
                        .append(`<option value="">${placeholderText}</option>`)
                        .prop('disabled', true);
                    window[loadingVar] = false;
                    return;
                }

                $.get('/Port/GetByProvince', { provinceCode: provinceCode })
                    .done(function(response) {
                        console.log('Edit ports response for', provinceCode, ':', response);

                        // Handle response structure from existing controller
                        const ports = response.results || [];

                        $target.empty().append(`<option value="">${placeholderText}</option>`);

                        if (Array.isArray(ports) && ports.length > 0) {
                            ports.forEach(port => {
                                // Use port.name for value and port.text for display
                                $target.append(`<option value="${port.name}">${port.text}</option>`);
                            });
                            $target.prop('disabled', false);
                            console.log(`✅ ${ports.length} edit ports loaded for ${targetSelect}`);

                            // Set initial port value if provided
                            if (initialPortName && initialPortName !== '') {
                                console.log('Setting initial port to:', initialPortName);
                                console.log('Available port options:', $target.find('option').map(function() { return $(this).val() + ':' + $(this).text(); }).get());
                                
                                // Try to find exact match first
                                const exactMatch = $target.find(`option[value="${initialPortName}"]`);
                                if (exactMatch.length > 0) {
                                    console.log('Found exact match for port:', initialPortName);
                                    $target.val(initialPortName);
                                    $target.trigger('change.select2');
                                    
                                    // Debug: Check if value was set correctly
                                    setTimeout(() => {
                                        console.log('Port value after set:', $target.val());
                                        console.log('Port Select2 data:', $target.select2('data'));
                                        console.log('Port options available:', $target.find('option').length);
                                        console.log('Port option with value', initialPortName, 'exists:', $target.find(`option[value="${initialPortName}"]`).length > 0);
                                    }, 200);
                                } else {
                                    // Try to find by text content (case insensitive)
                                    let found = false;
                                    $target.find('option').each(function() {
                                        const optionText = $(this).text().toLowerCase();
                                        const searchText = initialPortName.toLowerCase();
                                        if (optionText.includes(searchText) || searchText.includes(optionText)) {
                                            console.log('Found text match for port:', initialPortName, '->', $(this).text());
                                            $target.val($(this).val());
                                            $target.trigger('change.select2');
                                            
                                            // Debug: Check if value was set correctly
                                            setTimeout(() => {
                                                console.log('Port value after text match set:', $target.val());
                                                console.log('Port Select2 data:', $target.select2('data'));
                                                console.log('Port options available:', $target.find('option').length);
                                                console.log('Port option with value', $(this).val(), 'exists:', $target.find(`option[value="${$(this).val()}"]`).length > 0);
                                            }, 200);
                                            
                                            found = true;
                                            return false; // break the loop
                                        }
                                    });
                                    
                                    if (!found) {
                                        console.log('No match found for port:', initialPortName);
                                        console.log('Available ports:', $target.find('option').map(function() { return $(this).text(); }).get());
                                    }
                                }
                            } else {
                                console.log('No initial port name provided');
                            }

                            $target.trigger('change');
                        } else {
                            $target.append('<option value="">❌ Tidak ada pelabuhan tersedia</option>');
                            $target.prop('disabled', true);
                        }
                    })
                    .fail(function(xhr, status, error) {
                        console.error('Failed to load edit ports:', error);
                        $target.empty()
                            .append('<option value="">❌ Gagal memuat pelabuhan</option>')
                            .prop('disabled', true);
                    })
                    .always(function() {
                        window[loadingVar] = false;
                    });
            }


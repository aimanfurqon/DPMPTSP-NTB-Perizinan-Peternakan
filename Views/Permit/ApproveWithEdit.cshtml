@* File: Views/Permit/ApproveWithEdit.cshtml *@
@model PerizinanPeternakan.ViewModels.PermitApprovalViewModel
@{
    ViewData["Title"] = "Edit & Review Permohonan";
    var userRole = Context.Session.GetString("Role");
}

<div class="approval-container edit-mode">
    <div class="approval-header">
        <div class="header-content">
            <h1 class="approval-title">
                <i class="fas fa-edit"></i>
                Edit & Review Permohonan
            </h1>
            <p class="approval-subtitle">Koreksi data dan proses permohonan izin pengeluaran ternak</p>
        </div>

        <div class="header-actions">
            <a href="@Url.Action("Approve", "Permit", new { id = Model.Id })" class="btn btn-outline-secondary">
                <i class="fas fa-eye"></i>
                Mode Lihat
            </a>
            <a href="@Url.Action("Index", "Permit")" class="btn btn-outline-primary">
                <i class="fas fa-arrow-left"></i>
                Kembali
            </a>
        </div>
    </div>

    <div class="edit-notice">
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i>
            <strong>Mode Edit Admin:</strong> Anda dapat mengoreksi data yang salah sebelum memberikan persetujuan.
            Semua perubahan akan dicatat dalam riwayat approval.
        </div>
    </div>

    <!-- Form Edit -->
    <form asp-action="ApproveWithEdits" method="post" class="edit-approval-form" id="editApprovalForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ApplicationNumber" />
        <input type="hidden" asp-for="IsEditingData" value="true" />

        <div class="approval-content">
            <!-- Section 1: Informasi Dasar -->
            <div class="edit-section">
                <div class="section-header">
                    <h3>
                        <i class="fas fa-building"></i>
                        Informasi Perusahaan
                        <span class="edit-badge">Dapat Diedit</span>
                    </h3>
                </div>

                <div class="edit-grid">
                    <div class="edit-item">
                        <label asp-for="EditableCompanyName" class="form-label required">
                            <i class="fas fa-building"></i>
                            Nama Perusahaan
                        </label>
                        <input asp-for="EditableCompanyName" class="form-control editable-field"
                               data-original="@Model.CompanyName"
                               data-field="CompanyName" />
                        <span asp-validation-for="EditableCompanyName" class="text-danger"></span>
                        <small class="form-text text-muted">
                            Original: <span class="original-value">@Model.CompanyName</span>
                        </small>
                    </div>

                    <div class="edit-item">
                        <label asp-for="EditableCompanyAddress" class="form-label">
                            <i class="fas fa-map-marker-alt"></i>
                            Alamat Perusahaan
                        </label>
                        <textarea asp-for="EditableCompanyAddress" class="form-control editable-field"
                                  rows="3"
                                  data-original="@Model.EditableCompanyAddress"
                                  data-field="CompanyAddress"></textarea>
                        <span asp-validation-for="EditableCompanyAddress" class="text-danger"></span>
                    </div>
                </div>
            </div>

            @* File: Views/Permit/ApproveWithEdit.cshtml *@
            @* Add these sections after the existing shipping section *@

            <!-- Section 2: Detail Pengiriman dengan Dropdown Enhanced -->
            <div class="edit-section">
                <div class="section-header">
                    <h3>
                        <i class="fas fa-shipping-fast"></i>
                        Detail Pengiriman
                        <span class="edit-badge">Dapat Diedit</span>
                    </h3>
                </div>

                <div class="shipping-edit-container">
                    <!-- Origin Section -->
                    <div class="location-edit-group">
                        <h5><i class="fas fa-map-marker-alt text-success"></i> Asal Ternak</h5>
                        
                        <div class="location-edit-grid">
                            <div class="edit-item">
                                <label class="form-label required">Provinsi Asal</label>
                                <select id="editOriginProvinceSelect" class="form-control editable-location"
                                        data-field="OriginProvince">
                                    <option value="">Pilih Provinsi</option>
                                </select>
                                <input asp-for="EditableOriginProvinceId" type="hidden" />
                            </div>

                            <div class="edit-item">
                                <label class="form-label required">Kabupaten/Kota Asal</label>
                                <select id="editOriginRegencySelect" class="form-control editable-location"
                                        data-field="OriginRegency" disabled>
                                    <option value="">Pilih Kabupaten/Kota</option>
                                </select>
                                <input asp-for="EditableOriginRegencyId" type="hidden" />
                                <input asp-for="EditableOriginLocation" type="hidden" />
                            </div>

                            <div class="edit-item">
                                <label class="form-label required">Pelabuhan Keberangkatan</label>
                                <select id="editDeparturePortSelect" class="form-control editable-location"
                                        data-field="DeparturePort" disabled>
                                    <option value="">Pilih pelabuhan keberangkatan</option>
                                </select>
                                <input asp-for="EditableDeparturePort" type="hidden" />
                            </div>
                        </div>
                    </div>

                    <!-- Destination Section -->
                    <div class="location-edit-group">
                        <h5><i class="fas fa-map-marker-alt text-danger"></i> Tujuan Pengiriman</h5>
                        
                        <div class="location-edit-grid">
                            <div class="edit-item">
                                <label class="form-label required">Provinsi Tujuan</label>
                                <select id="editDestinationProvinceSelect" class="form-control editable-location"
                                        data-field="DestinationProvince">
                                    <option value="">Pilih Provinsi</option>
                                </select>
                                <input asp-for="EditableDestinationProvinceId" type="hidden" />
                            </div>

                            <div class="edit-item">
                                <label class="form-label required">Kabupaten/Kota Tujuan</label>
                                <select id="editDestinationRegencySelect" class="form-control editable-location"
                                        data-field="DestinationRegency" disabled>
                                    <option value="">Pilih Kabupaten/Kota</option>
                                </select>
                                <input asp-for="EditableDestinationRegencyId" type="hidden" />
                                <input asp-for="EditableDestinationLocation" type="hidden" />
                            </div>

                            <div class="edit-item">
                                <label class="form-label required">Pelabuhan Tujuan</label>
                                <select id="editArrivalPortSelect" class="form-control editable-location"
                                        data-field="ArrivalPort" disabled>
                                    <option value="">Pilih pelabuhan tujuan</option>
                                </select>
                                <input asp-for="EditableArrivalPort" type="hidden" />
                            </div>
                        </div>
                    </div>

                    <!-- Route Summary -->
                    <div class="shipping-summary" id="editShippingSummary" style="display: none;">
                        <div class="summary-card">
                            <div class="summary-header">
                                <i class="fas fa-route"></i>
                                <span>Ringkasan Rute Pengiriman (Setelah Edit)</span>
                            </div>
                            <div class="summary-content">
                                <div class="route-info">
                                    <div class="route-point origin">
                                        <div class="point-icon">
                                            <i class="fas fa-circle text-success"></i>
                                        </div>
                                        <div class="point-details">
                                            <div class="point-label">Asal</div>
                                            <div class="point-location" id="editSummaryOrigin">-</div>
                                            <div class="point-port" id="editSummaryDeparturePort">-</div>
                                        </div>
                                    </div>
                                    <div class="route-arrow">
                                        <i class="fas fa-arrow-right"></i>
                                    </div>
                                    <div class="route-point destination">
                                        <div class="point-icon">
                                            <i class="fas fa-circle text-danger"></i>
                                        </div>
                                        <div class="point-details">
                                            <div class="point-label">Tujuan</div>
                                            <div class="point-location" id="editSummaryDestination">-</div>
                                            <div class="point-port" id="editSummaryArrivalPort">-</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section 3: Detail Ternak (Editable) -->
            <div class="edit-section">
                <div class="section-header">
                    <h3>
                        <i class="fas fa-paw"></i>
                        Detail Ternak
                        <span class="edit-badge">Dapat Diedit</span>
                    </h3>
                </div>

                <div class="livestock-edit-container">
                    <!-- Quota Information Panel -->
                    <div class="quota-info-panel" id="editQuotaInfoPanel" style="display: none;">
                        <div class="panel-header">
                            <i class="fas fa-chart-pie"></i>
                            <span>Informasi Kuota Ternak 2025</span>
                            <button type="button" class="btn btn-sm btn-outline-primary" id="editRefreshQuotaBtn">
                                <i class="fas fa-sync-alt"></i> Refresh
                            </button>
                        </div>
                        <div class="panel-content" id="editQuotaInfoContent">
                            <!-- Quota info will be loaded here -->
                        </div>
                    </div>



                    <!-- Livestock Items Container -->
                    <div class="livestock-container" id="editLivestockContainer">
                        @for (int i = 0; i < Math.Max(Model.EditableLivestockDetails?.Count ?? 0, 1); i++)
                        {
                            var livestock = Model.EditableLivestockDetails?.ElementAtOrDefault(i) ?? new EditableLivestockDetailViewModel { Index = i };
                            <div class="livestock-item editable" data-index="@i">
                                <div class="livestock-header">
                                    <h4>Ternak #<span class="livestock-number">@(i + 1)</span></h4>
                                    @if (!livestock.IsNewEntry)
                                    {
                                        <span class="badge bg-info">
                                            <i class="fas fa-database"></i>
                                            Data Existing
                                        </span>
                                    }
                                    @if (i > 0)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-danger remove-livestock"
                                                title="Hapus item ini">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    }
                                </div>

                                <div class="livestock-form">
                                    <!-- Hidden fields -->
                                    <input type="hidden" name="EditableLivestockDetails[@i].Id" value="@livestock.Id" />
                                    <input type="hidden" name="EditableLivestockDetails[@i].Index" value="@i" />
                                    <input type="hidden" name="EditableLivestockDetails[@i].IsMarkedForDeletion" value="false" />
                                    <input type="hidden" name="EditableLivestockDetails[@i].IsNewEntry" value="@livestock.IsNewEntry.ToString().ToLower()" />

                                    <div class="form-group">
                                        <label class="form-label required">
                                            <i class="fas fa-paw"></i>
                                            Jenis Ternak
                                            <span class="quota-indicator" data-index="@i" style="display: none;">
                                                <i class="fas fa-info-circle text-primary"></i>
                                                <span class="quota-text">Loading...</span>
                                            </span>
                                        </label>
                                        <select name="EditableLivestockDetails[@i].LivestockType"
                                                class="form-control livestock-type editable-field"
                                                data-index="@i"
                                                data-original="@livestock.LivestockType"
                                                required>
                                            <option value="">Pilih Jenis Ternak</option>
                                            @if (livestock.LivestockType == "Sapi Potong")
                                            {
                                                <option value="Sapi Potong" selected>Sapi Potong</option>
                                            }
                                            else
                                            {
                                                <option value="Sapi Potong">Sapi Potong</option>
                                            }
                                            @if (livestock.LivestockType == "Kerbau Potong")
                                            {
                                                <option value="Kerbau Potong" selected>Kerbau Potong</option>
                                            }
                                            else
                                            {
                                                <option value="Kerbau Potong">Kerbau Potong</option>
                                            }
                                            @if (livestock.LivestockType == "Kuda Pedaging")
                                            {
                                                <option value="Kuda Pedaging" selected>Kuda Pedaging</option>
                                            }
                                            else
                                            {
                                                <option value="Kuda Pedaging">Kuda Pedaging</option>
                                            }
                                            @if (livestock.LivestockType == "Kambing")
                                            {
                                                <option value="Kambing" selected>Kambing</option>
                                            }
                                            else
                                            {
                                                <option value="Kambing">Kambing</option>
                                            }
                                            @if (livestock.LivestockType == "Domba")
                                            {
                                                <option value="Domba" selected>Domba</option>
                                            }
                                            else
                                            {
                                                <option value="Domba">Domba</option>
                                            }
                                        </select>
                                        @if (!string.IsNullOrEmpty(livestock.LivestockType))
                                        {
                                            <small class="form-text text-muted">
                                                <i class="fas fa-info-circle"></i>
                                                Data existing: <span class="original-value">@livestock.LivestockType</span>
                                            </small>
                                        }
                                    </div>

                                    <div class="form-group">
                                        <label class="form-label required">
                                            <i class="fas fa-calculator"></i>
                                            Jumlah (ekor)
                                            <span class="quota-limit" data-index="@i" style="display: none;">
                                                <small class="text-muted">Maks: <span class="max-quota">-</span> ekor</small>
                                            </span>
                                        </label>
                                        <input type="number"
                                               name="EditableLivestockDetails[@i].Quantity"
                                               class="form-control livestock-quantity editable-field"
                                               data-index="@i"
                                               data-original="@livestock.Quantity"
                                               min="1"
                                               value="@livestock.Quantity"
                                               placeholder="Masukkan jumlah ternak"
                                               required />
                                        @if (livestock.Quantity > 0)
                                        {
                                            <small class="form-text text-muted">
                                                <i class="fas fa-info-circle"></i>
                                                Data existing: <span class="original-value">@livestock.Quantity ekor</span>
                                            </small>
                                        }
                                        <div class="quantity-feedback" data-index="@i" style="display: none;">
                                            <small class="feedback-text">-</small>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="form-label">
                                            <i class="fas fa-comment"></i>
                                            Keterangan
                                        </label>
                                        <textarea name="EditableLivestockDetails[@i].Description"
                                              class="form-control editable-field"
                                              rows="2"
                                              data-original="@livestock.Description"
                                              placeholder="Keterangan tambahan (opsional)">@livestock.Description</textarea>
                                        @if (!string.IsNullOrEmpty(livestock.Description))
                                        {
                                            <small class="form-text text-muted">
                                                <i class="fas fa-info-circle"></i>
                                                Data existing: <span class="original-value">@livestock.Description</span>
                                            </small>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Livestock Actions -->
                    <div class="livestock-actions">
                        <button type="button" class="btn btn-outline-primary" id="editAddLivestock">
                            <i class="fas fa-plus"></i>
                            Tambah Jenis Ternak
                        </button>

                        <div class="livestock-summary">
                            <div class="summary-item">
                                <span class="label">Total Jenis</span>
                                <span class="value" id="editTotalTypes">@(Model.EditableLivestockDetails?.Count ?? 1)</span>
                            </div>
                            <div class="summary-item">
                                <span class="label">Total Ekor</span>
                                <span class="value" id="editTotalQuantity">@(Model.EditableLivestockDetails?.Sum(l => l.Quantity) ?? 0)</span>
                            </div>
                            <div class="summary-item quota-usage" style="display: none;">
                                <span class="label">Status Kuota</span>
                                <span class="value" id="editQuotaStatus">
                                    <i class="fas fa-check-circle text-success"></i>
                                    Dalam Batas
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- Quota Validation Summary -->
                    <div class="quota-validation-summary" id="editQuotaValidationSummary" style="display: none;">
                        <div class="validation-header">
                            <i class="fas fa-shield-alt"></i>
                            <span>Validasi Kuota</span>
                        </div>
                        <div class="validation-content" id="editValidationContent">
                            <!-- Validation results will be shown here -->
                        </div>
                    </div>
                </div>
            </div>
            <!-- Section 4: Dokumen Pendukung (Read-only) -->
            <div class="review-section">
                <div class="section-header">
                    <h3>
                        <i class="fas fa-file-alt"></i>
                        Dokumen Pendukung
                        <span class="readonly-badge">Tidak Dapat Diedit</span>
                    </h3>
                    <span class="document-count">@Model.Documents.Count dokumen</span>
                </div>

                <div class="documents-summary">
                    @foreach (var doc in Model.Documents.Take(5))
                    {
                        <div class="document-item">
                            <i class="fas fa-file-@(doc.FileExtension == ".pdf" ? "pdf text-danger" : "image text-primary")"></i>
                            <span>@doc.DocumentName</span>
                        </div>
                    }
                    @if (Model.Documents.Count > 5)
                    {
                        <div class="document-item">
                            <i class="fas fa-ellipsis-h"></i>
                            <span>... dan @(Model.Documents.Count - 5) dokumen lainnya</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Section 5: Form Approval dengan Edit -->
            <div class="approval-form-section">
                <div class="section-header">
                    <h3>
                        <i class="fas fa-clipboard-check"></i>
                        Review & Persetujuan
                    </h3>
                </div>

                <div class="form-group">
                    <label asp-for="Comments" class="form-label">
                        <i class="fas fa-comment"></i>
                        Komentar Admin
                    </label>
                    <textarea asp-for="Comments" class="form-control" rows="4"
                              placeholder="Berikan komentar hasil review dan perubahan yang dilakukan..."></textarea>
                    <span asp-validation-for="Comments" class="text-danger"></span>
                    <small class="form-text text-muted">
                        Komentar akan otomatis mencatat perubahan data yang Anda lakukan
                    </small>
                </div>

                <div class="action-buttons">
                    <div class="button-group">
                        <button type="button"
                                class="btn btn-success btn-lg"
                                onclick="submitEditApproval('Approve')"
                                id="approveBtn">
                            <i class="fas fa-check"></i>
                            Simpan Perubahan & Setujui
                        </button>

                        <button type="button"
                                class="btn btn-danger btn-lg"
                                onclick="submitEditApproval('Reject')"
                                id="rejectBtn">
                            <i class="fas fa-times"></i>
                            Tolak Permohonan
                        </button>
                    </div>

                    <div class="action-info">
                        <div class="info-item approve-info">
                            <i class="fas fa-info-circle"></i>
                            <span>Perubahan data akan disimpan dan dicatat dalam riwayat approval</span>
                        </div>
                    </div>
                </div>

                <input type="hidden" name="Action" id="actionInput" />
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="~/css/permit/edit-approve.css" />
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    

    <script>
                let hasChanges = false;
                let originalValues = {};

                $(document).ready(function() {
                    // Store original values
                    $('.editable-field').each(function() {
                        const field = $(this).data('field');
                        const original = $(this).data('original');
                        originalValues[field] = original;
                    });

                    // Track changes
                    $('.editable-field').on('input', function() {
                        trackChanges();
                    });

                    // Auto-resize textareas
                    $('textarea.editable-field').on('input', function() {
                        this.style.height = 'auto';
                        this.style.height = (this.scrollHeight) + 'px';
                    });
                });

                function trackChanges() {
                    const changes = [];
                    hasChanges = false;

                    $('.editable-field').each(function() {
                        const field = $(this).data('field');
                        const original = originalValues[field] || '';
                        const current = $(this).val() || '';

                        if (original !== current) {
                            hasChanges = true;
                            changes.push({
                                field: field,
                                original: original,
                                current: current,
                                label: $(this).prev('label').text().replace('*', '').trim()
                            });

                            // Add visual indicator
                            $(this).addClass('field-changed');
                        } else {
                            $(this).removeClass('field-changed');
                        }
                    });

                    // Update change tracker
                    if (changes.length > 0) {
                        $('#changeTracker').show();
                        const changesList = $('#changesList');
                        changesList.empty();

                        changes.forEach(change => {
                            changesList.append(`
                                <li>
                                    <strong>${change.label}:</strong>
                                    '<span class="text-muted">${change.original}</span>'
                                    → '<span class="text-success">${change.current}</span>'
                                </li>
                            `);
                        });
                    } else{
                        $('#changeTracker').hide();
                    }
                }

                function submitEditApproval(action) {
                    // Validate required fields for approval
                    if (action === 'Approve') {
                        let hasValidationErrors = false;

                        $('.form-label.required').each(function() {
                            const input = $(this).next('input, textarea');
                            if (!input.val().trim()) {
                                input.addClass('is-invalid');
                                hasValidationErrors = true;
                            } else {
                                input.removeClass('is-invalid');
                            }
                        });

                        if (hasValidationErrors) {
                            alert('Mohon lengkapi semua field yang wajib diisi sebelum menyetujui');
                            return;
                        }
                    }
        // Confirm if there are changes
                   if (hasChanges && action === 'Approve') {
                       if (!confirm('Anda telah melakukan perubahan data. Apakah yakin ingin menyimpan perubahan dan menyetujui permohonan?')) {
                           return;
                       }
                   } else if (action === 'Reject') {
                       const comments = $('#Comments').val().trim();
                       if (!comments) {
                           alert('Komentar wajib diisi untuk penolakan permohonan');
                           $('#Comments').focus();
                           return;
                       }

                       if (!confirm('Apakah yakin ingin menolak permohonan ini?')) {
                           return;
                       }
                   }

                   // Set action and submit
                   $('#actionInput').val(action);

                   // Show loading
                   if (action === 'Approve') {
                       $('#approveBtn').html('<i class="fas fa-spinner fa-spin"></i> Memproses...');
                       $('#approveBtn').prop('disabled', true);
                   } else {
                       $('#rejectBtn').html('<i class="fas fa-spinner fa-spin"></i> Memproses...');
                       $('#rejectBtn').prop('disabled', true);
                   }

                   $('#editApprovalForm').submit();
               }

               window.addEventListener('beforeunload', function(e) {
                   if (hasChanges) {
                       e.preventDefault();
                       e.returnValue = 'Anda memiliki perubahan yang belum disimpan. Yakin ingin meninggalkan halaman?';
                   }
               });

               // Real-time validation
               $('.editable-field').on('blur', function() {
                   validateField($(this));
               });

               function validateField($field) {
                   const value = $field.val().trim();
                   const fieldName = $field.data('field');

                   // Remove previous validation
                   $field.removeClass('is-invalid is-valid');
                   $field.siblings('.invalid-feedback').remove();

                   // Basic validation
                   if ($field.prev('label').hasClass('required') && !value) {
                       $field.addClass('is-invalid');
                       $field.after('<div class="invalid-feedback">Field ini wajib diisi</div>');
                       return false;
                   }

                   // Specific validations
                   if (fieldName === 'CompanyName' && value && value.length < 3) {
                       $field.addClass('is-invalid');
                       $field.after('<div class="invalid-feedback">Nama perusahaan minimal 3 karakter</div>');
                       return false;
                   }

                   if (value) {
                       $field.addClass('is-valid');
                   }

                   return true;
               }
    </script>
    <script>
            // ===============================================
            // ENHANCED JAVASCRIPT FOR EDIT MODE
            // ===============================================

            let editLivestockIndex = @(Model.EditableLivestockDetails?.Count ?? 1);
            let editQuotaCache = {};
            let editOriginProvinceCode = '';
            let isLoadingEditOriginPorts = false;
            let isLoadingEditDestinationPorts = false;

            $(document).ready(function() {
                console.log('Document ready - initializing edit mode...');
                
                // Initialize edit mode functionality
                initializeEditModeComponents();
                setupEditLocationHandlers();
                setupEditLivestockHandlers();
                
                // Load provinces and set initial values immediately
                setTimeout(function() {

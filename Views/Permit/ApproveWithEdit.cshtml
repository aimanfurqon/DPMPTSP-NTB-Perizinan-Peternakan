            function updateEditLocation() {
                const originProvinceName = $('#editOriginProvinceSelect option:selected').text();
                const originRegencyName = $('#editOriginRegencySelect option:selected').text();
                const destProvinceName = $('#editDestinationProvinceSelect option:selected').text();
                const destRegencyName = $('#editDestinationRegencySelect option:selected').text();

                if ($('#editOriginProvinceSelect').val() && $('#editOriginRegencySelect').val() &&
                    originProvinceName !== "Pilih Provinsi" && originRegencyName !== "Pilih Kabupaten/Kota") {
                    const originLocation = `${originRegencyName}, ${originProvinceName}`;
                    $('#EditableOriginLocation').val(originLocation);
                } else {
                    $('#EditableOriginLocation').val('');
                }

                if ($('#editDestinationProvinceSelect').val() && $('#editDestinationRegencySelect').val() &&
                    destProvinceName !== "Pilih Provinsi" && destRegencyName !== "Pilih Kabupaten/Kota") {
                    const destLocation = `${destRegencyName}, ${destProvinceName}`;
                    $('#EditableDestinationLocation').val(destLocation);
                } else {
                    $('#EditableDestinationLocation').val('');
                }

                updateEditShippingSummary();
                trackChanges(); // Update change tracking
            }


@model PerizinanPeternakan.ViewModels.PermitApprovalViewModel
@{
    ViewData["Title"] = "Proses Permohonan";
    var userRole = Context.Session.GetString("Role");
    var actionTitle = userRole == "Verifikator" ? "Verifikasi" : userRole == "Admin" ? "Review Data" : "Persetujuan Kepala Dinas";
}

<div class="approval-container">
    <div class="approval-header">
        <div class="header-content">
            <h1 class="approval-title">
                <i class="fas fa-gavel"></i>
                @actionTitle Permohonan
            </h1>
            <p class="approval-subtitle">Review dan proses permohonan izin pengeluaran ternak</p>
        </div>

        <div class="header-actions">
            <a href="@Url.Action("Index", "Permit")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i>
                Kembali
            </a>

            @if (userRole == "Admin")
    {
        <a href="@Url.Action("EnableEditMode", "Permit", new { id = Model.Id })" class="btn btn-warning">
            <i class="fas fa-edit"></i>
            Edit Data
        </a>
        <button type="button" class="btn btn-info" onclick="previewPdfAsAdmin(@Model.Id)">
            <i class="fas fa-file-pdf"></i>
            Preview PDF
        </button>
    }

            @if (userRole == "Verifikator" || userRole == "KepalaDinas")
            {
                <a href="@Url.Action("ViewDocument", "Permit", new { id = Model.Id })" class="btn btn-info">
                    <i class="fas fa-eye"></i>
                    Lihat Dokumen PDF
                </a>
            }
        </div>
    </div>

    <div class="approval-content">
        <!-- Informasi Permohonan -->
        <div class="review-section">
            <div class="section-header">
                <h3>
                    <i class="fas fa-info-circle"></i>
                    Informasi Permohonan
                </h3>
                <span class="status-badge badge-@PermitStatusHelper.GetStatusClass(Model.CurrentStatus)">
                    @PermitStatusHelper.GetStatusText(Model.CurrentStatus)
                </span>
            </div>

            <div class="review-grid">
                <div class="review-item">
                    <label>Nomor Permohonan</label>
                    <span class="value highlight">@Model.ApplicationNumber</span>
                </div>
                <div class="review-item">
                    <label>Tanggal Pengajuan</label>
                    <span class="value">@Model.SubmissionDate.ToString("dd MMMM yyyy")</span>
                </div>
                <div class="review-item">
                    <label>Nama Perusahaan</label>
                    <span class="value">@Model.CompanyName</span>
                </div>
                <div class="review-item">
                    <label>Pemohon</label>
                    <span class="value">@Model.ApplicantName</span>
                </div>
            </div>
        </div>

        <!-- Detail Pengiriman -->
        <div class="review-section">
            <div class="section-header">
                <h3>
                    <i class="fas fa-shipping-fast"></i>
                    Detail Pengiriman
                </h3>
            </div>

            <div class="shipping-route">
                <div class="route-item">
                    <div class="route-icon origin">
                        <i class="fas fa-map-marker-alt"></i>
                    </div>
                    <div class="route-content">
                        <h4>Asal Ternak</h4>
                        <p>@Model.OriginLocation</p>
                    </div>
                </div>

                <div class="route-arrow">
                    <i class="fas fa-arrow-right"></i>
                </div>

                <div class="route-item">
                    <div class="route-icon destination">
                        <i class="fas fa-map-marker-alt"></i>
                    </div>
                    <div class="route-content">
                        <h4>Tujuan Pengiriman</h4>
                        <p>@Model.DestinationLocation</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Detail Ternak -->
        <div class="review-section">
            <div class="section-header">
                <h3>
                    <i class="fas fa-paw"></i>
                    Detail Ternak
                </h3>
            </div>

            <div class="livestock-review">
                <table class="livestock-table">
                    <thead>
                        <tr>
                            <th>No.</th>
                            <th>Jenis Ternak</th>
                            <th>Jumlah</th>
                            <th>Keterangan</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.LivestockDetails.Count; i++)
                        {
                            <tr>
                                <td>@(i + 1)</td>
                                <td>@Model.LivestockDetails[i].LivestockType</td>
                                <td>@Model.LivestockDetails[i].Quantity ekor</td>
                                <td>@(Model.LivestockDetails[i].Description ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="total-row">
                            <td colspan="2"><strong>Total</strong></td>
                            <td><strong>@Model.LivestockDetails.Sum(l => l.Quantity) ekor</strong></td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <!-- Dokumen Pendukung -->
        <div class="review-section">
            <div class="section-header">
                <h3>
                    <i class="fas fa-file-alt"></i>
                    Dokumen Pendukung
                </h3>

                @{
                    // ⭐ DEKLARASI DICTIONARY UNTUK DOKUMEN
                    var requiredDocs = new Dictionary<string, string>
                                {
                                { "SURAT_PERMOHONAN", "Surat Permohonan" },
                                { "REKOMENDASI_DINAS_PROV", "Rekomendasi Dinas Peternakan Provinsi NTB" },
                                { "REKOMENDASI_DAERAH_TUJUAN", "Rekomendasi Pemasukan Ternak dari Daerah Tujuan" },
                                { "SKKH_KABUPATEN_ASAL", "SKKH dari Kabupaten Asal" },
                                { "SKKH_DINAS_PROVINSI", "SKKH dari Dinas Peternakan Provinsi NTB" },
                                { "SURAT_JALAN_TERNAK", "Surat Keterangan Jalan Ternak/Rekomendasi Asal" },
                                { "HASIL_PEMERIKSAAN_FISIK", "Hasil Pemeriksaan Fisik (Holding Ground)" }
                                };

                    var optionalDocs = new Dictionary<string, string>
                                {
                                { "DOKUMEN_OPSIONAL", "Dokumen Opsional" }
                                };

                    // PENGHITUNGAN DOKUMEN
                    var requiredDocsCount = Model.Documents.Count(d => requiredDocs.ContainsKey(d.DocumentType));
                    var optionalDocsCount = Model.Documents.Count(d => optionalDocs.ContainsKey(d.DocumentType));
                    var totalDocsUploaded = requiredDocsCount + optionalDocsCount;
                }

                @if (requiredDocsCount >= 7)
                {
                    <span class="document-status complete">
                        <i class="fas fa-check-circle"></i>
                        Lengkap (@requiredDocsCount/7 wajib
                        @if (optionalDocsCount > 0)
                        {
                            <text> + @optionalDocsCount opsional</text>
                        }
                        )
                    </span>
                }
                else
                {
                    <span class="document-status incomplete">
                        <i class="fas fa-exclamation-triangle"></i>
                        Tidak Lengkap (@requiredDocsCount/7 wajib
                        @if (optionalDocsCount > 0)
                        {
                            <text> + @optionalDocsCount opsional</text>
                        }
                        )
                    </span>
                }
            </div>

            <div class="documents-review">
                @if (Model.Documents.Any())
                {
                   <!-- Section Documents-grid yang benar -->
<div class="documents-grid">
    @foreach (var doc in Model.Documents)
    {
        <div class="document-card @(optionalDocs.ContainsKey(doc.DocumentType) ? "optional-doc" : "required-doc")">
            <div class="document-header">
                <div class="document-icon">
                    @switch (doc.FileExtension.ToLower())
                    {
                        case ".pdf":
                            <i class="fas fa-file-pdf text-danger"></i>
                            break;
                        case ".jpg":
                        case ".jpeg":
                        case ".png":
                            <i class="fas fa-file-image text-primary"></i>
                            break;
                        default:
                            <i class="fas fa-file text-secondary"></i>
                            break;
                    }
                </div>
                <div class="document-info">
                    <h4>@doc.DocumentDisplayName</h4>

                    <!-- Badge Tipe Dokumen -->
                    <div class="document-badges">
                        @if (optionalDocs.ContainsKey(doc.DocumentType))
                        {
                            <span class="doc-badge optional">Opsional</span>
                        }
                        else
                        {
                            <span class="doc-badge required">Wajib</span>
                        }
                    </div>

                    <!-- Detail Dokumen -->
                    @if (!string.IsNullOrEmpty(doc.DocumentNumber) || doc.DocumentDate.HasValue)
                    {
                        <div class="document-details">
                            @if (doc.DocumentDate.HasValue)
                            {
                                <div class="detail-item">
                                    <i class="fas fa-calendar"></i>
                                    <span>@doc.DocumentDate.Value.ToString("dd/MM/yyyy")</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(doc.DocumentNumber))
                            {
                                <div class="detail-item">
                                    <i class="fas fa-hashtag"></i>
                                    <span>@doc.DocumentNumber</span>
                                </div>
                            }
                        </div>
                    }

                    <p class="document-meta">
                        <span class="file-size">@doc.FormattedFileSize</span>
                        <span class="upload-date">@doc.UploadDate.ToString("dd/MM/yyyy HH:mm")</span>
                    </p>
                </div>
            </div>

            <div class="document-actions">
                <a href="@Url.Action("DownloadDocument", "Permit", new { id = doc.Id })" 
                   class="btn btn-sm btn-outline-primary" 
                   target="_blank">
                    <i class="fas fa-download"></i>
                    Download
                </a>

                @if (doc.FileExtension.ToLower() == ".pdf")
                {
                    <button type="button"
                            class="btn btn-sm btn-outline-secondary"
                            onclick="previewDocumentById(@doc.Id, '@doc.DocumentDisplayName')">
                        <i class="fas fa-eye"></i>
                        Preview
                    </button>
                }
                else if (doc.FileExtension.ToLower() == ".jpg" || doc.FileExtension.ToLower() == ".jpeg" || doc.FileExtension.ToLower() == ".png")
                {
                    <button type="button"
                            class="btn btn-sm btn-outline-info"
                            onclick="previewImageById(@doc.Id, '@doc.DocumentDisplayName')">
                        <i class="fas fa-image"></i>
                        Preview
                    </button>
                }


            </div>
        </div>
    }
</div>

                    <!-- Document Requirements Checklist -->
                    <div class="document-checklist">
                        <h4>
                            <i class="fas fa-clipboard-check"></i>
                            Checklist Dokumen Wajib
                        </h4>
                        
                  
                        <div class="checklist-items">
                            @foreach (var requiredDoc in requiredDocs)
                            {
                                var hasDoc = Model.Documents.Any(d => d.DocumentType == requiredDoc.Key);
                                <div class="checklist-item @(hasDoc ? "completed" : "missing")">
                                    <i class="fas @(hasDoc ? "fa-check-circle" : "fa-times-circle")"></i>
                                    <span class="checklist-text">@requiredDoc.Value</span>
                                    <span class="doc-type-badge required">Wajib</span>
                                    @if (hasDoc)
                                    {
                                        var doc = Model.Documents.First(d => d.DocumentType == requiredDoc.Key);
                                        <span class="checklist-meta">(@doc.FormattedFileSize)</span>
                                    }
                                </div>
                            }

                            <!-- ⭐ DOKUMEN OPSIONAL -->
                            @foreach (var optionalDoc in optionalDocs)
                            {
                                var hasDoc = Model.Documents.Any(d => d.DocumentType == optionalDoc.Key);
                                <div class="checklist-item @(hasDoc ? "completed" : "optional")">
                                    <i class="fas @(hasDoc ? "fa-check-circle" : "fa-circle")"></i>
                                    <span class="checklist-text">@optionalDoc.Value</span>
                                    <span class="doc-type-badge optional">Opsional</span>
                                    @if (hasDoc)
                                    {
                                        var doc = Model.Documents.First(d => d.DocumentType == optionalDoc.Key);
                                        <span class="checklist-meta">(@doc.FormattedFileSize)</span>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="no-documents">
                        <i class="fas fa-folder-open"></i>
                        <h4>Tidak Ada Dokumen</h4>
                        <p>Pemohon belum mengupload dokumen pendukung</p>
                    </div>
                }
            </div>
        </div>

        <!-- Form Approval -->
        <div class="approval-form-section">
            <div class="section-header">
                <h3>
                    <i class="fas fa-clipboard-check"></i>
                    Form @actionTitle
                </h3>
            </div>

       <form asp-action="Approve" method="post" class="approval-form" id="approvalForm">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ApplicationNumber" />

       
                @if (userRole == "Admin" && requiredDocsCount < 7)
                {
                    <div class="warning-message">
                        <i class="fas fa-exclamation-triangle"></i>
                        <strong>Peringatan:</strong> Dokumen wajib belum lengkap (@requiredDocsCount/7).
                        @if (optionalDocsCount > 0)
                        {
                            <text>Terdapat @optionalDocsCount dokumen opsional. </text>
                        }
                        Permohonan tidak dapat disetujui sampai semua dokumen wajib diupload oleh pemohon.
                    </div>
                }

                <div class="form-group">
                    <label for="Comments" class="form-label">
                        <i class="fas fa-comment"></i>
                        Komentar/Catatan
                    </label>
                    <textarea asp-for="Comments" class="form-control" rows="4"
                              placeholder="Berikan komentar atau catatan untuk permohonan ini..."></textarea>
                    <span asp-validation-for="Comments" class="text-danger"></span>
                    <small class="form-text text-muted">
                        @if (userRole == "Admin")
                        {
                            <text>Berikan catatan hasil review data, dokumen pendukung, dan persyaratan administratif</text>
                        }
                        else if (userRole == "Verifikator")
                        {
                            <text>Berikan catatan hasil verifikasi dokumen PDF dan persyaratan teknis</text>
                        }
                        else
                        {
                            <text>Berikan catatan atau arahan untuk permohonan ini</text>
                        }
                    </small>
                </div>

                <div class="action-buttons">
                    <div class="button-group">
                        <button type="button"
                                class="btn btn-success btn-lg"
                                onclick="submitApproval('Approve')"
                                id="approveBtn"
                                @(userRole == "Admin" && requiredDocsCount < 7 ? "disabled" : "")>
                            <i class="fas fa-check"></i>
                            @if (userRole == "Admin")
                            {
                                <text>Setujui Review</text>
                            }
                            else if (userRole == "Verifikator")
                            {
                                <text>Setujui Verifikasi</text>
                            }
                            else
                            {
                                <text>Setujui Permohonan</text>
                            }
                        </button>

                        <button type="button" class="btn btn-danger btn-lg" onclick="submitApproval('Reject')" id="rejectBtn">
                            <i class="fas fa-times"></i>
                            Tolak Permohonan
                        </button>
                    </div>

                    <div class="action-info">
                        @if (userRole == "Admin")
                        {
                            <div class="info-item approve-info">
                                <i class="fas fa-info-circle"></i>
                                <span>Dengan menyetujui, dokumen PDF akan digenerate dan permohonan diteruskan ke Verifikator</span>
                            </div>
                        }
                        else if (userRole == "Verifikator")
                        {
                            <div class="info-item approve-info">
                                <i class="fas fa-info-circle"></i>
                                <span>Dengan menyetujui, permohonan akan diteruskan ke Kepala Dinas untuk persetujuan final</span>
                            </div>
                        }
                        else
                        {
                            <div class="info-item approve-info">
                                <i class="fas fa-info-circle"></i>
                                <span>Dengan menyetujui, dokumen izin akan final dan dapat diunduh oleh pemohon</span>
                            </div>
                        }

                        <div class="info-item reject-info">
                            <i class="fas fa-exclamation-triangle"></i>
                            <span>Dengan menolak, permohonan akan dikembalikan kepada pemohon dengan status ditolak</span>
                        </div>
                    </div>
                </div>

                <input type="hidden" name="Action" id="actionInput" />
            </form>
        </div>
    </div>
</div>

<!-- Document Preview Modal -->
<div class="modal fade" id="documentPreviewModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="previewModalTitle">
                    <i class="fas fa-file-pdf text-danger"></i>
                    Preview Dokumen
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <div class="preview-container">
                    <div class="preview-toolbar">
                        <div class="toolbar-left">
                            <span id="previewDocumentName">Memuat dokumen...</span>
                        </div>
                        <div class="toolbar-right">
                            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="downloadFromPreview()">
                                <i class="fas fa-download"></i>
                                Download
                            </button>
                        </div>
                    </div>
                    <div class="preview-frame-container">
                        <div class="loading-spinner" id="previewLoader">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p>Memuat preview dokumen...</p>
                        </div>
                        <iframe id="previewFrame" style="display: none; width: 100%; height: 600px; border: none;"></iframe>
                        <div class="preview-error" id="previewError" style="display: none;">
                            <i class="fas fa-exclamation-triangle text-warning"></i>
                            <p>Gagal memuat preview dokumen. Silakan download untuk melihat dokumen.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Image Preview Modal -->
<div class="modal fade" id="imagePreviewModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="imageModalTitle">
                    <i class="fas fa-file-image text-primary"></i>
                    Preview Gambar
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <div class="image-preview-container">
                    <div class="image-loading" id="imageLoader">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p>Memuat gambar...</p>
                    </div>
                    <img id="previewImage" src="" alt="Preview" class="img-fluid" style="display: none; max-height: 600px; border-radius: 8px;" />
                    <div class="image-error" id="imageError" style="display: none;">
                        <i class="fas fa-exclamation-triangle text-warning"></i>
                        <p>Gagal memuat gambar. Silakan download untuk melihat file.</p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Tutup</button>
                <button type="button" class="btn btn-primary" onclick="downloadFromImagePreview()">
                    <i class="fas fa-download"></i>
                    Download
                </button>
            </div>
        </div>
    </div>
</div>



<!-- Confirmation Modal -->
<div class="modal fade" id="confirmationModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Konfirmasi Aksi</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="confirmation-content">
                    <div class="confirmation-icon" id="confirmationIcon">
                        <i class="fas fa-question-circle"></i>
                    </div>
                    <div class="confirmation-text">
                        <p id="confirmationMessage">Apakah Anda yakin ingin melakukan aksi ini?</p>
                        <div class="warning-text" id="warningText" style="display: none;">
                            <i class="fas fa-exclamation-triangle"></i>
                            <span>Aksi ini tidak dapat dibatalkan setelah diproses</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                <button type="button" class="btn" id="confirmButton" onclick="confirmAction()">Konfirmasi</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="~/css/permit/approve.css" />
    <script>
        let selectedAction = '';
        let currentPreviewPath = '';
         let currentImagePath = '';

        function previewImageById(documentId, imageName) {
            const modal = new bootstrap.Modal(document.getElementById('imagePreviewModal'));

            // Reset modal state
            document.getElementById('imageModalTitle').innerHTML = `<i class="fas fa-file-image text-primary"></i> ${imageName}`;
            document.getElementById('imageLoader').style.display = 'flex';
            document.getElementById('previewImage').style.display = 'none';
            document.getElementById('imageError').style.display = 'none';

            // Load image using the preview endpoint
            const img = document.getElementById('previewImage');
            const previewUrl = `/Permit/PreviewDocument/${documentId}`;
            
            img.onload = function() {
                document.getElementById('imageLoader').style.display = 'none';
                img.style.display = 'block';
                currentImagePath = previewUrl;
            };

            img.onerror = function() {
                document.getElementById('imageLoader').style.display = 'none';
                document.getElementById('imageError').style.display = 'block';
            };

            img.src = previewUrl;
            modal.show();
        }

        function previewImage(imagePath, imageName) {
            currentImagePath = imagePath;
            const modal = new bootstrap.Modal(document.getElementById('imagePreviewModal'));

            // Reset modal state
            document.getElementById('imageModalTitle').innerHTML = `<i class="fas fa-file-image text-primary"></i> ${imageName}`;
            document.getElementById('imageLoader').style.display = 'flex';
            document.getElementById('previewImage').style.display = 'none';
            document.getElementById('imageError').style.display = 'none';

            // Load image
            const img = document.getElementById('previewImage');
            img.onload = function() {
                document.getElementById('imageLoader').style.display = 'none';
                img.style.display = 'block';
            };

            img.onerror = function() {
                document.getElementById('imageLoader').style.display = 'none';
                document.getElementById('imageError').style.display = 'block';
            };

            img.src = imagePath;
            modal.show();
        }

        function downloadFromImagePreview() {
            if (currentImagePath) {
                // If it's already a preview URL, convert it to download URL
                if (currentImagePath.includes('/PreviewDocument/')) {
                    const documentId = currentImagePath.split('/').pop().split('?')[0];
                    window.open(`/Permit/DownloadDocument/${documentId}`, '_blank');
                } else {
                    window.open(currentImagePath, '_blank');
                }
            }
        }



        function submitApproval(action) {
            selectedAction = action;

            // Validate comments for rejection
            if (action === 'Reject') {
                const comments = document.getElementById('Comments').value.trim();
                if (!comments) {
                    alert('Komentar wajib diisi untuk penolakan permohonan');
                    document.getElementById('Comments').focus();
                    return;
                }
            }

            // Check document completeness for admin approval
                 // Check document completeness for admin approval
        @if (userRole == "Admin")
        {
                @:if (action === 'Approve' && @requiredDocsCount < 7) {
                @:    alert('Dokumen wajib belum lengkap. Permohonan tidak dapat disetujui.');
                @:    return;
                @:}
        }

            // Show confirmation modal
            showConfirmationModal(action);
        }

        function showConfirmationModal(action) {
            const modal = new bootstrap.Modal(document.getElementById('confirmationModal'));
            const modalTitle = document.getElementById('modalTitle');
            const confirmationIcon = document.getElementById('confirmationIcon');
            const confirmationMessage = document.getElementById('confirmationMessage');
            const warningText = document.getElementById('warningText');
            const confirmButton = document.getElementById('confirmButton');

            if (action === 'Approve') {
                modalTitle.textContent = 'Konfirmasi Persetujuan';
                confirmationIcon.innerHTML = '<i class="fas fa-check-circle text-success"></i>';
                confirmationMessage.textContent = 'Apakah Anda yakin ingin menyetujui permohonan ini?';
                confirmButton.className = 'btn btn-success';
                confirmButton.innerHTML = '<i class="fas fa-check"></i> Ya, Setujui';
                warningText.style.display = 'none';
            } else {
                modalTitle.textContent = 'Konfirmasi Penolakan';
                confirmationIcon.innerHTML = '<i class="fas fa-times-circle text-danger"></i>';
                confirmationMessage.textContent = 'Apakah Anda yakin ingin menolak permohonan ini?';
                confirmButton.className = 'btn btn-danger';
                confirmButton.innerHTML = '<i class="fas fa-times"></i> Ya, Tolak';
                warningText.style.display = 'block';
            }

            modal.show();
        }

        function confirmAction() {
            // Set action value
            document.getElementById('actionInput').value = selectedAction;

            // Show loading state
            const approveBtn = document.getElementById('approveBtn');
            const rejectBtn = document.getElementById('rejectBtn');
            const confirmButton = document.getElementById('confirmButton');

            if (selectedAction === 'Approve') {
                approveBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Memproses...';
                approveBtn.disabled = true;
            } else {
                rejectBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Memproses...';
                rejectBtn.disabled = true;
            }

            confirmButton.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Memproses...';
            confirmButton.disabled = true;

            // Submit form
            document.getElementById('approvalForm').submit();
        }

        function previewDocumentById(documentId, documentName) {
            currentPreviewPath = `/Permit/PreviewDocument/${documentId}`;
            const modal = new bootstrap.Modal(document.getElementById('documentPreviewModal'));
            
            // Reset modal state
            document.getElementById('previewDocumentName').textContent = documentName;
            document.getElementById('previewLoader').style.display = 'flex';
            document.getElementById('previewFrame').style.display = 'none';
            document.getElementById('previewError').style.display = 'none';

            // Load document in iframe using the preview endpoint
            const iframe = document.getElementById('previewFrame');
            const previewUrl = `/Permit/PreviewDocument/${documentId}`;
            
            // Add timestamp to prevent caching issues
            const timestamp = new Date().getTime();
            const urlWithTimestamp = previewUrl + '?_t=' + timestamp;
            iframe.src = urlWithTimestamp;

            // Handle iframe load
            iframe.onload = function() {
                document.getElementById('previewLoader').style.display = 'none';
                iframe.style.display = 'block';
            };

            iframe.onerror = function() {
                document.getElementById('previewLoader').style.display = 'none';
                document.getElementById('previewError').style.display = 'flex';
            };

            // Fallback timeout
            setTimeout(() => {
                if (document.getElementById('previewLoader').style.display !== 'none') {
                    document.getElementById('previewLoader').style.display = 'none';
                    iframe.style.display = 'block';
                }
            }, 5000);

            modal.show();
        }

        function previewDocument(filePath, documentName) {
            // Extract document ID from the filePath or use a different approach
            // For now, we'll use the direct file path but with proper error handling
            currentPreviewPath = filePath;
            const modal = new bootstrap.Modal(document.getElementById('documentPreviewModal'));
            
            // Reset modal state
            document.getElementById('previewDocumentName').textContent = documentName;
            document.getElementById('previewLoader').style.display = 'flex';
            document.getElementById('previewFrame').style.display = 'none';
            document.getElementById('previewError').style.display = 'none';

            // Load document in iframe
            const iframe = document.getElementById('previewFrame');
            
            // Add timestamp to prevent caching issues
            const timestamp = new Date().getTime();
            const urlWithTimestamp = filePath + (filePath.includes('?') ? '&' : '?') + '_t=' + timestamp;
            iframe.src = urlWithTimestamp;

            // Handle iframe load
            iframe.onload = function() {
                document.getElementById('previewLoader').style.display = 'none';
                iframe.style.display = 'block';
            };

            iframe.onerror = function() {
                document.getElementById('previewLoader').style.display = 'none';
                document.getElementById('previewError').style.display = 'flex';
            };

            // Fallback timeout
            setTimeout(() => {
                if (document.getElementById('previewLoader').style.display !== 'none') {
                    document.getElementById('previewLoader').style.display = 'none';
                    iframe.style.display = 'block';
                }
            }, 5000);

            modal.show();
        }

        document.getElementById('documentPreviewModal').addEventListener('hidden.bs.modal', function() {
            const iframe = document.getElementById('previewFrame');
            iframe.src = 'about:blank';
            currentPreviewPath = '';
        });

        document.getElementById('imagePreviewModal').addEventListener('hidden.bs.modal', function() {
            document.getElementById('previewImage').src = '';
            currentImagePath = '';
        });

        function downloadFromPreview() {
            if (currentPreviewPath) {
                // If it's already a preview URL, convert it to download URL
                if (currentPreviewPath.includes('/PreviewDocument/')) {
                    const documentId = currentPreviewPath.split('/').pop().split('?')[0];
                    window.open(`/Permit/DownloadDocument/${documentId}`, '_blank');
                } else {
                    window.open(currentPreviewPath, '_blank');
                }
            }
        }

        function previewPdfAsAdmin(permitId) {
            const modal = new bootstrap.Modal(document.getElementById('documentPreviewModal'));
            
            // Reset modal state
            document.getElementById('previewModalTitle').innerHTML = '<i class="fas fa-file-pdf text-danger"></i> Preview PDF - Admin';
            document.getElementById('previewDocumentName').textContent = 'Memuat preview PDF...';
            document.getElementById('previewLoader').style.display = 'flex';
            document.getElementById('previewFrame').style.display = 'none';
            document.getElementById('previewError').style.display = 'none';

            // Load PDF in iframe
            const iframe = document.getElementById('previewFrame');
            iframe.src = `/Permit/PreviewPdf/${permitId}`;

            // Handle iframe load
            iframe.onload = function() {
                document.getElementById('previewLoader').style.display = 'none';
                iframe.style.display = 'block';
                document.getElementById('previewDocumentName').textContent = 'Dokumen Izin Pengeluaran Ternak';
            };

            iframe.onerror = function() {
                document.getElementById('previewLoader').style.display = 'none';
                document.getElementById('previewError').style.display = 'flex';
            };

            // Fallback timeout
            setTimeout(() => {
                if (document.getElementById('previewLoader').style.display !== 'none') {
                    document.getElementById('previewLoader').style.display = 'none';
                    iframe.style.display = 'block';
                }
            }, 3000);

            modal.show();
        }

        document.getElementById('Comments').addEventListener('input', function() {
            this.style.height = 'auto';
            this.style.height = (this.scrollHeight) + 'px';
        });

    </script>

@{
    ViewData["Title"] = "Test User Data";
}

<div class="container mt-4">
    <h2>Test User Data</h2>
    <button type="button" class="btn btn-primary" onclick="testUserData()">Test User Data</button>
    <div id="testResult" class="mt-3"></div>
</div>

@section Scripts {
    <script>
        function testUserData() {
            $.get('/Permit/TestUserData')
                .done(function(response) {
                    console.log('Test response:', response);
                    if (response.success) {
                        var html = '<h4>User Data:</h4><ul>';
                        response.data.forEach(function(user) {
                            html += `<li>ID: ${user.Id}, Nama: ${user.NamaLengkap}, Email: ${user.Email}, Role: ${user.Role}</li>`;
                        });
                        html += '</ul>';
                        $('#testResult').html(html);
                    } else {
                        $('#testResult').html('<p class="text-danger">Error: ' + response.message + '</p>');
                    }
                })
                .fail(function(xhr, status, error) {
                    console.log('Test error:', xhr, status, error);
                    $('#testResult').html('<p class="text-danger">Failed to load data</p>');
                });
        }
    </script>
} 
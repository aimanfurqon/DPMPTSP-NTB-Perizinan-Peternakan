<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistem Perizinan Peternakan</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="icon" type="image/png" href="~/images/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/accessibility-widget.css" asp-append-version="true" />
    <style>
        :root {
            --background-color: #f0f2f5;
            --card-background: #ffffff;
            --shadow-color: rgba(0, 0, 0, 0.1);
            --primary-text: #333;
        }

        body {
            font-family: 'Poppins', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--background-color);
            background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23d4d6d9' fill-opacity='0.4'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 1rem;
        }

        .login-container {
            width: 100%;
            max-width: 450px;
            background-color: var(--card-background);
            padding: 2.5rem;
            border-radius: 12px;
            box-shadow: 0 10px 25px var(--shadow-color);
            transition: all 0.3s ease;
        }

        .alert {
            border-radius: 8px;
        }

        .login-container h2 {
            margin-bottom: 1.5rem;
            font-weight: 600;
            color: var(--primary-text);
        }

    </style>
</head>
<body>
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show position-fixed" style="top: 20px; right: 20px; z-index: 9999; max-width: 400px;" role="alert">
            <i class="fas fa-check-circle me-2"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show position-fixed" style="top: 20px; right: 20px; z-index: 9999; max-width: 400px;" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <main class="login-container">
        @RenderBody()
    </main>

    <!-- Reading Guide for Accessibility -->
    <div class="reading-guide" id="readingGuide"></div>

    <!-- Accessibility Widget -->
    <div class="accessibility-widget">
        <div class="accessibility-panel" id="accessibilityPanel">
            <div class="panel-header">
                <h3><i class="fas fa-universal-access"></i> Aksesibilitas</h3>
            </div>
            <div class="panel-content">
                <!-- Font Size -->
                <div class="accessibility-option">
                    <div class="option-info">
                        <div class="option-icon">
                            <i class="fas fa-text-height"></i>
                        </div>
                        <div class="option-text">
                            <h4>Ukuran Teks</h4>
                            <p>Sesuaikan ukuran teks</p>
                        </div>
                    </div>
                    <div class="range-container">
                        <input type="range" class="range-input" id="fontSizeRange" min="50" max="200" value="100">
                        <span class="range-value" id="fontSizeValue">100%</span>
                    </div>
                </div>

                <!-- High Contrast -->
                <div class="accessibility-option">
                    <div class="option-info">
                        <div class="option-icon">
                            <i class="fas fa-adjust"></i>
                        </div>
                        <div class="option-text">
                            <h4>Kontras Tinggi</h4>
                            <p>Tingkatkan kontras warna</p>
                        </div>
                    </div>
                    <div class="toggle-switch" id="contrastToggle"></div>
                </div>

                <!-- Large Text -->
                <div class="accessibility-option">
                    <div class="option-info">
                        <div class="option-icon">
                            <i class="fas fa-font"></i>
                        </div>
                        <div class="option-text">
                            <h4>Teks Besar</h4>
                            <p>Perbesar semua teks</p>
                        </div>
                    </div>
                    <div class="toggle-switch" id="largeTextToggle"></div>
                </div>

                <!-- Big Cursor -->
                <div class="accessibility-option">
                    <div class="option-info">
                        <div class="option-icon">
                            <i class="fas fa-mouse-pointer"></i>
                        </div>
                        <div class="option-text">
                            <h4>Kursor Besar</h4>
                            <p>Perbesar ukuran kursor</p>
                        </div>
                    </div>
                    <div class="toggle-switch" id="bigCursorToggle"></div>
                </div>

                <!-- Reading Guide -->
                <div class="accessibility-option">
                    <div class="option-info">
                        <div class="option-icon">
                            <i class="fas fa-eye"></i>
                        </div>
                        <div class="option-text">
                            <h4>Panduan Baca</h4>
                            <p>Garis panduan untuk membaca</p>
                        </div>
                    </div>
                    <div class="toggle-switch" id="readingGuideToggle"></div>
                </div>

                <!-- Dyslexia Font -->
                <div class="accessibility-option">
                    <div class="option-info">
                        <div class="option-icon">
                            <i class="fas fa-language"></i>
                        </div>
                        <div class="option-text">
                            <h4>Font Disleksia</h4>
                            <p>Font ramah disleksia</p>
                        </div>
                    </div>
                    <div class="toggle-switch" id="dyslexiaFontToggle"></div>
                </div>

                <!-- Grayscale -->
                <div class="accessibility-option">
                    <div class="option-info">
                        <div class="option-icon">
                            <i class="fas fa-palette"></i>
                        </div>
                        <div class="option-text">
                            <h4>Mode Grayscale</h4>
                            <p>Tampilkan dalam skala abu-abu</p>
                        </div>
                    </div>
                    <div class="toggle-switch" id="grayscaleToggle"></div>
                </div>

                <!-- Invert Colors -->
                <div class="accessibility-option">
                    <div class="option-info">
                        <div class="option-icon">
                            <i class="fas fa-exchange-alt"></i>
                        </div>
                        <div class="option-text">
                            <h4>Balik Warna</h4>
                            <p>Inversi semua warna</p>
                        </div>
                    </div>
                    <div class="toggle-switch" id="invertColorsToggle"></div>
                </div>

                <!-- Reset Button -->
                <button class="reset-button" id="resetButton">
                    <i class="fas fa-undo"></i> Reset Semua Pengaturan
                </button>
            </div>
        </div>

        <button class="accessibility-toggle" id="accessibilityToggle" aria-label="Buka panel aksesibilitas">
            <i class="fas fa-universal-access"></i>
        </button>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/accessibility-widget.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const alerts = document.querySelectorAll('.alert');
            if (alerts.length > 0) {
                setTimeout(() => {
                    alerts.forEach(alert => {
                        new bootstrap.Alert(alert).close();
                    });
                }, 5000);
            }
        });
    </script>
</body>
</html>
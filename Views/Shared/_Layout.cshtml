<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistem Perizinan Peternakan</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="icon" type="image/png" href="~/images/favicon.png" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg custom-navbar">
            <div class="container">
                <a class="navbar-brand" href="@Url.Action("Index", "Dashboard")">
                    <img src="~/images/logo-ntb.png" alt="Logo" class="navbar-logo" />
                    <span class="brand-text">
                        <strong>Perizinan Peternakan</strong>
                        <small>DPMPTSP NTB</small>
                    </span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Index", "Dashboard")">
                                <i class="fas fa-home"></i> Dashboard
                            </a>
                        </li>

                        @if (Context.Session.GetString("Role") == "User")
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-file-alt"></i> Permohonan Saya
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="@Url.Action("Create", "Permit")"><i class="fas fa-plus"></i> Permohonan Baru</a></li>
                                    <li><a class="dropdown-item" href="@Url.Action("Index", "Permit")"><i class="fas fa-list"></i> Daftar Permohonan</a></li>
                                </ul>
                            </li>
                        }

                        @if (Context.Session.GetString("Role") == "Admin")
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-clipboard-check"></i> Administrasi
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="@Url.Action("Index", "Permit")"><i class="fas fa-tasks"></i> Perlu Review Data</a></li>
                                    <li><a class="dropdown-item" href="@Url.Action("AdminHistory", "Permit")"><i class="fas fa-history"></i> Riwayat Review</a></li>
                                </ul>
                            </li>
                        }

                        @if (Context.Session.GetString("Role") == "Verifikator")
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-file-signature"></i> Verifikasi
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="@Url.Action("Index", "Permit")"><i class="fas fa-clipboard-check"></i> Verifikasi Dokumen</a></li>
                                    <li><a class="dropdown-item" href="@Url.Action("VerifikatorHistory", "Permit")"><i class="fas fa-history"></i> Riwayat Verifikasi</a></li>
                                </ul>
                            </li>
                        }

                        @if (Context.Session.GetString("Role") == "KepalaDinas")
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-stamp"></i> Persetujuan
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="@Url.Action("Index", "Permit")"><i class="fas fa-gavel"></i> Perlu Persetujuan</a></li>
                                    <li><a class="dropdown-item" href="@Url.Action("KepalaDinasHistory", "Permit")"><i class="fas fa-history"></i> Riwayat Persetujuan</a></li>
                                </ul>
                            </li>

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-cogs"></i> Manajemen
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="#"><i class="fas fa-chart-bar"></i> Laporan</a></li>
                                    <li><a class="dropdown-item" href="#"><i class="fas fa-users"></i> Kelola Pengguna</a></li>
                                    <li><a class="dropdown-item" href="#"><i class="fas fa-cog"></i> Pengaturan</a></li>
                                </ul>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle user-menu" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-user-circle"></i>
                                <div>
                                    <span>@Context.Session.GetString("NamaLengkap")</span>
                                    <small class="user-role">@Context.Session.GetString("Role")</small>
                                </div>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="@Url.Action("Profile", "Auth")"><i class="fas fa-user"></i> Profile</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="fas fa-sign-out-alt"></i> Logout
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="main-content-wrapper">
        <div class="container">
            <main role="main" class="py-3">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="fas fa-check-circle me-2"></i>
                        @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        @TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="custom-footer">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <p>&copy; @DateTime.Now.Year - Sistem Perizinan Peternakan</p>
                    <p class="small">Dinas Penanaman Modal dan Pelayanan Terpadu Satu Pintu</p>
                    <p class="small">Provinsi Nusa Tenggara Barat</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p class="small">Versi 1.0.0</p>
                    <p class="small">Dukungan Teknis: IT DPMPTSP NTB</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

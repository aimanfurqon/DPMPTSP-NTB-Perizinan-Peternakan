@model PerizinanPeternakan.ViewModels.DashboardStatsViewModel
@{
    ViewData["Title"] = "Dashboard";
    var userRole = ViewData["UserRole"]?.ToString();
    var userName = ViewData["UserName"]?.ToString();
}

<div class="dashboard-container">
    <!-- Header Section -->
    <div class="header-section">
        <div class="header-content">
            <div class="welcome-info">
                <h1>
                    <i class="fas fa-home"></i>
                    Selamat Datang, @userName!
                </h1>
                <p>Sistem Perizinan Peternakan - DPMPTSP NTB</p>
                <span class="user-badge">@userRole</span>
            </div>
            <div class="quick-stats">
                <div class="quick-stat">
                    <span class="number">@Model.TotalApplications</span>
                    <span class="label">Total</span>
                </div>
                @if (userRole == "User")
                {
                    <div class="quick-stat">
                        <span class="number">@(Model.PendingAdminReview + Model.PendingVerifikatorReview + Model.PendingKepalaDinas)</span>
                        <span class="label">Pending</span>
                    </div>
                }
                else if (userRole == "Admin")
                {
                    <div class="quick-stat">
                        <span class="number">@Model.PendingAdminReview</span>
                        <span class="label">Need Review</span>
                    </div>
                }
                else if (userRole == "Verifikator")
                {
                    <div class="quick-stat">
                        <span class="number">@Model.PendingVerifikatorReview</span>
                        <span class="label">Need Verify</span>
                    </div>
                }
                else if (userRole == "KepalaDinas")
                {
                    <div class="quick-stat">
                        <span class="number">@Model.PendingKepalaDinas</span>
                        <span class="label">Need Approval</span>
                    </div>
                }
                <div class="quick-stat">
                    <span class="number">@Model.ApprovedThisMonth</span>
                    <span class="label">Approved</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon default">
                <i class="fas fa-file-alt"></i>
            </div>
            <div class="stat-content">
                <div class="number">@Model.TotalApplications</div>
                <div class="label">
                    @if (userRole == "User")
                    {
                        <text>Total Permohonan Saya</text>
                    }
                    else
                    {
                        <text>Total Permohonan</text>
                    }
                </div>
                <div class="stat-trend">
                    <i class="fas fa-info-circle"></i> Data terkini
                </div>
            </div>
        </div>

        @if (userRole == "User")
        {
            <div class="stat-card">
                <div class="stat-icon pending">
                    <i class="fas fa-clock"></i>
                </div>
                <div class="stat-content">
                    <div class="number">@(Model.PendingAdminReview + Model.PendingVerifikatorReview + Model.PendingKepalaDinas)</div>
                    <div class="label">Sedang Diproses</div>
                    <div class="stat-trend">
                        <i class="fas fa-hourglass-half"></i> Menunggu tindakan
                    </div>
                </div>
            </div>
        }
        else if (userRole == "Admin")
        {
            <div class="stat-card">
                <div class="stat-icon pending">
                    <i class="fas fa-clipboard-check"></i>
                </div>
                <div class="stat-content">
                    <div class="number">@Model.PendingAdminReview</div>
                    <div class="label">Perlu Review Admin</div>
                    <div class="stat-trend">
                        <i class="fas fa-exclamation-triangle"></i> Butuh tindakan
                    </div>
                </div>
            </div>
        }
        else if (userRole == "Verifikator")
        {
            <div class="stat-card">
                <div class="stat-icon pending">
                    <i class="fas fa-search"></i>
                </div>
                <div class="stat-content">
                    <div class="number">@Model.PendingVerifikatorReview</div>
                    <div class="label">Perlu Verifikasi</div>
                    <div class="stat-trend">
                        <i class="fas fa-exclamation-triangle"></i> Butuh tindakan
                    </div>
                </div>
            </div>
        }
        else if (userRole == "KepalaDinas")
        {
            <div class="stat-card">
                <div class="stat-icon pending">
                    <i class="fas fa-user-tie"></i>
                </div>
                <div class="stat-content">
                    <div class="number">@Model.PendingKepalaDinas</div>
                    <div class="label">Perlu Persetujuan</div>
                    <div class="stat-trend">
                        <i class="fas fa-exclamation-triangle"></i> Butuh tindakan
                    </div>
                </div>
            </div>
        }

        @if (userRole != "User")
        {
            <div class="stat-card">
                <div class="stat-icon warning">
                    <i class="fas fa-chart-line"></i>
                </div>
                <div class="stat-content">
                    <div class="number">@(Model.PendingAdminReview + Model.PendingVerifikatorReview + Model.PendingKepalaDinas)</div>
                    <div class="label">Total Pending</div>
                    <div class="stat-trend">
                        <i class="fas fa-tasks"></i> Semua status
                    </div>
                </div>
            </div>
        }

        <div class="stat-card">
            <div class="stat-icon approved">
                <i class="fas fa-check-circle"></i>
            </div>
            <div class="stat-content">
                <div class="number">@Model.ApprovedThisMonth</div>
                <div class="label">Disetujui Bulan Ini</div>
                <div class="stat-trend">
                    <i class="fas fa-calendar-check"></i> Bulan @DateTime.Now.ToString("MMMM")
                </div>
            </div>
        </div>
    </div>

    <!-- Content Grid -->
    <div class="content-grid">
        <!-- Recent Applications -->
        <div class="content-card">
            <div class="card-header">
                <h3>
                    <i class="fas fa-list"></i>
                    @if (userRole == "User")
                    {
                        <text>Permohonan Terbaru</text>
                    }
                    else
                    {
                        <text>Aktivitas Terbaru</text>
                    }
                </h3>
                <a href="@Url.Action("Index", "Permit")" class="view-all-link">
                    Lihat Semua <i class="fas fa-arrow-right"></i>
                </a>
            </div>
            <div class="card-body">
                @if (Model.RecentApplications?.Any() == true)
                {
                    <div class="application-list">
                        @foreach (var app in Model.RecentApplications)
                        {
                            <div class="application-item @(app.Status == PerizinanPeternakan.Models.PermitStatus.Submitted ? "urgent" : "")">
                                <div class="app-info">
                                    <div class="app-header">
                                        <span class="app-number">@app.ApplicationNumber</span>
                                        <span class="status-badge badge-@PermitStatusHelper.GetStatusClass(app.Status)">
                                            @PermitStatusHelper.GetStatusText(app.Status)
                                        </span>
                                    </div>
                                    <h4 class="app-company">@app.CompanyName</h4>
                                    @if (!string.IsNullOrEmpty(app.ApplicantName))
                                    {
                                        <p class="app-applicant">
                                            <i class="fas fa-user"></i>
                                            @app.ApplicantName
                                        </p>
                                    }
                                    <div class="app-details">
                                        <span class="app-route">
                                            <i class="fas fa-route"></i>
                                            @app.OriginLocation → @app.DestinationLocation
                                        </span>
                                        <span class="app-date">
                                            <i class="fas fa-calendar"></i>
                                            @app.SubmissionDate.ToString("dd/MM/yyyy")
                                        </span>
                                    </div>
                                </div>
                                <div class="app-actions">
                                    <a href="@Url.Action("Detail", "Permit", new { id = app.Id })"
                                       class="btn btn-sm btn-outline-primary"
                                       title="Lihat Detail">
                                        <i class="fas fa-eye"></i>
                                        <span class="btn-text">Lihat</span>
                                    </a>
                                    @if (userRole != "User" &&
                                                                ((userRole == "Admin" && (app.Status == PerizinanPeternakan.Models.PermitStatus.Submitted || app.Status == PerizinanPeternakan.Models.PermitStatus.UnderAdminReview)) ||
                                                                (userRole == "Verifikator" && (app.Status == PerizinanPeternakan.Models.PermitStatus.AdminApproved || app.Status == PerizinanPeternakan.Models.PermitStatus.UnderVerifikatorReview)) ||
                                                                (userRole == "KepalaDinas" && (app.Status == PerizinanPeternakan.Models.PermitStatus.VerifikatorApproved || app.Status == PerizinanPeternakan.Models.PermitStatus.PendingKepalaDinas))))
                                    {
                                        <a href="@Url.Action("Approve", "Permit", new { id = app.Id })"
                                           class="btn btn-sm btn-warning"
                                           title="Proses Permohonan">
                                            <i class="fas fa-gavel"></i>
                                            <span class="btn-text">Proses</span>
                                        </a>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <i class="fas fa-inbox"></i>
                        <p>Tidak ada data untuk ditampilkan</p>
                        @if (userRole == "User")
                        {
                            <a href="@Url.Action("Create", "Permit")" class="btn btn-primary">
                                <i class="fas fa-plus"></i>
                                Buat Permohonan Baru
                            </a>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Pending Approvals for Non-Users -->
        @if (userRole != "User" && Model.MyPendingApprovals?.Any() == true)
        {
            <div class="content-card">
                <div class="card-header">
                    <h3>
                        <i class="fas fa-tasks"></i>
                        @if (userRole == "Admin")
                        {
                            <text>Perlu Review</text>
                        }
                        else if (userRole == "Verifikator")
                        {
                            <text>Perlu Verifikasi</text>
                        }
                        else
                        {
                            <text>Perlu Persetujuan</text>
                        }
                    </h3>
                    <span class="pending-count">@Model.MyPendingApprovals.Count</span>
                </div>
                <div class="card-body">
                    <div class="application-list">
                        @foreach (var app in Model.MyPendingApprovals)
                        {
                            <div class="application-item urgent">
                                <div class="app-info">
                                    <div class="app-header">
                                        <span class="app-number">@app.ApplicationNumber</span>
                                        <span class="urgency-indicator">
                                            <i class="fas fa-exclamation-triangle"></i>
                                        </span>
                                    </div>
                                    <h4 class="app-company">@app.CompanyName</h4>
                                    @if (!string.IsNullOrEmpty(app.ApplicantName))
                                    {
                                        <p class="app-applicant">
                                            <i class="fas fa-user"></i>
                                            @app.ApplicantName
                                        </p>
                                    }
                                    <div class="app-details">
                                        <span class="app-route">
                                            <i class="fas fa-route"></i>
                                            @app.OriginLocation → @app.DestinationLocation
                                        </span>
                                        <span class="app-date">
                                            <i class="fas fa-clock"></i>
                                            @((DateTime.Now - app.SubmissionDate).Days) hari yang lalu
                                        </span>
                                    </div>
                                </div>
                                <div class="app-actions">
                                    <a href="@Url.Action("Approve", "Permit", new { id = app.Id })"
                                       class="btn btn-sm btn-primary"
                                       title="Proses Permohonan">
                                        <i class="fas fa-gavel"></i>
                                        Proses
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- Quick Actions for Users -->
        @if (userRole == "User")
        {
            <div class="content-card">
                <div class="card-header">
                    <h3>
                        <i class="fas fa-plus-circle"></i>
                        Aksi Cepat
                    </h3>
                </div>
                <div class="card-body">
                    <div class="quick-actions">
                        <a href="@Url.Action("Create", "Permit")" class="quick-action-item">
                            <div class="action-icon">
                                <i class="fas fa-file-plus"></i>
                            </div>
                            <div class="action-content">
                                <h4>Permohonan Baru</h4>
                                <p>Buat permohonan izin pengeluaran ternak</p>
                            </div>
                        </a>

                        <a href="@Url.Action("Index", "Permit")" class="quick-action-item">
                            <div class="action-icon">
                                <i class="fas fa-search"></i>
                            </div>
                            <div class="action-content">
                                <h4>Cek Status</h4>
                                <p>Lihat status permohonan Anda</p>
                            </div>
                        </a>

                        <a href="@Url.Action("Profile", "Auth")" class="quick-action-item">
                            <div class="action-icon">
                                <i class="fas fa-user-edit"></i>
                            </div>
                            <div class="action-content">
                                <h4>Update Profile</h4>
                                <p>Perbarui informasi akun Anda</p>
                            </div>
                        </a>

                        <a href="@Url.Action("Help", "Home")" class="quick-action-item">
                            <div class="action-icon">
                                <i class="fas fa-question-circle"></i>
                            </div>
                            <div class="action-content">
                                <h4>Bantuan</h4>
                                <p>Panduan dan FAQ sistem</p>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        min-height: 100vh;
        line-height: 1.6;
    }

    .dashboard-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 20px;
    }

    /* Header Section */
    .header-section {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 2rem;
        border-radius: 20px;
        margin-bottom: 2rem;
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

        .header-section::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 100%;
            height: 200%;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            transform: rotate(15deg);
        }

    .header-content {
        position: relative;
        z-index: 2;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .welcome-info h1 {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .welcome-info p {
        font-size: 1.1rem;
        opacity: 0.9;
        margin-bottom: 1rem;
    }

    .user-badge {
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        padding: 0.5rem 1rem;
        border-radius: 25px;
        font-size: 0.9rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .quick-stats {
        display: flex;
        gap: 1rem;
        align-items: center;
    }

    .quick-stat {
        text-align: center;
        padding: 0.5rem;
    }

        .quick-stat .number {
            font-size: 1.5rem;
            font-weight: 700;
            display: block;
        }

        .quick-stat .label {
            font-size: 0.8rem;
            opacity: 0.8;
        }

    /* Stats Grid */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: white;
        padding: 1.5rem;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        display: flex;
        align-items: center;
        gap: 1rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
    }

        .stat-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15);
        }

    .stat-icon {
        width: 60px;
        height: 60px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: white;
        position: relative;
        overflow: hidden;
    }

        .stat-icon::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(45deg, transparent 30%, rgba(255, 255, 255, 0.1) 50%, transparent 70%);
            transform: translateX(-100%);
            transition: transform 0.6s;
        }

    .stat-card:hover .stat-icon::before {
        transform: translateX(100%);
    }

    .stat-icon.default {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .stat-icon.pending {
        background: linear-gradient(135deg, #ffc107 0%, #ff8c42 100%);
    }

    .stat-icon.warning {
        background: linear-gradient(135deg, #fd7e14 0%, #ff6b6b 100%);
    }

    .stat-icon.approved {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
    }

    .stat-content {
        flex: 1;
    }

        .stat-content .number {
            font-size: 2rem;
            font-weight: 700;
            color: #333;
            margin-bottom: 0.25rem;
        }

        .stat-content .label {
            color: #666;
            font-size: 0.9rem;
            font-weight: 500;
            margin-bottom: 0.25rem;
        }

    .stat-trend {
        font-size: 0.8rem;
        color: #28a745;
        margin-top: 0.25rem;
    }

    /* Content Grid */
    .content-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .content-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        overflow: hidden;
        transition: transform 0.3s;
    }

        .content-card:hover {
            transform: translateY(-2px);
        }

    .card-header {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        padding: 1.5rem;
        border-bottom: 1px solid #e9ecef;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .card-header h3 {
            color: #333;
            font-size: 1.1rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .card-header i {
            color: #667eea;
        }

    .view-all-link {
        color: #667eea;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 0.25rem;
        transition: color 0.3s;
    }

        .view-all-link:hover {
            color: #5a6fd8;
        }

    .pending-count {
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        color: white;
        padding: 0.25rem 0.75rem;
        border-radius: 12px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .card-body {
        padding: 1.5rem;
    }

    /* Application Items */
    .application-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem;
        background: #f8f9fa;
        border-radius: 12px;
        margin-bottom: 1rem;
        transition: all 0.3s;
        border-left: 4px solid transparent;
    }

        .application-item:hover {
            background: #e9ecef;
            transform: translateX(4px);
        }

        .application-item.urgent {
            border-left-color: #dc3545;
            background: linear-gradient(135deg, #fff5f5 0%, #ffe6e6 100%);
        }

            .application-item.urgent:hover {
                background: linear-gradient(135deg, #ffe6e6 0%, #ffcccc 100%);
            }

    .app-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.5rem;
    }

    .app-number {
        font-size: 0.8rem;
        color: #666;
        font-weight: 600;
        background: rgba(102, 126, 234, 0.1);
        padding: 0.25rem 0.5rem;
        border-radius: 8px;
    }

    .status-badge {
        padding: 0.25rem 0.75rem;
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
    }

    .urgency-indicator {
        color: #dc3545;
        font-size: 1rem;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0%

    {
        transform: scale(1);
        opacity: 1;
    }

    50% {
        transform: scale(1.1);
        opacity: 0.7;
    }

    100% {
        transform: scale(1);
        opacity: 1;
    }

    }

    .app-company {
        font-size: 1rem;
        font-weight: 600;
        color: #333;
        margin-bottom: 0.25rem;
    }

    .app-applicant {
        font-size: 0.85rem;
        color: #666;
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .app-details {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .app-route, .app-date {
        font-size: 0.85rem;
        color: #666;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .app-actions {
        display: flex;
        gap: 0.5rem;
    }

    .btn {
        padding: 0.5rem 1rem;
        border: none;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 500;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        transition: all 0.3s;
        cursor: pointer;
    }

    .btn-sm {
        padding: 0.375rem 0.75rem;
        font-size: 0.8rem;
    }

    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
        }

    .btn-outline-primary {
        border: 1px solid #667eea;
        color: #667eea;
        background: transparent;
    }

        .btn-outline-primary:hover {
            background: #667eea;
            color: white;
        }

    .btn-warning {
        background: linear-gradient(135deg, #ffc107 0%, #ff8c42 100%);
        color: white;
    }

        .btn-warning:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(255, 193, 7, 0.4);
        }

    /* Quick Actions */
    .quick-actions {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .quick-action-item {
        display: flex;
        align-items: center;
        padding: 1rem;
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        border-radius: 12px;
        text-decoration: none;
        color: inherit;
        transition: all 0.3s;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

        .quick-action-item:hover {
